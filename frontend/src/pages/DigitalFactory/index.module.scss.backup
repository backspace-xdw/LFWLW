.digitalFactory {
  width: 100%;
  height: 100%;
  background: linear-gradient(to bottom, #000000 0%, #0a0e1a 50%, #000000 100%);
  overflow: hidden;
  position: relative;

  &::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background:
      radial-gradient(ellipse at top, rgba(52, 152, 219, 0.08) 0%, transparent 50%),
      radial-gradient(ellipse at bottom, rgba(41, 128, 185, 0.06) 0%, transparent 50%);
    pointer-events: none;
  }

  .header {
    position: relative;
    width: 100%;
    height: 100px;
    background: linear-gradient(180deg,
      rgba(6, 22, 74, 0.95) 0%,
      rgba(27, 38, 79, 0.85) 50%,
      rgba(6, 22, 74, 0.95) 100%
    );
    z-index: 10;
    border-bottom: 2px solid rgba(2, 166, 181, 0.3);

    .headerContent {
      height: 100%;
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 0 30px;
      position: relative;

      // 左侧导航按钮组
      .navButtons {
        display: flex;
        gap: 12px;
        z-index: 2;

        .navBtn {
          min-width: 100px;
          height: 36px;
          padding: 0 20px;
          background: rgba(2, 166, 181, 0.1);
          border: 1px solid rgba(2, 166, 181, 0.3);
          color: #fff;
          font-size: 14px;
          font-weight: 500;
          text-align: center;
          line-height: 36px;
          cursor: pointer;
          transition: all 0.3s ease;
          position: relative;

          &:hover {
            border-color: rgba(129, 231, 237, 0.6);
            background: rgba(2, 166, 181, 0.2);
            color: #81E7ED;
          }

          &.active {
            background: rgba(2, 166, 181, 0.3);
            border-color: #81E7ED;
            color: #81E7ED;
            box-shadow: 0 0 15px rgba(2, 166, 181, 0.4);
          }
        }
      }

      .titleContainer {
        position: absolute;
        left: 50%;
        top: 50%;
        transform: translate(-50%, -50%);
        display: flex;
        align-items: center;
        gap: 0;

        .titleDecorLeft,
        .titleDecorRight {
          display: none; // 隐藏装饰，保持简洁
        }

        .titleWrapper {
          .mainTitle {
            margin: 0;
            font-size: 38px;
            font-weight: 600;
            letter-spacing: 4px;
            white-space: nowrap;
            font-family: 'Microsoft YaHei UI', 'Microsoft YaHei', 'PingFang SC', sans-serif;
            color: #81E7ED;
            text-align: center;
            text-shadow: 0 0 10px rgba(129, 231, 237, 0.6);
          }
        }
      }

      .datetime {
        font-size: 16px;
        color: #81E7ED;
        font-weight: 600;
        letter-spacing: 1px;
        font-family: 'Consolas', 'Monaco', 'Courier New', monospace;
      }
    }
  }

  .mainContent {
    position: relative;
    height: calc(100% - 100px);
    overflow: hidden;
  }

  .centerPanel {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    z-index: 1;

    .scene3d {
      width: 100%;
      height: 100%;
      background: transparent;
      overflow: hidden;
      position: relative;

      canvas {
        position: relative;
        z-index: 1;
        cursor: grab;

        &:active {
          cursor: grabbing;
        }
      }
    }
  }

  .leftPanel,
  .rightPanel {
    position: absolute;
    top: 0;
    bottom: 0;
    width: 380px;
    display: flex;
    flex-direction: column;
    gap: 16px;
    padding: 20px;
    overflow-y: auto;
    z-index: 10;
    pointer-events: none;

    > * {
      pointer-events: auto;
    }

    &::-webkit-scrollbar {
      width: 6px;
    }

    &::-webkit-scrollbar-track {
      background: rgba(255, 255, 255, 0.05);
      border-radius: 3px;
    }

    &::-webkit-scrollbar-thumb {
      background: rgba(52, 152, 219, 0.5);
      border-radius: 3px;

      &:hover {
        background: rgba(52, 152, 219, 0.7);
      }
    }
  }

  .leftPanel {
    left: 0;
  }

  .rightPanel {
    right: 0;
  }

  .card {
    background: linear-gradient(135deg, rgba(13, 27, 42, 0.4) 0%, rgba(10, 22, 40, 0.3) 100%) !important;
    border: 1px solid rgba(52, 152, 219, 0.3) !important;
    border-radius: 12px !important;
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.3),
      0 0 0 1px rgba(52, 152, 219, 0.1) inset,
      0 0 20px rgba(52, 152, 219, 0.05) inset !important;
    transition: all 0.3s ease;
    position: relative;
    overflow: hidden;

    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: linear-gradient(
        135deg,
        rgba(52, 152, 219, 0.05) 0%,
        transparent 50%,
        rgba(52, 152, 219, 0.03) 100%
      );
      pointer-events: none;
    }

    &:hover {
      background: linear-gradient(135deg, rgba(13, 27, 42, 0.5) 0%, rgba(10, 22, 40, 0.4) 100%) !important;
      border-color: rgba(52, 152, 219, 0.5) !important;
      box-shadow:
        0 12px 40px rgba(52, 152, 219, 0.2),
        0 0 0 1px rgba(52, 152, 219, 0.2) inset,
        0 0 30px rgba(52, 152, 219, 0.1) inset !important;
      transform: translateY(-2px);
    }

    :global {
      .ant-card-head {
        color: #3498db !important;
        border-bottom: 1px solid rgba(52, 152, 219, 0.2) !important;
        font-weight: 600;
        font-size: 16px;
        padding: 12px 16px;
      }

      .ant-card-body {
        color: #ecf0f1 !important;
        padding: 16px;
      }

      .ant-statistic-title {
        color: rgba(236, 240, 241, 0.7) !important;
        font-size: 13px;
      }

      .ant-statistic-content {
        color: #ecf0f1 !important;
        font-size: 18px;
      }

      .ant-progress-bg {
        background: linear-gradient(90deg, #2ecc71, #27ae60) !important;
      }

      .ant-progress-inner {
        background: rgba(255, 255, 255, 0.1) !important;
      }
    }
  }

  .processInfo,
  .personnelInfo {
    font-size: 14px;
    line-height: 2;
    color: #ecf0f1;

    > div {
      padding: 4px 0;
      border-bottom: 1px dashed rgba(52, 152, 219, 0.15);

      &:last-child {
        border-bottom: none;
      }
    }
  }

  .attendanceRate {
    font-size: 15px;
    font-weight: 600;
    color: #3498db;
    margin-bottom: 12px;
    padding-bottom: 8px;
    border-bottom: 2px solid rgba(52, 152, 219, 0.3);
  }

  // BigDataView风格的数据标签
  .dataTag {
    position: relative;
    padding: 16px 20px;
    background: linear-gradient(135deg,
      rgba(0, 100, 180, 0.12) 0%,
      rgba(0, 50, 120, 0.18) 100%
    );
    border: 1px solid rgba(0, 180, 255, 0.35);
    border-radius: 6px;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: pointer;

    // 顶部发光线
    &::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      height: 2px;
      background: linear-gradient(90deg,
        transparent 0%,
        rgba(0, 200, 255, 0.6) 20%,
        rgba(0, 255, 255, 0.9) 50%,
        rgba(0, 200, 255, 0.6) 80%,
        transparent 100%
      );
      opacity: 0.8;
    }

    // 左侧竖线装饰
    &::after {
      content: '';
      position: absolute;
      left: 0;
      top: 0;
      bottom: 0;
      width: 3px;
      background: linear-gradient(180deg,
        rgba(0, 200, 255, 0.3) 0%,
        rgba(0, 255, 255, 0.8) 50%,
        rgba(0, 200, 255, 0.3) 100%
      );
      box-shadow: 0 0 10px rgba(0, 200, 255, 0.6);
    }

    &:hover {
      transform: translateY(-3px);
      background: linear-gradient(135deg,
        rgba(0, 120, 200, 0.18) 0%,
        rgba(0, 70, 150, 0.25) 100%
      );
      border-color: rgba(0, 200, 255, 0.6);
      box-shadow:
        0 8px 25px rgba(0, 180, 255, 0.25),
        inset 0 0 30px rgba(0, 200, 255, 0.1);

      .dataTagValue {
        transform: scale(1.05);
        text-shadow:
          0 0 15px rgba(0, 200, 255, 1),
          0 0 30px rgba(0, 150, 255, 0.8);
      }
    }

    .dataTagLabel {
      font-size: 14px;
      color: rgba(200, 230, 255, 0.85);
      margin-bottom: 8px;
      font-weight: 500;
      letter-spacing: 1px;
      display: flex;
      align-items: center;
      gap: 8px;

      // 图标装饰
      &::before {
        content: '';
        width: 6px;
        height: 6px;
        background: rgba(0, 200, 255, 0.7);
        border-radius: 50%;
        box-shadow: 0 0 8px rgba(0, 200, 255, 0.8);
        animation: pulse 2s ease-in-out infinite;
      }
    }

    .dataTagValue {
      font-size: 28px;
      font-weight: 700;
      color: #00d4ff;
      font-family: 'Arial', 'Consolas', 'Courier New', monospace;
      letter-spacing: 2px;
      text-shadow:
        0 0 10px rgba(0, 200, 255, 0.8),
        0 0 20px rgba(0, 150, 255, 0.6);
      transition: all 0.3s ease;
      display: flex;
      align-items: baseline;
      gap: 4px;

      .dataTagUnit {
        font-size: 14px;
        color: rgba(0, 200, 255, 0.7);
        font-weight: 400;
        margin-left: 4px;
      }
    }

    .dataTagTrend {
      margin-top: 8px;
      font-size: 12px;
      display: flex;
      align-items: center;
      gap: 4px;

      &.up {
        color: #00ff88;

        &::before {
          content: '↑';
          font-size: 14px;
        }
      }

      &.down {
        color: #ff4444;

        &::before {
          content: '↓';
          font-size: 14px;
        }
      }

      &.flat {
        color: #ffaa00;

        &::before {
          content: '→';
          font-size: 14px;
        }
      }
    }
  }

  // 小型指标卡片
  .metricCard {
    position: relative;
    padding: 12px 16px;
    background: rgba(0, 50, 100, 0.15);
    border: 1px solid rgba(0, 180, 255, 0.25);
    border-left: 3px solid rgba(0, 200, 255, 0.7);
    border-radius: 4px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    transition: all 0.3s ease;

    &:hover {
      background: rgba(0, 70, 130, 0.25);
      border-color: rgba(0, 200, 255, 0.5);
      border-left-color: rgba(0, 255, 255, 1);
      box-shadow: 0 4px 15px rgba(0, 180, 255, 0.2);
    }

    .metricLabel {
      font-size: 13px;
      color: rgba(200, 230, 255, 0.8);
      font-weight: 500;
    }

    .metricValue {
      font-size: 18px;
      font-weight: 700;
      color: #00d4ff;
      font-family: 'Consolas', 'Courier New', monospace;
      text-shadow: 0 0 8px rgba(0, 200, 255, 0.6);
    }
  }

  // 状态标签
  .statusTag {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 6px 12px;
    border-radius: 4px;
    font-size: 12px;
    font-weight: 500;
    letter-spacing: 0.5px;

    &::before {
      content: '';
      width: 6px;
      height: 6px;
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }

    &.online {
      background: rgba(0, 255, 100, 0.15);
      border: 1px solid rgba(0, 255, 100, 0.4);
      color: #00ff88;

      &::before {
        background: #00ff88;
        box-shadow: 0 0 10px rgba(0, 255, 100, 0.8);
      }
    }

    &.offline {
      background: rgba(255, 68, 68, 0.15);
      border: 1px solid rgba(255, 68, 68, 0.4);
      color: #ff4444;

      &::before {
        background: #ff4444;
        box-shadow: 0 0 10px rgba(255, 68, 68, 0.8);
      }
    }

    &.warning {
      background: rgba(255, 170, 0, 0.15);
      border: 1px solid rgba(255, 170, 0, 0.4);
      color: #ffaa00;

      &::before {
        background: #ffaa00;
        box-shadow: 0 0 10px rgba(255, 170, 0, 0.8);
      }
    }
  }

  // 数据网格布局
  .dataGrid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 12px;

    &.cols3 {
      grid-template-columns: repeat(3, 1fr);
    }

    &.cols4 {
      grid-template-columns: repeat(4, 1fr);
    }
  }

  .recruitmentTable {
    .tableHeader,
    .tableRow {
      display: grid;
      grid-template-columns: repeat(5, 1fr);
      gap: 8px;
      padding: 10px 4px;
      text-align: center;
      font-size: 13px;
    }

    .tableHeader {
      background: rgba(52, 152, 219, 0.2);
      border-radius: 4px;
      font-weight: 600;
      color: #3498db;
      border: 1px solid rgba(52, 152, 219, 0.3);
    }

    .tableRow {
      border-bottom: 1px solid rgba(52, 152, 219, 0.15);
      transition: all 0.3s ease;

      &:hover {
        background: rgba(52, 152, 219, 0.1);
      }

      &:last-child {
        border-bottom: none;
      }

      span {
        color: #ecf0f1;
      }
    }
  }

  .sensorStatus {
    .statusLegend {
      display: flex;
      justify-content: space-around;
      margin-bottom: 16px;
      padding: 10px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 6px;

      span {
        font-size: 13px;
        padding: 4px 12px;
        border-radius: 4px;
        font-weight: 500;

        &.normal {
          background: rgba(46, 204, 113, 0.2);
          color: #2ecc71;
          border: 1px solid rgba(46, 204, 113, 0.5);
        }

        &.warning {
          background: rgba(241, 196, 15, 0.2);
          color: #f1c40f;
          border: 1px solid rgba(241, 196, 15, 0.5);
        }

        &.alarm {
          background: rgba(231, 76, 60, 0.2);
          color: #e74c3c;
          border: 1px solid rgba(231, 76, 60, 0.5);
        }

        &.fault {
          background: rgba(155, 89, 182, 0.2);
          color: #9b59b6;
          border: 1px solid rgba(155, 89, 182, 0.5);
        }
      }
    }

    .heatmapPlaceholder {
      height: 120px;
      background: rgba(0, 0, 0, 0.3);
      border-radius: 6px;
      display: flex;
      align-items: flex-end;
      padding: 8px;
      border: 1px solid rgba(52, 152, 219, 0.2);

      .timeScale {
        width: 100%;
        font-size: 11px;
        color: rgba(236, 240, 241, 0.6);
        display: flex;
        justify-content: space-between;
      }
    }
  }

  .sensorButtons {
    display: flex;
    gap: 8px;
    margin-bottom: 12px;
    flex-wrap: wrap;

    button {
      padding: 6px 16px;
      background: rgba(52, 152, 219, 0.15);
      border: 1px solid rgba(52, 152, 219, 0.3);
      border-radius: 4px;
      color: #ecf0f1;
      font-size: 13px;
      cursor: pointer;
      transition: all 0.3s ease;

      &:hover {
        background: rgba(52, 152, 219, 0.25);
        border-color: rgba(52, 152, 219, 0.5);
        transform: translateY(-1px);
        box-shadow: 0 2px 8px rgba(52, 152, 219, 0.3);
      }

      &.active {
        background: rgba(52, 152, 219, 0.4);
        border-color: #3498db;
        color: #3498db;
        font-weight: 600;
        box-shadow: 0 0 15px rgba(52, 152, 219, 0.4);
      }
    }
  }
}

@keyframes shimmer {
  0%, 100% {
    opacity: 0.5;
  }
  50% {
    opacity: 1;
  }
}

@keyframes pulse {
  0%, 100% {
    opacity: 1;
    transform: scale(1);
  }
  50% {
    opacity: 0.7;
    transform: scale(1.1);
  }
}

@keyframes scanline {
  0% {
    transform: translateX(-100%);
    opacity: 0.5;
  }
  50% {
    opacity: 1;
  }
  100% {
    transform: translateX(100%);
    opacity: 0.5;
  }
}

@keyframes titleGlow {
  0%, 100% {
    opacity: 0.8;
    box-shadow:
      0 0 15px rgba(0, 220, 255, 0.8),
      0 0 25px rgba(0, 200, 255, 0.5);
  }
  50% {
    opacity: 1;
    box-shadow:
      0 0 25px rgba(0, 255, 255, 1),
      0 0 40px rgba(0, 220, 255, 0.8),
      0 0 55px rgba(0, 200, 255, 0.5);
  }
}

@keyframes textShine {
  0%, 100% {
    filter:
      drop-shadow(0 0 8px rgba(255, 255, 255, 0.9))
      drop-shadow(0 0 16px rgba(0, 220, 255, 1))
      drop-shadow(0 0 24px rgba(0, 200, 255, 0.8))
      drop-shadow(0 0 32px rgba(0, 180, 255, 0.6))
      drop-shadow(0 4px 8px rgba(0, 0, 0, 0.8));
  }
  50% {
    filter:
      drop-shadow(0 0 12px rgba(255, 255, 255, 1))
      drop-shadow(0 0 24px rgba(0, 255, 255, 1))
      drop-shadow(0 0 36px rgba(0, 220, 255, 0.9))
      drop-shadow(0 0 48px rgba(0, 200, 255, 0.7))
      drop-shadow(0 4px 8px rgba(0, 0, 0, 0.8));
  }
}

@keyframes datetimeGlow {
  0% {
    left: -100%;
  }
  100% {
    left: 200%;
  }
}
