import React, { useEffect, useState, useRef } from 'react'
import { Card, Row, Col, Statistic, Progress } from 'antd'
import {
  ApiOutlined,
  ThunderboltOutlined,
  TeamOutlined,
  AlertOutlined,
} from '@ant-design/icons'
import { Line, Column } from '@ant-design/plots'
import * as THREE from 'three'
import { OrbitControls } from 'three/examples/jsm/controls/OrbitControls'
import {
  createDetailedBoxOpener,
  createDetailedMetalDetector,
  createDetailedXRayInspector,
  createDetailedCheckweigher,
  createDetailedSlicer,
  createDetailedPacker,
  createDetailedPalletizer,
  createDetailedLaminator,
  createRealisticRollerConveyor
} from './EquipmentModels'
import styles from './index.module.scss'

const DigitalFactory: React.FC = () => {
  const [currentTime, setCurrentTime] = useState(new Date())
  const mountRef = useRef<HTMLDivElement>(null)

  // Helper function to create text sprite
  const createTextSprite = (
    text: string,
    options: {
      fontSize?: number
      fontColor?: string
      backgroundColor?: string
      borderColor?: string
    } = {}
  ) => {
    const {
      fontSize = 32,
      fontColor = '#ffffff',
      backgroundColor = 'rgba(0, 0, 0, 0.7)',
      borderColor = '#ffffff'
    } = options

    const canvas = document.createElement('canvas')
    const context = canvas.getContext('2d')!
    canvas.width = 512
    canvas.height = 128

    // Draw background
    context.fillStyle = backgroundColor
    context.fillRect(0, 0, canvas.width, canvas.height)

    // Draw border
    context.strokeStyle = borderColor
    context.lineWidth = 4
    context.strokeRect(2, 2, canvas.width - 4, canvas.height - 4)

    // Draw text
    context.font = `bold ${fontSize}px Arial, sans-serif`
    context.fillStyle = fontColor
    context.textAlign = 'center'
    context.textBaseline = 'middle'
    context.fillText(text, canvas.width / 2, canvas.height / 2)

    const texture = new THREE.CanvasTexture(canvas)
    const material = new THREE.SpriteMaterial({ map: texture })
    const sprite = new THREE.Sprite(material)
    sprite.scale.set(2, 0.5, 1)

    return sprite
  }

  useEffect(() => {
    const timer = setInterval(() => {
      setCurrentTime(new Date())
    }, 1000)
    return () => clearInterval(timer)
  }, [])

  // Initialize 3D scene
  useEffect(() => {
    if (!mountRef.current) return

    // Scene setup
    const scene = new THREE.Scene()
    scene.background = new THREE.Color(0x0a1628)
    scene.fog = new THREE.Fog(0x0a1628, 50, 200)

    // Camera setup - 调整视角以俯瞰整个工厂布局
    const camera = new THREE.PerspectiveCamera(
      60,
      mountRef.current.clientWidth / mountRef.current.clientHeight,
      0.1,
      1000
    )
    camera.position.set(0, 50, 40)  // 更高的俯视角度，聚焦工厂中心

    // Renderer setup - 禁用阴影提高性能
    const renderer = new THREE.WebGLRenderer({ antialias: false, alpha: true })
    renderer.setSize(mountRef.current.clientWidth, mountRef.current.clientHeight)
    renderer.shadowMap.enabled = false  // 禁用阴影以提高性能
    mountRef.current.appendChild(renderer.domElement)

    // Controls
    const controls = new OrbitControls(camera, renderer.domElement)
    controls.enableDamping = true
    controls.dampingFactor = 0.05
    controls.autoRotate = false  // 禁用自动旋转

    // 启用平移功能 - 可以拖拽移动场景中心
    controls.enablePan = true
    controls.panSpeed = 1.0
    controls.screenSpacePanning = false  // 使用世界空间平移，保持在水平面上

    // 鼠标按键设置：左键平移（拖拽），右键旋转，滚轮缩放
    // 这样可以用左键拖拽某个位置到中心，然后滚轮放大缩小
    controls.mouseButtons = {
      LEFT: THREE.MOUSE.PAN,      // 左键拖拽平移
      MIDDLE: THREE.MOUSE.DOLLY,  // 中键缩放
      RIGHT: THREE.MOUSE.ROTATE   // 右键旋转
    }

    // 缩放设置
    controls.enableZoom = true
    controls.zoomSpeed = 1.0
    controls.minDistance = 5   // 最小缩放距离
    controls.maxDistance = 100 // 最大缩放距离

    // Enhanced Lighting - 工业环境照明
    const ambientLight = new THREE.AmbientLight(0xffffff, 0.3)
    scene.add(ambientLight)

    // 主光源 - 模拟顶部工业照明
    const mainLight = new THREE.DirectionalLight(0xffffff, 1.2)
    mainLight.position.set(20, 40, 30)
    mainLight.castShadow = true
    mainLight.shadow.mapSize.width = 2048
    mainLight.shadow.mapSize.height = 2048
    mainLight.shadow.camera.left = -50
    mainLight.shadow.camera.right = 50
    mainLight.shadow.camera.top = 50
    mainLight.shadow.camera.bottom = -50
    scene.add(mainLight)

    // 辅助光源
    const fillLight = new THREE.DirectionalLight(0x3498db, 0.4)
    fillLight.position.set(-30, 20, -20)
    scene.add(fillLight)

    // 点光源增强设备照明
    const spotlights = [
      { pos: [-30, 15, -15], color: 0xffffff },
      { pos: [0, 15, 0], color: 0xffffff },
      { pos: [25, 15, 0], color: 0xffffff }
    ]

    spotlights.forEach(({ pos, color }) => {
      const light = new THREE.PointLight(color, 0.6, 30)
      light.position.set(...pos)
      light.castShadow = true
      scene.add(light)
    })

    // Create realistic 3D equipment models
    const createRealisticEquipment = () => {
      // 材质定义
      const materials = {
        metal: new THREE.MeshStandardMaterial({
          color: 0xc0c0c0,  // 银色边框
          metalness: 0.8,
          roughness: 0.2
        }),
        metalDark: new THREE.MeshStandardMaterial({
          color: 0x505050,
          metalness: 0.9,
          roughness: 0.3
        }),
        plastic: new THREE.MeshStandardMaterial({
          color: 0x2c3e50,
          metalness: 0.1,
          roughness: 0.7
        }),
        glass: new THREE.MeshPhysicalMaterial({
          color: 0xffffff,
          metalness: 0,
          roughness: 0.1,
          transmission: 0.9,
          transparent: true,
          opacity: 0.3
        }),
        rubber: new THREE.MeshStandardMaterial({
          color: 0x2ecc71,  // 绿色履带/滚筒
          metalness: 0,
          roughness: 0.9
        })
      }

      // 创建开箱机 (KCKX20)
      const createBoxOpener = () => {
        const machine = new THREE.Group()

        // 主机身
        const mainBody = new THREE.Mesh(
          new THREE.BoxGeometry(3.1, 1.2, 3.5),
          materials.metal
        )
        mainBody.position.y = 0.6
        mainBody.castShadow = true
        machine.add(mainBody)

        // 顶部罩壳
        const topCover = new THREE.Mesh(
          new THREE.BoxGeometry(3.2, 0.3, 3.6),
          materials.plastic
        )
        topCover.position.y = 1.35
        topCover.castShadow = true
        machine.add(topCover)

        // 开箱机构 (V型推板)
        for (let i = 0; i < 4; i++) {
          const pusher = new THREE.Mesh(
            new THREE.BoxGeometry(0.1, 0.8, 1.5),
            materials.metalDark
          )
          pusher.position.set(-1.2 + i * 0.8, 0.6, 0)
          pusher.castShadow = true
          machine.add(pusher)
        }

        // 输送辊轴
        for (let i = 0; i < 8; i++) {
          const roller = new THREE.Mesh(
            new THREE.CylinderGeometry(0.05, 0.05, 3.4, 16),
            materials.rubber
          )
          roller.rotation.z = Math.PI / 2
          roller.position.set(-1.3 + i * 0.35, 0.1, 0)
          machine.add(roller)
        }

        // 控制面板
        const controlPanel = new THREE.Mesh(
          new THREE.BoxGeometry(0.4, 0.6, 0.3),
          materials.plastic
        )
        controlPanel.position.set(1.6, 1, 1.5)
        machine.add(controlPanel)

        // 状态指示灯
        const statusLight = new THREE.Mesh(
          new THREE.SphereGeometry(0.05, 16, 16),
          new THREE.MeshStandardMaterial({
            color: 0x00ff00,
            emissive: 0x00ff00,
            emissiveIntensity: 1
          })
        )
        statusLight.position.set(1.6, 1.4, 1.5)
        machine.add(statusLight)

        return machine
      }

      // 创建切片机 (Slicer)
      const createSlicer = (type = 'RTU') => {
        const machine = new THREE.Group()

        // 主机架
        const frame = new THREE.Mesh(
          new THREE.BoxGeometry(2.5, 2, 1.5),
          materials.metal
        )
        frame.position.y = 1
        frame.castShadow = true
        machine.add(frame)

        // 切割平台
        const platform = new THREE.Mesh(
          new THREE.BoxGeometry(2.3, 0.15, 1.3),
          materials.metalDark
        )
        platform.position.y = 0.5
        machine.add(platform)

        // 切割刀组 (多片刀片)
        for (let i = 0; i < 10; i++) {
          const blade = new THREE.Mesh(
            new THREE.BoxGeometry(0.02, 1.2, 1),
            new THREE.MeshStandardMaterial({
              color: 0xc0c0c0,
              metalness: 1,
              roughness: 0.1
            })
          )
          blade.position.set(-1 + i * 0.22, 1.5, 0)
          machine.add(blade)
        }

        // 电机
        const motor = new THREE.Mesh(
          new THREE.CylinderGeometry(0.25, 0.25, 0.5, 16),
          materials.metalDark
        )
        motor.rotation.z = Math.PI / 2
        motor.position.set(1.3, 1.8, 0)
        machine.add(motor)

        // 通讯模块标识
        const commModule = new THREE.Mesh(
          new THREE.BoxGeometry(0.3, 0.2, 0.2),
          new THREE.MeshStandardMaterial({
            color: type === 'RTU' ? 0x2ecc71 : 0x27ae60
          })
        )
        commModule.position.set(0, 2.2, 0.7)
        machine.add(commModule)

        // 状态灯
        const light = new THREE.PointLight(
          type === 'RTU' ? 0x2ecc71 : 0x27ae60,
          0.5,
          5
        )
        light.position.set(0, 2.5, 0)
        machine.add(light)

        return machine
      }

      // 创建装箱机 (ZX15)
      const createPacker = (mirrored = false) => {
        const machine = new THREE.Group()

        // 主机架
        const mainFrame = new THREE.Mesh(
          new THREE.BoxGeometry(6.2, 2.784, 1.48),
          materials.metal
        )
        mainFrame.position.y = 1.392
        mainFrame.castShadow = true
        machine.add(mainFrame)

        // 纸箱成型区
        const formingArea = new THREE.Mesh(
          new THREE.BoxGeometry(1.5, 1.5, 1.2),
          materials.glass
        )
        formingArea.position.set(-2, 1.5, 0)
        machine.add(formingArea)

        // 产品推送机构
        for (let i = 0; i < 3; i++) {
          const pusher = new THREE.Mesh(
            new THREE.BoxGeometry(0.2, 0.3, 0.8),
            materials.metalDark
          )
          pusher.position.set(-1 + i * 2, 1.2, 0)
          machine.add(pusher)
        }

        // 封箱胶带头
        const tapeHead = new THREE.Mesh(
          new THREE.CylinderGeometry(0.15, 0.15, 0.6, 16),
          materials.plastic
        )
        tapeHead.rotation.z = Math.PI / 2
        tapeHead.position.set(2.5, 2, 0)
        machine.add(tapeHead)

        // 输送带
        const conveyor = new THREE.Mesh(
          new THREE.BoxGeometry(6, 0.1, 0.8),
          materials.rubber
        )
        conveyor.position.y = 0.05
        machine.add(conveyor)

        // 控制柜
        const cabinet = new THREE.Mesh(
          new THREE.BoxGeometry(0.6, 1.8, 0.5),
          materials.plastic
        )
        cabinet.position.set(mirrored ? 3.5 : -3.5, 0.9, 1)
        machine.add(cabinet)

        // 触摸屏
        const hmi = new THREE.Mesh(
          new THREE.BoxGeometry(0.4, 0.3, 0.05),
          new THREE.MeshStandardMaterial({
            color: 0x000000,
            emissive: 0x3498db,
            emissiveIntensity: 0.5
          })
        )
        hmi.position.set(mirrored ? 3.5 : -3.5, 1.5, 1.3)
        machine.add(hmi)

        return machine
      }

      // 创建码垛机 (Palletizer)
      const createPalletizer = () => {
        const machine = new THREE.Group()

        // 底座
        const base = new THREE.Mesh(
          new THREE.BoxGeometry(4, 0.5, 3),
          materials.metal
        )
        base.position.y = 0.25
        base.castShadow = true
        machine.add(base)

        // 立柱
        const column = new THREE.Mesh(
          new THREE.BoxGeometry(0.4, 6, 0.4),
          materials.metalDark
        )
        column.position.y = 3
        column.castShadow = true
        machine.add(column)

        // 横梁 (可移动)
        const beam = new THREE.Mesh(
          new THREE.BoxGeometry(3.5, 0.3, 0.3),
          materials.metal
        )
        beam.position.y = 5
        beam.castShadow = true
        machine.add(beam)

        // 抓取机械手
        const gripper = new THREE.Group()
        const gripperArm = new THREE.Mesh(
          new THREE.BoxGeometry(0.3, 2, 0.3),
          materials.metalDark
        )
        gripperArm.position.y = 4
        gripper.add(gripperArm)

        // 夹爪
        for (let i = 0; i < 4; i++) {
          const finger = new THREE.Mesh(
            new THREE.BoxGeometry(0.8, 0.15, 0.1),
            materials.metal
          )
          const angle = (i / 4) * Math.PI * 2
          finger.position.x = Math.cos(angle) * 0.5
          finger.position.z = Math.sin(angle) * 0.5
          finger.position.y = 3
          gripper.add(finger)
        }
        machine.add(gripper)

        // 传感器阵列
        for (let i = 0; i < 6; i++) {
          const sensor = new THREE.Mesh(
            new THREE.CylinderGeometry(0.05, 0.05, 0.1, 8),
            new THREE.MeshStandardMaterial({
              color: 0xff0000,
              emissive: 0xff0000,
              emissiveIntensity: 0.5
            })
          )
          sensor.position.set(-1.5 + i * 0.5, 5.5, 0.3)
          machine.add(sensor)
        }

        return machine
      }

      // 创建覆膜机 (Laminator)
      const createLaminator = () => {
        const machine = new THREE.Group()

        // 主机身
        const body = new THREE.Mesh(
          new THREE.BoxGeometry(3.5, 2.2, 2),
          materials.metal
        )
        body.position.y = 1.1
        body.castShadow = true
        machine.add(body)

        // 上加热辊
        const upperRoller = new THREE.Mesh(
          new THREE.CylinderGeometry(0.2, 0.2, 1.8, 24),
          new THREE.MeshStandardMaterial({
            color: 0xff6600,
            emissive: 0xff3300,
            emissiveIntensity: 0.3
          })
        )
        upperRoller.rotation.z = Math.PI / 2
        upperRoller.position.set(0, 1.8, 0)
        machine.add(upperRoller)

        // 下加热辊
        const lowerRoller = new THREE.Mesh(
          new THREE.CylinderGeometry(0.2, 0.2, 1.8, 24),
          new THREE.MeshStandardMaterial({
            color: 0xff6600,
            emissive: 0xff3300,
            emissiveIntensity: 0.3
          })
        )
        lowerRoller.rotation.z = Math.PI / 2
        lowerRoller.position.set(0, 0.4, 0)
        machine.add(lowerRoller)

        // 膜卷支架
        const filmRoll = new THREE.Mesh(
          new THREE.CylinderGeometry(0.3, 0.3, 0.4, 16),
          materials.plastic
        )
        filmRoll.rotation.z = Math.PI / 2
        filmRoll.position.set(-1.5, 2.5, 0)
        machine.add(filmRoll)

        // 膜卷本体
        const film = new THREE.Mesh(
          new THREE.CylinderGeometry(0.25, 0.25, 0.35, 16),
          new THREE.MeshStandardMaterial({
            color: 0xffffff,
            transparent: true,
            opacity: 0.7
          })
        )
        film.rotation.z = Math.PI / 2
        film.position.set(-1.5, 2.5, 0)
        machine.add(film)

        // 温度传感器
        for (let i = 0; i < 3; i++) {
          const sensor = new THREE.Mesh(
            new THREE.BoxGeometry(0.1, 0.1, 0.1),
            new THREE.MeshStandardMaterial({
              color: 0x1abc9c,
              emissive: 0x1abc9c,
              emissiveIntensity: 0.8
            })
          )
          sensor.position.set(-0.8 + i * 0.8, 1.8, 1)
          machine.add(sensor)
        }

        return machine
      }

      // 创建输送带段
      const createConveyor = (length, width) => {
        const conveyor = new THREE.Group()

        // 支架
        const frameLeft = new THREE.Mesh(
          new THREE.BoxGeometry(0.1, 0.4, length),
          materials.metal
        )
        frameLeft.position.set(-width / 2, 0.2, 0)
        conveyor.add(frameLeft)

        const frameRight = new THREE.Mesh(
          new THREE.BoxGeometry(0.1, 0.4, length),
          materials.metal
        )
        frameRight.position.set(width / 2, 0.2, 0)
        conveyor.add(frameRight)

        // 滚筒
        const rollerCount = Math.floor(length / 0.3)
        for (let i = 0; i < rollerCount; i++) {
          const roller = new THREE.Mesh(
            new THREE.CylinderGeometry(0.05, 0.05, width, 16),
            materials.rubber
          )
          roller.rotation.z = Math.PI / 2
          roller.position.set(0, 0.15, -length / 2 + i * 0.3)
          conveyor.add(roller)
        }

        return conveyor
      }

      return {
        createBoxOpener,
        createSlicer,
        createPacker,
        createPalletizer,
        createLaminator,
        createConveyor
      }
    }

    // Create TFF factory with realistic equipment - 根据TTF工厂平面图布局
    const createFactory = () => {
      const group = new THREE.Group()
      const equipment = createRealisticEquipment()

      // === 根据平面图的布局重新规划 ===
      // 平面图坐标映射：左上为原点，X向右，Z向下
      // 3D场景坐标：中心为原点，X向右，Z向前（-Z向后）

      // 1. 底部切片机阵列区域 - 高性能版本
      const createBottomSlicingArea = () => {
        const area = new THREE.Group()

        // 底部1排6台（大幅减少）
        for (let col = 0; col < 6; col++) {
          const slicer = createDetailedSlicer()
          slicer.position.set(-25 + col * 10, 0, -22)
          area.add(slicer)
        }

        // 底部传送带（只保留2段）
        const conv1 = createRealisticRollerConveyor(30, 0.8)
        conv1.position.set(-10, 0, -20)
        conv1.rotation.y = 0
        area.add(conv1)

        return area
      }

      // 2. 中心生产线区域 - 高性能版本
      const createCentralProductionArea = () => {
        const area = new THREE.Group()

        // 中心切片机组 - 减少到1排4台
        for (let col = 0; col < 4; col++) {
          const slicer = createDetailedSlicer()
          slicer.position.set(-15 + col * 10, 0, 0)
          area.add(slicer)
        }

        // 纵向主传送带 - 只保留1段
        const conv1 = createRealisticRollerConveyor(15, 0.7)
        conv1.position.set(-5, 0, -8)
        conv1.rotation.y = Math.PI / 2
        area.add(conv1)

        return area
      }

      // 3. 左侧检测与包装进线区 (ZONE 9附近)
      const createLeftInspectionArea = () => {
        const area = new THREE.Group()

        // 开箱机 KCKX20
        const boxOpener = createDetailedBoxOpener()
        boxOpener.position.set(-35, 0, 8)
        area.add(boxOpener)

        // 金属检测机 M001, M002
        const metalDetector1 = createDetailedMetalDetector()
        metalDetector1.position.set(-30, 0, 8)
        area.add(metalDetector1)

        const metalDetector2 = createDetailedMetalDetector()
        metalDetector2.position.set(-26, 0, 8)
        area.add(metalDetector2)

        // X光检测系统 M003
        const xrayInspector = createDetailedXRayInspector()
        xrayInspector.position.set(-22, 0, 8)
        area.add(xrayInspector)

        // 检重秤 M004
        const checkweigher = createDetailedCheckweigher()
        checkweigher.position.set(-18, 0, 8)
        area.add(checkweigher)

        // 检测区传送带（横向连接）
        for (let i = 0; i < 5; i++) {
          const conv = createRealisticRollerConveyor(3.5, 0.65)
          conv.position.set(-33 + i * 4, 0, 8)
          conv.rotation.y = 0  // 横向
          area.add(conv)
        }

        return area
      }

      // 4. 装箱与封箱区域 - 高性能版本
      const createPackingArea = () => {
        const area = new THREE.Group()

        // 装箱机 - 只保留2台
        const packer1 = createDetailedPacker()
        packer1.position.set(-10, 0, 12)
        area.add(packer1)

        const packer2 = createDetailedPacker()
        packer2.position.set(5, 0, 12)
        area.add(packer2)

        // 装箱区输送带
        const conv1 = createRealisticRollerConveyor(20, 0.8)
        conv1.position.set(-3, 0, 14)
        conv1.rotation.y = 0
        area.add(conv1)

        return area
      }

      // 5. 右侧成品区与码垛区 - 高性能版本
      const createFinishedProductArea = () => {
        const area = new THREE.Group()

        // 码垛机器人 - 只保留1台
        const palletizer1 = createDetailedPalletizer()
        palletizer1.position.set(25, 0, 10)
        area.add(palletizer1)

        // 成品区传送带
        const conv1 = createRealisticRollerConveyor(15, 0.8)
        conv1.position.set(18, 0, 12)
        conv1.rotation.y = 0
        area.add(conv1)

        return area
      }

      // 创建真实的工业切肉设备 - 高度详细的食品级加工切片机
      const createMeatSlicingEquipment = () => {
        const slicer = new THREE.Group()

        // ========== 材质定义 - 食品级工业材料（白色系）==========
        const stainlessSteelMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.92,
          roughness: 0.15
        })

        const brushedSteelMaterial = new THREE.MeshStandardMaterial({
          color: 0xf5f5f5,  // 改为白色
          metalness: 0.85,
          roughness: 0.38
        })

        const darkSteelMaterial = new THREE.MeshStandardMaterial({
          color: 0xf0f0f0,  // 改为白色
          metalness: 0.78,
          roughness: 0.32
        })

        const rubberMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0,
          roughness: 0.92
        })

        const bladeMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为纯白色
          metalness: 0.98,
          roughness: 0.05
        })

        const plasticMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.15,
          roughness: 0.65
        })

        const safetyCoverMaterial = new THREE.MeshPhysicalMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0,
          roughness: 0.12,
          transmission: 0.85,
          transparent: true,
          opacity: 0.4
        })

        const motorMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.35,
          roughness: 0.68
        })

        const pipeMaterial = new THREE.MeshStandardMaterial({
          color: 0xf5f5f5,  // 改为白色
          metalness: 0.25,
          roughness: 0.75
        })

        // ========== 尺寸参数 ==========
        const unitWidth = 0.9
        const unitLength = 2.0
        const unitHeight = 1.2

        // ========== 1. 重型底座框架 ==========
        const baseFrameGeo = new THREE.BoxGeometry(unitWidth, 0.12, unitLength)
        const baseFrame = new THREE.Mesh(baseFrameGeo, stainlessSteelMaterial)
        baseFrame.position.y = 0.06
        baseFrame.castShadow = true
        slicer.add(baseFrame)

        // 底座加强筋
        for (let i = 0; i < 4; i++) {
          const ribGeo = new THREE.BoxGeometry(0.04, 0.08, unitLength)
          const rib = new THREE.Mesh(ribGeo, darkSteelMaterial)
          rib.position.set(-unitWidth/2 + 0.15 + i * (unitWidth - 0.3)/3, 0.04, 0)
          slicer.add(rib)
        }

        // ========== 2. 主机身框架 - 多层结构 ==========
        // 下层机身
        const lowerBodyGeo = new THREE.BoxGeometry(unitWidth - 0.12, unitHeight * 0.4, unitLength * 0.7)
        const lowerBody = new THREE.Mesh(lowerBodyGeo, stainlessSteelMaterial)
        lowerBody.position.set(0, unitHeight * 0.25, 0)
        lowerBody.castShadow = true
        slicer.add(lowerBody)

        // 上层机身 - 稍窄
        const upperBodyGeo = new THREE.BoxGeometry(unitWidth - 0.18, unitHeight * 0.35, unitLength * 0.6)
        const upperBody = new THREE.Mesh(upperBodyGeo, brushedSteelMaterial)
        upperBody.position.set(0, unitHeight * 0.625, 0)
        upperBody.castShadow = true
        slicer.add(upperBody)

        // ========== 3. 进料传送带系统 - 真实传送带 ==========
        const feedConveyorGroup = new THREE.Group()
        const conveyorLength = unitLength * 0.55
        const conveyorWidth = unitWidth * 0.6

        // 传送带框架
        const convFrameLeft = new THREE.Mesh(
          new THREE.BoxGeometry(0.025, 0.06, conveyorLength),
          darkSteelMaterial
        )
        convFrameLeft.position.set(-conveyorWidth/2, 0, 0)
        feedConveyorGroup.add(convFrameLeft)

        const convFrameRight = new THREE.Mesh(
          new THREE.BoxGeometry(0.025, 0.06, conveyorLength),
          darkSteelMaterial
        )
        convFrameRight.position.set(conveyorWidth/2, 0, 0)
        feedConveyorGroup.add(convFrameRight)

        // 传送带滚筒 - 多个滚筒
        const rollerCount = 12
        for (let i = 0; i < rollerCount; i++) {
          const rollerGeo = new THREE.CylinderGeometry(0.02, 0.02, conveyorWidth - 0.05, 12)
          const roller = new THREE.Mesh(rollerGeo, rubberMaterial)
          roller.rotation.z = Math.PI / 2
          roller.position.set(0, -0.02, -conveyorLength/2 + (i / (rollerCount - 1)) * conveyorLength)
          feedConveyorGroup.add(roller)
        }

        // 黑色橡胶传送带表面
        const beltGeo = new THREE.BoxGeometry(conveyorWidth - 0.08, 0.015, conveyorLength)
        const belt = new THREE.Mesh(beltGeo, rubberMaterial)
        belt.position.y = 0.005
        feedConveyorGroup.add(belt)

        feedConveyorGroup.position.set(0, unitHeight * 0.52, unitLength * 0.18)
        slicer.add(feedConveyorGroup)

        // ========== 4. 多刀片切割系统 - 3个独立圆形刀片 ==========
        const bladeRadius = 0.2
        const bladeThickness = 0.005
        const bladePositions = [
          { x: -0.22, z: -0.05 },
          { x: 0, z: 0 },
          { x: 0.22, z: 0.05 }
        ]

        bladePositions.forEach((pos, idx) => {
          // 主刀片
          const bladeGeo = new THREE.CylinderGeometry(bladeRadius, bladeRadius, bladeThickness, 48)
          const blade = new THREE.Mesh(bladeGeo, bladeMaterial)
          blade.rotation.z = Math.PI / 2
          blade.position.set(pos.x, unitHeight * 0.55, pos.z)
          blade.castShadow = true
          slicer.add(blade)

          // 刀片锯齿 - 更密集
          for (let i = 0; i < 36; i++) {
            const angle = (i / 36) * Math.PI * 2
            const toothGeo = new THREE.BoxGeometry(0.01, bladeThickness + 0.002, 0.025)
            const tooth = new THREE.Mesh(toothGeo, bladeMaterial)
            tooth.position.set(
              pos.x + Math.cos(angle) * bladeRadius,
              unitHeight * 0.55,
              pos.z + Math.sin(angle) * bladeRadius
            )
            tooth.rotation.y = angle
            slicer.add(tooth)
          }

          // 刀片中心轴承座
          const bearingGeo = new THREE.CylinderGeometry(0.035, 0.035, 0.12, 16)
          const bearing = new THREE.Mesh(bearingGeo, darkSteelMaterial)
          bearing.rotation.z = Math.PI / 2
          bearing.position.set(pos.x, unitHeight * 0.55, pos.z)
          slicer.add(bearing)

          // 刀片护罩 - 半圆形
          const guardGeo = new THREE.TorusGeometry(bladeRadius + 0.03, 0.015, 8, 24, Math.PI)
          const guard = new THREE.Mesh(guardGeo, stainlessSteelMaterial)
          guard.rotation.y = Math.PI / 2
          guard.rotation.z = Math.PI / 2
          guard.position.set(pos.x, unitHeight * 0.55, pos.z)
          slicer.add(guard)
        })

        // ========== 5. 压料装置 - 液压压臂 ==========
        // 主压臂
        const pressArmGeo = new THREE.BoxGeometry(unitWidth * 0.65, 0.08, 0.08)
        const pressArm = new THREE.Mesh(pressArmGeo, brushedSteelMaterial)
        pressArm.position.set(0, unitHeight * 0.68, unitLength * 0.3)
        slicer.add(pressArm)

        // 压臂支撑柱 - 液压缸
        for (let i = 0; i < 3; i++) {
          const cylinderGeo = new THREE.CylinderGeometry(0.025, 0.025, 0.15, 12)
          const cylinder = new THREE.Mesh(cylinderGeo, darkSteelMaterial)
          cylinder.position.set(-unitWidth * 0.25 + i * unitWidth * 0.25, unitHeight * 0.75, unitLength * 0.3)
          slicer.add(cylinder)

          // 液压活塞杆
          const pistonGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.08, 12)
          const piston = new THREE.Mesh(pistonGeo, stainlessSteelMaterial)
          piston.position.set(-unitWidth * 0.25 + i * unitWidth * 0.25, unitHeight * 0.64, unitLength * 0.3)
          slicer.add(piston)
        }

        // 压料滚轮
        for (let i = 0; i < 5; i++) {
          const rollerGeo = new THREE.CylinderGeometry(0.03, 0.03, unitWidth * 0.12, 16)
          const roller = new THREE.Mesh(rollerGeo, rubberMaterial)
          roller.rotation.z = Math.PI / 2
          roller.position.set(0, unitHeight * 0.67, unitLength * 0.25 + i * 0.08)
          slicer.add(roller)
        }

        // ========== 6. 电机和传动系统 ==========
        // 主驱动电机 - 侧面
        const motorGeo = new THREE.CylinderGeometry(0.12, 0.15, 0.25, 16)
        const motor = new THREE.Mesh(motorGeo, motorMaterial)
        motor.rotation.x = Math.PI / 2
        motor.position.set(-unitWidth * 0.5 - 0.08, unitHeight * 0.55, 0)
        motor.castShadow = true
        slicer.add(motor)

        // 电机散热片
        for (let i = 0; i < 8; i++) {
          const finGeo = new THREE.BoxGeometry(0.25, 0.002, 0.15)
          const fin = new THREE.Mesh(finGeo, darkSteelMaterial)
          fin.rotation.x = Math.PI / 2
          fin.position.set(-unitWidth * 0.5 - 0.08, unitHeight * 0.55, -0.08 + i * 0.022)
          slicer.add(fin)
        }

        // 皮带轮组
        const pulleyGeo = new THREE.CylinderGeometry(0.08, 0.08, 0.04, 24)
        const pulley1 = new THREE.Mesh(pulleyGeo, darkSteelMaterial)
        pulley1.rotation.z = Math.PI / 2
        pulley1.position.set(-unitWidth * 0.38, unitHeight * 0.55, 0)
        slicer.add(pulley1)

        // 传动皮带
        const beltPath = new THREE.CatmullRomCurve3([
          new THREE.Vector3(-unitWidth * 0.38, unitHeight * 0.55, -0.08),
          new THREE.Vector3(-0.22, unitHeight * 0.55, -0.08),
          new THREE.Vector3(-0.22, unitHeight * 0.55, 0.08),
          new THREE.Vector3(-unitWidth * 0.38, unitHeight * 0.55, 0.08)
        ], true)
        const beltGeoTube = new THREE.TubeGeometry(beltPath, 64, 0.012, 8, true)
        const transmBelt = new THREE.Mesh(beltGeoTube, rubberMaterial)
        slicer.add(transmBelt)

        // ========== 7. 液压管线系统 ==========
        // 创建管线路径
        const pipePoints = [
          new THREE.Vector3(-unitWidth * 0.4, unitHeight * 0.3, unitLength * 0.4),
          new THREE.Vector3(-unitWidth * 0.4, unitHeight * 0.6, unitLength * 0.4),
          new THREE.Vector3(-unitWidth * 0.25, unitHeight * 0.7, unitLength * 0.3),
        ]
        const pipeCurve = new THREE.CatmullRomCurve3(pipePoints)
        const pipeGeo = new THREE.TubeGeometry(pipeCurve, 20, 0.012, 8, false)
        const pipe = new THREE.Mesh(pipeGeo, pipeMaterial)
        slicer.add(pipe)

        // 管线接头
        pipePoints.forEach(point => {
          const jointGeo = new THREE.SphereGeometry(0.018, 12, 12)
          const joint = new THREE.Mesh(jointGeo, darkSteelMaterial)
          joint.position.copy(point)
          slicer.add(joint)
        })

        // ========== 8. 出料系统 - 倾斜导槽和收集托盘 ==========
        const outletChute = new THREE.Group()

        // 导槽底板
        const chuteBottomGeo = new THREE.BoxGeometry(unitWidth * 0.55, 0.025, unitLength * 0.4)
        const chuteBottom = new THREE.Mesh(chuteBottomGeo, stainlessSteelMaterial)
        chuteBottom.rotation.x = Math.PI / 8
        outletChute.add(chuteBottom)

        // 导槽侧壁 - 带支撑
        const chuteSideGeo = new THREE.BoxGeometry(0.025, 0.12, unitLength * 0.4)
        const chuteSide1 = new THREE.Mesh(chuteSideGeo, stainlessSteelMaterial)
        chuteSide1.position.set(-unitWidth * 0.265, 0.06, 0)
        chuteSide1.rotation.x = Math.PI / 8
        outletChute.add(chuteSide1)

        const chuteSide2 = new THREE.Mesh(chuteSideGeo, stainlessSteelMaterial)
        chuteSide2.position.set(unitWidth * 0.265, 0.06, 0)
        chuteSide2.rotation.x = Math.PI / 8
        outletChute.add(chuteSide2)

        outletChute.position.set(0, unitHeight * 0.35, -unitLength * 0.35)
        slicer.add(outletChute)

        // 收集托盘
        const trayGeo = new THREE.BoxGeometry(unitWidth * 0.65, 0.04, unitLength * 0.3)
        const tray = new THREE.Mesh(trayGeo, stainlessSteelMaterial)
        tray.position.set(0, unitHeight * 0.15, -unitLength * 0.45)
        tray.castShadow = true
        slicer.add(tray)

        // ========== 9. 安全装置和护栏 ==========
        // 透明安全罩 - 更大范围
        const safetyGuardGeo = new THREE.BoxGeometry(unitWidth * 0.8, 0.5, unitLength * 0.6)
        const safetyGuard = new THREE.Mesh(safetyGuardGeo, safetyCoverMaterial)
        safetyGuard.position.set(0, unitHeight * 0.7, unitLength * 0.05)
        slicer.add(safetyGuard)

        // 安全罩金属框架 - 更结实
        const guardFrameGeo = new THREE.BoxGeometry(0.025, 0.55, 0.025)
        const guardFramePositions = [
          [-unitWidth * 0.38, unitHeight * 0.7, -unitLength * 0.25],
          [unitWidth * 0.38, unitHeight * 0.7, -unitLength * 0.25],
          [-unitWidth * 0.38, unitHeight * 0.7, unitLength * 0.35],
          [unitWidth * 0.38, unitHeight * 0.7, unitLength * 0.35]
        ]
        guardFramePositions.forEach(pos => {
          const frame = new THREE.Mesh(guardFrameGeo, darkSteelMaterial)
          frame.position.set(...pos)
          slicer.add(frame)
        })

        // 顶部横梁
        const topBeamGeo = new THREE.BoxGeometry(unitWidth * 0.8, 0.03, 0.03)
        const topBeam = new THREE.Mesh(topBeamGeo, darkSteelMaterial)
        topBeam.position.set(0, unitHeight * 0.95, unitLength * 0.05)
        slicer.add(topBeam)

        // 急停按钮 - 突出的红色蘑菇头
        const stopButtonGeo = new THREE.CylinderGeometry(0.04, 0.03, 0.03, 16)
        const stopButton = new THREE.Mesh(stopButtonGeo, new THREE.MeshStandardMaterial({
          color: 0xff0000,
          emissive: 0xff0000,
          emissiveIntensity: 0.8
        }))
        stopButton.position.set(unitWidth * 0.42, unitHeight * 0.65, unitLength * 0.35)
        slicer.add(stopButton)

        // ========== 10. 控制系统 ==========
        // 主控制柜 - 侧面
        const controlBoxGeo = new THREE.BoxGeometry(0.25, 0.45, 0.35)
        const controlBox = new THREE.Mesh(controlBoxGeo, plasticMaterial)
        controlBox.position.set(unitWidth * 0.5 + 0.13, unitHeight * 0.5, -unitLength * 0.35)
        controlBox.castShadow = true
        slicer.add(controlBox)

        // HMI触摸屏 - 倾斜便于操作
        const screenGeo = new THREE.BoxGeometry(0.18, 0.25, 0.03)
        const screen = new THREE.Mesh(screenGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          emissive: 0xffffff,  // 改为白色发光
          emissiveIntensity: 0.7
        }))
        screen.rotation.y = -Math.PI / 4
        screen.rotation.x = Math.PI / 12
        screen.position.set(unitWidth * 0.5 + 0.24, unitHeight * 0.58, -unitLength * 0.35)
        slicer.add(screen)

        // 控制按钮面板
        const buttonPanelGeo = new THREE.BoxGeometry(0.15, 0.12, 0.02)
        const buttonPanel = new THREE.Mesh(buttonPanelGeo, darkSteelMaterial)
        buttonPanel.rotation.y = -Math.PI / 4
        buttonPanel.position.set(unitWidth * 0.5 + 0.22, unitHeight * 0.38, -unitLength * 0.3)
        slicer.add(buttonPanel)

        // 控制按钮 - 4个
        const buttonConfigs = [
          { x: -0.05, y: 0.03, color: 0x00ff00, label: '启动' },
          { x: 0.05, y: 0.03, color: 0xffff00, label: '暂停' },
          { x: -0.05, y: -0.03, color: 0x0000ff, label: '设置' },
          { x: 0.05, y: -0.03, color: 0xff6600, label: '重置' }
        ]
        buttonConfigs.forEach(btn => {
          const btnGeo = new THREE.CylinderGeometry(0.018, 0.018, 0.015, 12)
          const button = new THREE.Mesh(btnGeo, new THREE.MeshStandardMaterial({
            color: btn.color,
            emissive: btn.color,
            emissiveIntensity: 0.6
          }))
          button.rotation.x = Math.PI / 2
          const offsetPos = new THREE.Vector3(btn.x, btn.y, 0.015)
          offsetPos.applyAxisAngle(new THREE.Vector3(0, 1, 0), -Math.PI / 4)
          button.position.set(
            unitWidth * 0.5 + 0.22 + offsetPos.x,
            unitHeight * 0.38 + offsetPos.y,
            -unitLength * 0.3 + offsetPos.z
          )
          slicer.add(button)
        })

        // ========== 11. 状态指示灯塔 ==========
        const lightTowerGeo = new THREE.CylinderGeometry(0.025, 0.025, 0.2, 16)
        const lightTower = new THREE.Mesh(lightTowerGeo, darkSteelMaterial)
        lightTower.position.set(unitWidth * 0.42, unitHeight * 0.85, unitLength * 0.42)
        slicer.add(lightTower)

        // 三色信号灯
        const lightColors = [0x00ff00, 0xffcc00, 0xff0000]
        lightColors.forEach((color, i) => {
          const lightGeo = new THREE.CylinderGeometry(0.03, 0.03, 0.04, 16)
          const light = new THREE.Mesh(lightGeo, new THREE.MeshStandardMaterial({
            color: color,
            emissive: color,
            emissiveIntensity: 2.0
          }))
          light.position.set(unitWidth * 0.42, unitHeight * 0.8 + i * 0.06, unitLength * 0.42)
          slicer.add(light)
        })

        // ========== 12. 机械细节 - 螺栓和铆钉 ==========
        // 在关键连接处添加螺栓
        const boltPositions = [
          // 底座四角
          [-unitWidth/2 + 0.1, 0.12, -unitLength/2 + 0.1],
          [unitWidth/2 - 0.1, 0.12, -unitLength/2 + 0.1],
          [-unitWidth/2 + 0.1, 0.12, unitLength/2 - 0.1],
          [unitWidth/2 - 0.1, 0.12, unitLength/2 - 0.1],
          // 机身侧面
          [-unitWidth/2 + 0.05, unitHeight * 0.4, unitLength * 0.3],
          [unitWidth/2 - 0.05, unitHeight * 0.4, unitLength * 0.3],
          [-unitWidth/2 + 0.05, unitHeight * 0.4, -unitLength * 0.3],
          [unitWidth/2 - 0.05, unitHeight * 0.4, -unitLength * 0.3]
        ]
        boltPositions.forEach(pos => {
          const boltHeadGeo = new THREE.CylinderGeometry(0.012, 0.012, 0.008, 6)
          const bolt = new THREE.Mesh(boltHeadGeo, darkSteelMaterial)
          bolt.position.set(...pos)
          slicer.add(bolt)
        })

        // ========== 13. 支撑腿 - 可调节高度 ==========
        const legPositions = [
          [-unitWidth/2 + 0.08, 0.05, -unitLength/2 + 0.1],
          [unitWidth/2 - 0.08, 0.05, -unitLength/2 + 0.1],
          [-unitWidth/2 + 0.08, 0.05, unitLength/2 - 0.1],
          [unitWidth/2 - 0.08, 0.05, unitLength/2 - 0.1]
        ]
        legPositions.forEach(pos => {
          // 主腿柱
          const legGeo = new THREE.CylinderGeometry(0.03, 0.032, 0.1, 12)
          const leg = new THREE.Mesh(legGeo, stainlessSteelMaterial)
          leg.position.set(...pos)
          leg.castShadow = true
          slicer.add(leg)

          // 可调节底脚
          const footGeo = new THREE.CylinderGeometry(0.04, 0.045, 0.02, 12)
          const foot = new THREE.Mesh(footGeo, rubberMaterial)
          foot.position.set(pos[0], 0.01, pos[2])
          slicer.add(foot)
        })

        // ========== 14. 品牌标识和铭牌 ==========
        const brandPlateGeo = new THREE.BoxGeometry(0.3, 0.12, 0.02)
        const brandPlate = new THREE.Mesh(brandPlateGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.8,
          roughness: 0.2
        }))
        brandPlate.position.set(0, unitHeight * 0.25, unitLength / 2 - 0.05)
        slicer.add(brandPlate)

        // 铭牌文字区域（白色）
        const nameplateGeo = new THREE.BoxGeometry(0.25, 0.08, 0.005)
        const nameplate = new THREE.Mesh(nameplateGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.9,
          roughness: 0.1
        }))
        nameplate.position.set(0, unitHeight * 0.25, unitLength / 2 - 0.03)
        slicer.add(nameplate)

        // ========== 15. 排水孔和清洁口 ==========
        // 底部排水孔（4个）
        const drainPositions = [
          [-unitWidth * 0.35, unitHeight * 0.08, -unitLength * 0.25],
          [unitWidth * 0.35, unitHeight * 0.08, -unitLength * 0.25],
          [-unitWidth * 0.35, unitHeight * 0.08, unitLength * 0.25],
          [unitWidth * 0.35, unitHeight * 0.08, unitLength * 0.25]
        ]
        drainPositions.forEach(pos => {
          // 排水孔盖板（带孔）
          const drainCoverGeo = new THREE.CylinderGeometry(0.035, 0.035, 0.008, 8)
          const drainCover = new THREE.Mesh(drainCoverGeo, stainlessSteelMaterial)
          drainCover.rotation.x = Math.PI / 2
          drainCover.position.set(...pos)
          slicer.add(drainCover)

          // 排水孔中心洞
          const drainHoleGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.01, 8)
          const drainHole = new THREE.Mesh(drainHoleGeo, new THREE.MeshStandardMaterial({
            color: 0x111111,
            metalness: 0.5,
            roughness: 0.8
          }))
          drainHole.rotation.x = Math.PI / 2
          drainHole.position.set(...pos)
          slicer.add(drainHole)
        })

        // ========== 16. 食品级密封圈 ==========
        // 机身接缝处的密封条（白色硅胶）
        const sealMaterial = new THREE.MeshStandardMaterial({
          color: 0xeeeeee,
          metalness: 0,
          roughness: 0.6
        })

        // 上下机身连接处密封圈
        const sealPath1 = new THREE.CatmullRomCurve3([
          new THREE.Vector3(-unitWidth * 0.42, unitHeight * 0.45, -unitLength * 0.35),
          new THREE.Vector3(unitWidth * 0.42, unitHeight * 0.45, -unitLength * 0.35),
          new THREE.Vector3(unitWidth * 0.42, unitHeight * 0.45, unitLength * 0.35),
          new THREE.Vector3(-unitWidth * 0.42, unitHeight * 0.45, unitLength * 0.35)
        ], true)
        const seal1Geo = new THREE.TubeGeometry(sealPath1, 64, 0.008, 8, true)
        const seal1 = new THREE.Mesh(seal1Geo, sealMaterial)
        slicer.add(seal1)

        // ========== 17. 维护检修盖板 ==========
        // 侧面检修盖板（带螺丝）
        const accessPanelGeo = new THREE.BoxGeometry(0.25, 0.35, 0.02)
        const accessPanel = new THREE.Mesh(accessPanelGeo, brushedSteelMaterial)
        accessPanel.position.set(-unitWidth / 2 + 0.01, unitHeight * 0.35, -unitLength * 0.25)
        slicer.add(accessPanel)

        // 盖板螺丝（4个角）
        const screwPositions = [
          [-0.11, 0.16], [-0.11, -0.16],
          [0.11, 0.16], [0.11, -0.16]
        ]
        screwPositions.forEach(([dx, dy]) => {
          const screwGeo = new THREE.CylinderGeometry(0.008, 0.008, 0.006, 6)
          const screw = new THREE.Mesh(screwGeo, darkSteelMaterial)
          screw.rotation.z = Math.PI / 2
          screw.position.set(
            -unitWidth / 2 + 0.02,
            unitHeight * 0.35 + dy,
            -unitLength * 0.25 + dx
          )
          slicer.add(screw)
        })

        // ========== 18. 认证标识和安全标签 ==========
        // CE认证标签
        const ceLabelGeo = new THREE.CircleGeometry(0.04, 16)
        const ceLabel = new THREE.Mesh(ceLabelGeo, new THREE.MeshStandardMaterial({
          color: 0x0066cc,
          metalness: 0.3,
          roughness: 0.7
        }))
        ceLabel.position.set(-unitWidth * 0.35, unitHeight * 0.72, unitLength / 2 - 0.001)
        ceLabel.rotation.y = Math.PI
        slicer.add(ceLabel)

        // 食品安全认证标签（绿色）
        const foodSafeGeo = new THREE.CircleGeometry(0.04, 16)
        const foodSafe = new THREE.Mesh(foodSafeGeo, new THREE.MeshStandardMaterial({
          color: 0x00aa33,
          metalness: 0.3,
          roughness: 0.7
        }))
        foodSafe.position.set(-unitWidth * 0.25, unitHeight * 0.72, unitLength / 2 - 0.001)
        foodSafe.rotation.y = Math.PI
        slicer.add(foodSafe)

        // IP67防水等级标签
        const ipRatingGeo = new THREE.BoxGeometry(0.1, 0.05, 0.005)
        const ipRating = new THREE.Mesh(ipRatingGeo, new THREE.MeshStandardMaterial({
          color: 0xffaa00,
          metalness: 0.4,
          roughness: 0.6
        }))
        ipRating.position.set(unitWidth * 0.35, unitHeight * 0.72, unitLength / 2 - 0.001)
        ipRating.rotation.y = Math.PI
        slicer.add(ipRating)

        // ========== 19. 刀片防护网格 ==========
        // 在刀片区域添加细密的防护网格
        const guardMeshMaterial = new THREE.MeshStandardMaterial({
          color: 0xa0a0a0,
          metalness: 0.85,
          roughness: 0.25,
          transparent: true,
          opacity: 0.7
        })

        // 垂直网格条（6条）
        for (let i = 0; i < 6; i++) {
          const meshBarGeo = new THREE.BoxGeometry(0.003, 0.25, 0.3)
          const meshBar = new THREE.Mesh(meshBarGeo, guardMeshMaterial)
          meshBar.position.set(-0.15 + i * 0.06, unitHeight * 0.55, unitLength * 0.12)
          slicer.add(meshBar)
        }

        // 水平网格条（4条）
        for (let i = 0; i < 4; i++) {
          const meshBarGeo = new THREE.BoxGeometry(0.35, 0.003, 0.3)
          const meshBar = new THREE.Mesh(meshBarGeo, guardMeshMaterial)
          meshBar.position.set(0, unitHeight * 0.45 + i * 0.07, unitLength * 0.12)
          slicer.add(meshBar)
        }

        // ========== 20. 增强刀片锋利光泽 ==========
        // 为刀片添加额外的高光边缘
        bladePositions.forEach(pos => {
          // 刀刃高光线（超亮）
          const edgeHighlightGeo = new THREE.TorusGeometry(bladeRadius - 0.005, 0.002, 8, 48)
          const edgeHighlight = new THREE.Mesh(edgeHighlightGeo, new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 1.0,
            roughness: 0.0,
            emissive: 0xccddff,
            emissiveIntensity: 0.3
          }))
          edgeHighlight.rotation.z = Math.PI / 2
          edgeHighlight.position.set(pos.x, unitHeight * 0.55, pos.z)
          slicer.add(edgeHighlight)
        })

        // ========== 21. 控制面板增强细节 ==========
        // 控制面板边框凸起
        const panelBorderGeo = new THREE.BoxGeometry(0.42, 0.32, 0.015)
        const panelBorder = new THREE.Mesh(panelBorderGeo, new THREE.MeshStandardMaterial({
          color: 0x333333,
          metalness: 0.6,
          roughness: 0.4
        }))
        panelBorder.rotation.y = -Math.PI / 4
        panelBorder.rotation.x = Math.PI / 12
        panelBorder.position.set(unitWidth * 0.42, unitHeight * 0.68, unitLength * 0.25)
        slicer.add(panelBorder)

        // 按钮上方的指示文字区域（4个）
        const buttonLabels = [
          { x: -0.05, y: 0.08, color: 0x00ff00 },  // START
          { x: 0.05, y: 0.08, color: 0xffff00 },   // PAUSE
          { x: -0.05, y: 0.0, color: 0x0088ff },   // SETUP
          { x: 0.05, y: 0.0, color: 0xff6600 }     // RESET
        ]

        buttonLabels.forEach(label => {
          const textBoxGeo = new THREE.BoxGeometry(0.06, 0.015, 0.002)
          const textBox = new THREE.Mesh(textBoxGeo, new THREE.MeshStandardMaterial({
            color: 0x111111,
            emissive: label.color,
            emissiveIntensity: 0.5
          }))
          textBox.rotation.y = -Math.PI / 4
          textBox.rotation.x = Math.PI / 12
          textBox.position.set(
            unitWidth * 0.42 + label.x * Math.cos(-Math.PI / 4),
            unitHeight * 0.68 + label.y,
            unitLength * 0.25 + label.x * Math.sin(-Math.PI / 4)
          )
          slicer.add(textBox)
        })

        // ========== 22. 出料口加强筋 ==========
        // 出料槽两侧加强支撑
        for (let side of [-1, 1]) {
          const supportGeo = new THREE.BoxGeometry(0.02, 0.15, 0.25)
          const support = new THREE.Mesh(supportGeo, darkSteelMaterial)
          support.position.set(
            side * unitWidth * 0.25,
            unitHeight * 0.35,
            -unitLength * 0.42
          )
          support.rotation.x = Math.PI / 8
          slicer.add(support)
        }

        return slicer
      }

      // 创建履带传送带
      const createBeltConveyor = (length: number, width: number) => {
        const conveyor = new THREE.Group()

        // 材质定义
        const frameMaterial = new THREE.MeshStandardMaterial({
          color: 0xc9b583,  // 金黄色金属框架
          metalness: 0.7,
          roughness: 0.3
        })

        const beltMaterial = new THREE.MeshStandardMaterial({
          color: 0x555555,  // 改为深灰色履带
          metalness: 0,
          roughness: 0.9
        })

        const rollerMaterial = new THREE.MeshStandardMaterial({
          color: 0xaaaaaa,  // 改为浅灰色滚筒
          metalness: 0,
          roughness: 0.95
        })

        // 框架底座
        const frameGeometry = new THREE.BoxGeometry(width, 0.08, length)
        const frame = new THREE.Mesh(frameGeometry, frameMaterial)
        frame.position.set(0, 0.04, 0)
        conveyor.add(frame)

        // 左右侧边框
        const sideFrameGeometry = new THREE.BoxGeometry(0.05, 0.12, length)
        const leftSideFrame = new THREE.Mesh(sideFrameGeometry, frameMaterial)
        leftSideFrame.position.set(-width / 2 + 0.025, 0.06, 0)
        conveyor.add(leftSideFrame)

        const rightSideFrame = new THREE.Mesh(sideFrameGeometry, frameMaterial)
        rightSideFrame.position.set(width / 2 - 0.025, 0.06, 0)
        conveyor.add(rightSideFrame)

        // 一节一节的履带板
        const segmentLength = 0.15  // 每节履带板的长度
        const segmentGap = 0.02     // 履带板之间的间隙
        const segmentSpacing = segmentLength + segmentGap  // 履带板的间距
        const segmentCount = Math.floor(length / segmentSpacing)

        // 履带板材质（深灰色履带板）
        const segmentMaterial = new THREE.MeshStandardMaterial({
          color: 0x666666,  // 稍浅的深灰色
          metalness: 0.1,
          roughness: 0.85
        })

        // 履带板边缘材质（更深灰色）
        const segmentEdgeMaterial = new THREE.MeshStandardMaterial({
          color: 0x333333,  // 更深灰色边缘
          metalness: 0.2,
          roughness: 0.8
        })

        for (let i = 0; i < segmentCount; i++) {
          // 主履带板
          const segmentGeometry = new THREE.BoxGeometry(width - 0.12, 0.025, segmentLength)
          const segment = new THREE.Mesh(segmentGeometry, segmentMaterial)
          segment.position.set(0, 0.09, -length / 2 + segmentLength / 2 + i * segmentSpacing)
          segment.castShadow = true
          conveyor.add(segment)

          // 履带板前后边缘凸起（模拟履带齿）
          const edgeHeight = 0.008
          const edgeGeometry = new THREE.BoxGeometry(width - 0.14, edgeHeight, 0.015)

          const frontEdge = new THREE.Mesh(edgeGeometry, segmentEdgeMaterial)
          frontEdge.position.set(0, 0.09 + 0.0125 + edgeHeight / 2, -length / 2 + i * segmentSpacing + 0.008)
          conveyor.add(frontEdge)

          const backEdge = new THREE.Mesh(edgeGeometry, segmentEdgeMaterial)
          backEdge.position.set(0, 0.09 + 0.0125 + edgeHeight / 2, -length / 2 + segmentLength + i * segmentSpacing - 0.008)
          conveyor.add(backEdge)
        }

        // 前后滚筒
        const rollerGeometry = new THREE.CylinderGeometry(0.06, 0.06, width, 16)
        const frontRoller = new THREE.Mesh(rollerGeometry, rollerMaterial)
        frontRoller.rotation.z = Math.PI / 2
        frontRoller.position.set(0, 0.06, -length / 2 + 0.05)
        conveyor.add(frontRoller)

        const rearRoller = new THREE.Mesh(rollerGeometry, rollerMaterial)
        rearRoller.rotation.z = Math.PI / 2
        rearRoller.position.set(0, 0.06, length / 2 - 0.05)
        conveyor.add(rearRoller)

        // 中间支撑滚筒
        const supportRollerCount = Math.floor(length / 1.2)
        for (let i = 0; i < supportRollerCount; i++) {
          const supportRollerGeometry = new THREE.CylinderGeometry(0.04, 0.04, width, 12)
          const supportRoller = new THREE.Mesh(supportRollerGeometry, rollerMaterial)
          supportRoller.rotation.z = Math.PI / 2
          supportRoller.position.set(0, 0.02, -length / 2 + 0.5 + i * 1.2)
          conveyor.add(supportRoller)
        }

        // 支撑横梁
        const beamCount = Math.floor(length / 1.0) + 1
        for (let i = 0; i < beamCount; i++) {
          const beamGeometry = new THREE.BoxGeometry(width - 0.02, 0.03, 0.03)
          const beam = new THREE.Mesh(beamGeometry, frameMaterial)
          beam.position.set(0, 0.01, -length / 2 + 0.2 + i * 1.0)
          conveyor.add(beam)
        }

        // 支腿
        const legMaterial = new THREE.MeshStandardMaterial({
          color: 0xc0c0c0,  // 银灰色金属支腿
          metalness: 0.8,
          roughness: 0.3
        })

        const legHeight = 0.8  // 支腿高度
        const legRadius = 0.04  // 支腿半径

        // 四个角的支腿位置
        const legPositions = [
          [-width / 2 + 0.15, -length / 2 + 0.15],  // 左前
          [width / 2 - 0.15, -length / 2 + 0.15],   // 右前
          [-width / 2 + 0.15, length / 2 - 0.15],   // 左后
          [width / 2 - 0.15, length / 2 - 0.15]     // 右后
        ]

        legPositions.forEach(([x, z]) => {
          // 支腿圆柱
          const legGeometry = new THREE.CylinderGeometry(legRadius, legRadius, legHeight, 16)
          const leg = new THREE.Mesh(legGeometry, legMaterial)
          leg.position.set(x, -legHeight / 2, z)
          leg.castShadow = true
          conveyor.add(leg)

          // 底部固定板
          const footPlateGeometry = new THREE.BoxGeometry(0.12, 0.02, 0.12)
          const footPlate = new THREE.Mesh(footPlateGeometry, new THREE.MeshStandardMaterial({
            color: 0x808080,
            metalness: 0.7,
            roughness: 0.4
          }))
          footPlate.position.set(x, -legHeight - 0.01, z)
          footPlate.castShadow = true
          conveyor.add(footPlate)

          // 顶部连接件
          const topConnectorGeometry = new THREE.CylinderGeometry(legRadius * 1.5, legRadius, 0.08, 16)
          const topConnector = new THREE.Mesh(topConnectorGeometry, legMaterial)
          topConnector.position.set(x, 0.04, z)
          conveyor.add(topConnector)

          // 对角支撑加强筋
          const braceGeometry = new THREE.BoxGeometry(0.03, legHeight * 0.6, 0.03)
          const brace = new THREE.Mesh(braceGeometry, legMaterial)
          brace.rotation.z = x < 0 ? Math.PI / 6 : -Math.PI / 6
          brace.position.set(x + (x < 0 ? 0.08 : -0.08), -legHeight / 2 + 0.15, z)
          conveyor.add(brace)
        })

        return conveyor
      }

      // 创建安检扫描设备（X光机）
      const createSecurityCheckDevice = () => {
        const device = new THREE.Group()

        // 材质定义
        const outerCasingMaterial = new THREE.MeshStandardMaterial({
          color: 0xe8e8e8,  // 浅灰色外壳
          metalness: 0.3,
          roughness: 0.4
        })

        const darkCasingMaterial = new THREE.MeshStandardMaterial({
          color: 0x2d3436,  // 深灰色外壳
          metalness: 0.5,
          roughness: 0.3
        })

        const rubberCurtainMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色（黑色橡胶帘）
          metalness: 0,
          roughness: 0.9
        })

        const displayMaterial = new THREE.MeshStandardMaterial({
          color: 0x1e3a5f,  // 深蓝色显示屏
          emissive: 0x0a1f3d,
          emissiveIntensity: 0.3
        })

        const warningStripeMaterial = new THREE.MeshStandardMaterial({
          color: 0xffd700,  // 黄色警示条
          emissive: 0xffa500,
          emissiveIntensity: 0.2
        })

        const ledGreenMaterial = new THREE.MeshStandardMaterial({
          color: 0x00ff00,
          emissive: 0x00ff00,
          emissiveIntensity: 0.8
        })

        // 底座平台（增加长度）
        const baseGeometry = new THREE.BoxGeometry(1.8, 0.15, 5.5)
        const base = new THREE.Mesh(baseGeometry, darkCasingMaterial)
        base.position.y = 0.075
        device.add(base)

        // 主扫描腔体（增加长度）
        const mainBodyGeometry = new THREE.BoxGeometry(1.6, 1.2, 3.5)
        const mainBody = new THREE.Mesh(mainBodyGeometry, outerCasingMaterial)
        mainBody.position.set(0, 0.75, 0)
        device.add(mainBody)

        // 顶部扫描单元外壳（增加长度）
        const topUnitGeometry = new THREE.BoxGeometry(1.5, 0.3, 3.2)
        const topUnit = new THREE.Mesh(topUnitGeometry, darkCasingMaterial)
        topUnit.position.set(0, 1.5, 0)
        device.add(topUnit)

        // 入口和出口延伸部分
        const inletGeometry = new THREE.BoxGeometry(1.2, 0.8, 0.8)
        const inlet = new THREE.Mesh(inletGeometry, outerCasingMaterial)
        inlet.position.set(0, 0.55, -2.15)
        device.add(inlet)

        const outlet = new THREE.Mesh(inletGeometry, outerCasingMaterial)
        outlet.position.set(0, 0.55, 2.15)
        device.add(outlet)

        // 橡胶防护帘（入口）
        const curtainGeometry = new THREE.PlaneGeometry(1.0, 0.8)
        const inletCurtain = new THREE.Mesh(curtainGeometry, rubberCurtainMaterial)
        inletCurtain.position.set(0, 0.55, -1.75)
        device.add(inletCurtain)

        const outletCurtain = new THREE.Mesh(curtainGeometry, rubberCurtainMaterial)
        outletCurtain.position.set(0, 0.55, 1.75)
        outletCurtain.rotation.y = Math.PI
        device.add(outletCurtain)

        // 传送带通道（增加长度）
        const beltGeometry = new THREE.BoxGeometry(1.0, 0.02, 5.3)
        const belt = new THREE.Mesh(beltGeometry, new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.1,
          roughness: 0.8
        }))
        belt.position.set(0, 0.16, 0)
        device.add(belt)

        // 操作控制台（右侧）
        const consoleGeometry = new THREE.BoxGeometry(0.45, 0.7, 0.5)
        const console = new THREE.Mesh(consoleGeometry, darkCasingMaterial)
        console.position.set(1.1, 0.85, 0.8)
        device.add(console)

        // 显示屏
        const displayGeometry = new THREE.BoxGeometry(0.4, 0.3, 0.02)
        const display = new THREE.Mesh(displayGeometry, displayMaterial)
        display.position.set(1.08, 1.1, 0.8)
        display.rotation.y = -Math.PI / 12
        device.add(display)

        // 控制按钮面板
        const buttonPanelGeometry = new THREE.BoxGeometry(0.3, 0.15, 0.02)
        const buttonPanel = new THREE.Mesh(buttonPanelGeometry, new THREE.MeshStandardMaterial({
          color: 0x3a3a3a,
          metalness: 0.4,
          roughness: 0.5
        }))
        buttonPanel.position.set(1.08, 0.7, 0.8)
        buttonPanel.rotation.y = -Math.PI / 12
        device.add(buttonPanel)

        // LED指示灯组
        for (let i = 0; i < 3; i++) {
          const ledGeometry = new THREE.SphereGeometry(0.02, 8, 8)
          const led = new THREE.Mesh(ledGeometry, ledGreenMaterial)
          led.position.set(0.4, 1.55, -0.95 + i * 0.1)
          device.add(led)
        }

        // 警示条纹（调整位置）
        const stripeGeometry = new THREE.BoxGeometry(1.6, 0.08, 0.05)
        const topStripe = new THREE.Mesh(stripeGeometry, warningStripeMaterial)
        topStripe.position.set(0, 1.38, 1.76)
        device.add(topStripe)

        const bottomStripe = new THREE.Mesh(stripeGeometry, warningStripeMaterial)
        bottomStripe.position.set(0, 0.2, 1.76)
        device.add(bottomStripe)

        // X射线警告标志（调整位置）
        const warningSignGeometry = new THREE.CircleGeometry(0.08, 16)
        const warningSign = new THREE.Mesh(warningSignGeometry, new THREE.MeshStandardMaterial({
          color: 0xff0000,
          emissive: 0xff0000,
          emissiveIntensity: 0.3
        }))
        warningSign.position.set(-0.7, 1.2, 1.77)
        device.add(warningSign)

        // 侧面散热格栅（增加数量和调整分布）
        for (let i = 0; i < 12; i++) {
          const grillGeometry = new THREE.BoxGeometry(0.02, 0.6, 0.05)
          const grill = new THREE.Mesh(grillGeometry, darkCasingMaterial)
          grill.position.set(-0.81, 0.75, -1.4 + i * 0.25)
          device.add(grill)
        }

        // 品牌标识牌（调整位置）
        const brandPlateGeometry = new THREE.BoxGeometry(0.5, 0.15, 0.02)
        const brandPlate = new THREE.Mesh(brandPlateGeometry, new THREE.MeshStandardMaterial({
          color: 0x2c3e50,
          metalness: 0.8,
          roughness: 0.2
        }))
        brandPlate.position.set(0, 1.55, -1.76)
        device.add(brandPlate)

        // 底部履带传送带系统
        const beltFrameMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 白色金属框架
          metalness: 0.7,
          roughness: 0.3
        })

        const beltMaterial = new THREE.MeshStandardMaterial({
          color: 0x555555,  // 改为深灰色履带
          metalness: 0,
          roughness: 0.9
        })

        const rollerMaterial = new THREE.MeshStandardMaterial({
          color: 0xaaaaaa,  // 改为浅灰色滚筒
          metalness: 0,
          roughness: 0.95
        })

        // 传送带框架底座
        const beltFrameGeometry = new THREE.BoxGeometry(1.0, 0.08, 5.5)
        const beltFrame = new THREE.Mesh(beltFrameGeometry, beltFrameMaterial)
        beltFrame.position.set(0, 0.04, 0)
        device.add(beltFrame)

        // 左右侧边框
        const sideFrameGeometry = new THREE.BoxGeometry(0.05, 0.12, 5.5)
        const leftSideFrame = new THREE.Mesh(sideFrameGeometry, beltFrameMaterial)
        leftSideFrame.position.set(-0.525, 0.06, 0)
        device.add(leftSideFrame)

        const rightSideFrame = new THREE.Mesh(sideFrameGeometry, beltFrameMaterial)
        rightSideFrame.position.set(0.525, 0.06, 0)
        device.add(rightSideFrame)

        // 传送带履带表面
        const beltSurfaceGeometry = new THREE.BoxGeometry(0.95, 0.02, 5.4)
        const beltSurface = new THREE.Mesh(beltSurfaceGeometry, beltMaterial)
        beltSurface.position.set(0, 0.09, 0)
        device.add(beltSurface)

        // 履带纹理线条
        for (let i = 0; i < 22; i++) {
          const lineGeometry = new THREE.BoxGeometry(0.94, 0.015, 0.04)
          const line = new THREE.Mesh(lineGeometry, new THREE.MeshStandardMaterial({
            color: 0xe0e0e0,
            metalness: 0.1,
            roughness: 0.9
          }))
          line.position.set(0, 0.1, -2.6 + i * 0.25)
          device.add(line)
        }

        // 前后滚筒
        const frontRollerGeometry = new THREE.CylinderGeometry(0.06, 0.06, 1.0, 16)
        const frontRoller = new THREE.Mesh(frontRollerGeometry, rollerMaterial)
        frontRoller.rotation.z = Math.PI / 2
        frontRoller.position.set(0, 0.06, -2.7)
        device.add(frontRoller)

        const rearRoller = new THREE.Mesh(frontRollerGeometry, rollerMaterial)
        rearRoller.rotation.z = Math.PI / 2
        rearRoller.position.set(0, 0.06, 2.7)
        device.add(rearRoller)

        // 中间支撑滚筒
        for (let i = 0; i < 5; i++) {
          const supportRollerGeometry = new THREE.CylinderGeometry(0.04, 0.04, 1.0, 12)
          const supportRoller = new THREE.Mesh(supportRollerGeometry, rollerMaterial)
          supportRoller.rotation.z = Math.PI / 2
          supportRoller.position.set(0, 0.02, -2.2 + i * 1.1)
          device.add(supportRoller)
        }

        // 传送带支撑横梁
        for (let i = 0; i < 6; i++) {
          const beamGeometry = new THREE.BoxGeometry(0.98, 0.03, 0.03)
          const beam = new THREE.Mesh(beamGeometry, beltFrameMaterial)
          beam.position.set(0, 0.01, -2.5 + i * 1.0)
          device.add(beam)
        }

        return device
      }

      // 创建肉制品原料区（冷冻肉块 + 不锈钢托盘）
      const createMaterialStack = () => {
        const stack = new THREE.Group()

        // ========== 材质定义 ==========
        // 不锈钢托盘材质
        const trayMaterial = new THREE.MeshStandardMaterial({
          color: 0xd0d0d0,
          metalness: 0.92,
          roughness: 0.18
        })

        // 冷冻肉块材质（粉红色带霜冻感）
        const meatMaterial = new THREE.MeshStandardMaterial({
          color: 0xd88888,  // 粉红肉色
          metalness: 0.1,
          roughness: 0.7
        })

        // 肥肉/筋膜材质（白色）
        const fatMaterial = new THREE.MeshStandardMaterial({
          color: 0xf5e5d5,
          metalness: 0.05,
          roughness: 0.8
        })

        // 保鲜膜材质（半透明）
        const wrapMaterial = new THREE.MeshPhysicalMaterial({
          color: 0xffffff,
          metalness: 0,
          roughness: 0.1,
          transmission: 0.7,  // 透明度
          thickness: 0.1
        })

        // 冰晶/霜冻材质
        const frostMaterial = new THREE.MeshStandardMaterial({
          color: 0xe8f4ff,
          metalness: 0.3,
          roughness: 0.4,
          emissive: 0xaaccff,
          emissiveIntensity: 0.15
        })

        // ========== 不锈钢托盘底座 ==========
        const trayWidth = 1.1
        const trayLength = 0.9
        const trayHeight = 0.08

        // 托盘底板
        const trayBottomGeo = new THREE.BoxGeometry(trayWidth, 0.015, trayLength)
        const trayBottom = new THREE.Mesh(trayBottomGeo, trayMaterial)
        trayBottom.position.y = trayHeight / 2
        trayBottom.castShadow = true
        stack.add(trayBottom)

        // 托盘四周边框
        const borders = [
          { w: trayWidth, h: trayHeight, d: 0.02, x: 0, z: trayLength/2 },  // 前
          { w: trayWidth, h: trayHeight, d: 0.02, x: 0, z: -trayLength/2 }, // 后
          { w: 0.02, h: trayHeight, d: trayLength, x: trayWidth/2, z: 0 },  // 右
          { w: 0.02, h: trayHeight, d: trayLength, x: -trayWidth/2, z: 0 }  // 左
        ]

        borders.forEach(b => {
          const borderGeo = new THREE.BoxGeometry(b.w, b.h, b.d)
          const border = new THREE.Mesh(borderGeo, trayMaterial)
          border.position.set(b.x, trayHeight / 2, b.z)
          border.castShadow = true
          stack.add(border)
        })

        // 托盘支撑脚（4个）
        const legPositions = [
          { x: -trayWidth/2 + 0.15, z: -trayLength/2 + 0.12 },
          { x: trayWidth/2 - 0.15, z: -trayLength/2 + 0.12 },
          { x: -trayWidth/2 + 0.15, z: trayLength/2 - 0.12 },
          { x: trayWidth/2 - 0.15, z: trayLength/2 - 0.12 }
        ]

        legPositions.forEach(pos => {
          const legGeo = new THREE.CylinderGeometry(0.03, 0.04, 0.08, 8)
          const leg = new THREE.Mesh(legGeo, trayMaterial)
          leg.position.set(pos.x, 0.04, pos.z)
          stack.add(leg)
        })

        // ========== 堆叠的冷冻肉块（2层）==========
        const meatBlockConfigs = [
          // 第一层 - 4大块
          { x: -0.3, y: trayHeight + 0.08, z: -0.25, w: 0.4, h: 0.16, d: 0.35 },
          { x: 0.25, y: trayHeight + 0.08, z: -0.25, w: 0.38, h: 0.16, d: 0.35 },
          { x: -0.3, y: trayHeight + 0.08, z: 0.22, w: 0.4, h: 0.16, d: 0.32 },
          { x: 0.25, y: trayHeight + 0.08, z: 0.22, w: 0.38, h: 0.16, d: 0.32 },
          // 第二层 - 3块
          { x: -0.22, y: trayHeight + 0.26, z: -0.15, w: 0.35, h: 0.14, d: 0.3 },
          { x: 0.18, y: trayHeight + 0.28, z: -0.15, w: 0.33, h: 0.14, d: 0.28 },
          { x: 0.0, y: trayHeight + 0.24, z: 0.2, w: 0.36, h: 0.12, d: 0.32 }
        ]

        meatBlockConfigs.forEach((config, index) => {
          // 主肉块（不规则形状 - 使用多个box组合）
          const meatGroup = new THREE.Group()

          // 主体肉块
          const meatGeo = new THREE.BoxGeometry(config.w, config.h, config.d)
          const meatBlock = new THREE.Mesh(meatGeo, meatMaterial)

          // 添加微小随机旋转使其更自然
          meatBlock.rotation.set(
            (Math.random() - 0.5) * 0.1,
            (Math.random() - 0.5) * 0.15,
            (Math.random() - 0.5) * 0.1
          )
          meatBlock.castShadow = true
          meatGroup.add(meatBlock)

          // 添加肥肉/白色筋膜纹理（3-5条）
          const fatLines = 3 + Math.floor(Math.random() * 3)
          for (let i = 0; i < fatLines; i++) {
            const fatGeo = new THREE.BoxGeometry(
              config.w * 0.6,
              config.h * 0.15,
              config.d * 0.08
            )
            const fat = new THREE.Mesh(fatGeo, fatMaterial)
            fat.position.set(
              (Math.random() - 0.5) * config.w * 0.3,
              (Math.random() - 0.5) * config.h * 0.4,
              (Math.random() - 0.5) * config.d * 0.3
            )
            fat.rotation.set(
              Math.random() * 0.5,
              Math.random() * 0.5,
              Math.random() * 0.5
            )
            meatGroup.add(fat)
          }

          // 添加表面霜冻效果（冰晶颗粒）
          const frostCount = 12 + Math.floor(Math.random() * 8)
          for (let i = 0; i < frostCount; i++) {
            const frostSize = 0.005 + Math.random() * 0.01
            const frostGeo = new THREE.SphereGeometry(frostSize, 4, 4)
            const frost = new THREE.Mesh(frostGeo, frostMaterial)
            frost.position.set(
              (Math.random() - 0.5) * config.w * 0.9,
              config.h / 2 + frostSize,
              (Math.random() - 0.5) * config.d * 0.9
            )
            meatGroup.add(frost)
          }

          meatGroup.position.set(config.x, config.y, config.z)
          stack.add(meatGroup)

          // 顶层肉块添加保鲜膜覆盖
          if (index >= 4) {
            const wrapGeo = new THREE.BoxGeometry(
              config.w + 0.02,
              config.h + 0.02,
              config.d + 0.02
            )
            const wrap = new THREE.Mesh(wrapGeo, wrapMaterial)
            wrap.position.copy(meatGroup.position)
            wrap.rotation.copy(meatBlock.rotation)
            stack.add(wrap)
          }
        })

        // ========== 温度标签（蓝色冷藏标识）==========
        const tempLabelGeo = new THREE.BoxGeometry(0.18, 0.12, 0.01)
        const tempLabelMat = new THREE.MeshStandardMaterial({
          color: 0x0066cc,
          emissive: 0x003366,
          emissiveIntensity: 0.4
        })
        const tempLabel = new THREE.Mesh(tempLabelGeo, tempLabelMat)
        tempLabel.position.set(trayWidth / 2 - 0.1, trayHeight + 0.06, trayLength / 2 + 0.015)
        tempLabel.rotation.y = -Math.PI / 6
        stack.add(tempLabel)

        // 温度数字背景（白色LCD显示）
        const tempDisplayGeo = new THREE.BoxGeometry(0.12, 0.05, 0.005)
        const tempDisplayMat = new THREE.MeshStandardMaterial({
          color: 0x001100,
          emissive: 0x00ff00,
          emissiveIntensity: 0.8
        })
        const tempDisplay = new THREE.Mesh(tempDisplayGeo, tempDisplayMat)
        tempDisplay.position.set(trayWidth / 2 - 0.1, trayHeight + 0.06, trayLength / 2 + 0.022)
        tempDisplay.rotation.y = -Math.PI / 6
        stack.add(tempDisplay)

        // 食品安全标签
        const safetyLabelGeo = new THREE.BoxGeometry(0.15, 0.1, 0.008)
        const safetyLabelMat = new THREE.MeshStandardMaterial({
          color: 0xffffff,
          metalness: 0,
          roughness: 0.9
        })
        const safetyLabel = new THREE.Mesh(safetyLabelGeo, safetyLabelMat)
        safetyLabel.position.set(-trayWidth / 2 + 0.12, trayHeight + 0.05, trayLength / 2 + 0.015)
        stack.add(safetyLabel)

        return stack
      }

      // 创建180度圆弧形传送带（样式与直线传送带一致）
      const createCurvedConveyor = (radius = 3.0, width = 0.8) => {
        const curved = new THREE.Group()

        // 材质定义 - 与直线传送带完全一致
        const frameMaterial = new THREE.MeshStandardMaterial({
          color: 0xc9b583,  // 米黄色/金色不锈钢
          metalness: 0.7,
          roughness: 0.3
        })

        const rollerMaterial = new THREE.MeshStandardMaterial({
          color: 0xaaaaaa,  // 改为浅灰色滚筒（圆弧形）
          metalness: 0,
          roughness: 0.95
        })

        const beltMaterial = new THREE.MeshStandardMaterial({
          color: 0x555555,  // 改为深灰色橡胶皮带（圆弧形）
          metalness: 0,
          roughness: 0.9,
          side: THREE.DoubleSide  // 双面渲染
        })

        const legMaterial = new THREE.MeshStandardMaterial({
          color: 0xa0a0a0,  // 灰色金属腿
          metalness: 0.6,
          roughness: 0.4
        })

        const elevationHeight = 0.35  // 与直线传送带高度一致
        const frameHeight = 0.18      // 与直线传送带框架高度一致
        const frameWidth = 0.03       // 框架宽度
        const rollerDiameter = 0.05   // 滚筒直径

        // 使用180度半圆弧路径创建框架
        const arcAngle = Math.PI  // 180度
        const outerRadius = radius + width / 2
        const innerRadius = radius - width / 2

        // 创建180度半圆弧路径（向-X方向凸起）
        const createArcCurve = (r: number) => {
          const points = []
          const segments = 64
          for (let i = 0; i <= segments; i++) {
            const angle = (i / segments) * Math.PI  // 从0到PI
            points.push(new THREE.Vector3(
              -r * Math.sin(angle),  // 向-X方向凸起
              0,
              r * Math.cos(angle)    // Z从+r到-r
            ))
          }
          return new THREE.CatmullRomCurve3(points)
        }

        // 创建垂直立着的连续圆弧形金属框架
        // 外侧框架 - 使用圆弧内外两个半径定义框架厚度
        const outerFrameVertices = []
        const outerFrameIndices = []
        const segments = 128

        // 框架向内延伸的宽度（与直线传送带框架厚度一致）
        const frameDepth = frameWidth  // 0.03米，与直线传送带一致

        for (let i = 0; i <= segments; i++) {
          const angle = (i / segments) * Math.PI  // 从0到PI

          // 外圈边缘（传送带外边界）
          const outerX = -outerRadius * Math.sin(angle)  // 向-X方向凸起
          const outerZ = outerRadius * Math.cos(angle)   // Z从+r到-r

          // 内圈边缘（外侧框架的内边界 = outerRadius - frameDepth）
          const innerR = outerRadius - frameDepth
          const innerX = -innerR * Math.sin(angle)  // 向-X方向凸起
          const innerZ = innerR * Math.cos(angle)   // Z从+r到-r

          // 每个角度创建4个顶点（外侧下、外侧上、内侧下、内侧上）
          outerFrameVertices.push(outerX, elevationHeight, outerZ)  // 外侧下
          outerFrameVertices.push(outerX, elevationHeight + frameHeight, outerZ)  // 外侧上
          outerFrameVertices.push(innerX, elevationHeight, innerZ)  // 内侧下
          outerFrameVertices.push(innerX, elevationHeight + frameHeight, innerZ)  // 内侧上
        }

        // 创建三角形面
        for (let i = 0; i < segments; i++) {
          const base = i * 4
          const next = (i + 1) * 4

          // 外侧面（面向传送带外部）
          outerFrameIndices.push(base, next, base + 1)
          outerFrameIndices.push(base + 1, next, next + 1)

          // 内侧面（面向传送带内部）
          outerFrameIndices.push(base + 2, base + 3, next + 2)
          outerFrameIndices.push(base + 3, next + 3, next + 2)

          // 顶面
          outerFrameIndices.push(base + 1, next + 1, base + 3)
          outerFrameIndices.push(base + 3, next + 1, next + 3)

          // 底面
          outerFrameIndices.push(base, base + 2, next)
          outerFrameIndices.push(base + 2, next + 2, next)
        }

        const outerFrameGeo = new THREE.BufferGeometry()
        outerFrameGeo.setAttribute('position', new THREE.Float32BufferAttribute(outerFrameVertices, 3))
        outerFrameGeo.setIndex(outerFrameIndices)
        outerFrameGeo.computeVertexNormals()

        const outerFrame = new THREE.Mesh(outerFrameGeo, frameMaterial)
        outerFrame.castShadow = true
        curved.add(outerFrame)

        // 内侧框架
        const innerFrameVertices = []
        const innerFrameIndices = []

        for (let i = 0; i <= segments; i++) {
          const angle = (i / segments) * Math.PI  // 从0到PI

          // 内圈边缘（传送带内边界）
          const innerX = -innerRadius * Math.sin(angle)  // 向-X方向凸起
          const innerZ = innerRadius * Math.cos(angle)   // Z从+r到-r

          // 外圈边缘（内侧框架的外边界 = innerRadius + frameDepth）
          const outerR = innerRadius + frameDepth
          const outerX = -outerR * Math.sin(angle)  // 向-X方向凸起
          const outerZ = outerR * Math.cos(angle)   // Z从+r到-r

          // 每个角度创建4个顶点
          innerFrameVertices.push(innerX, elevationHeight, innerZ)  // 内侧下
          innerFrameVertices.push(innerX, elevationHeight + frameHeight, innerZ)  // 内侧上
          innerFrameVertices.push(outerX, elevationHeight, outerZ)  // 外侧下
          innerFrameVertices.push(outerX, elevationHeight + frameHeight, outerZ)  // 外侧上
        }

        // 创建三角形面
        for (let i = 0; i < segments; i++) {
          const base = i * 4
          const next = (i + 1) * 4

          // 内侧面（面向圆心）
          innerFrameIndices.push(base, next, base + 1)
          innerFrameIndices.push(base + 1, next, next + 1)

          // 外侧面（面向传送带）
          innerFrameIndices.push(base + 2, base + 3, next + 2)
          innerFrameIndices.push(base + 3, next + 3, next + 2)

          // 顶面
          innerFrameIndices.push(base + 1, next + 1, base + 3)
          innerFrameIndices.push(base + 3, next + 1, next + 3)

          // 底面
          innerFrameIndices.push(base, base + 2, next)
          innerFrameIndices.push(base + 2, next + 2, next)
        }

        const innerFrameGeo = new THREE.BufferGeometry()
        innerFrameGeo.setAttribute('position', new THREE.Float32BufferAttribute(innerFrameVertices, 3))
        innerFrameGeo.setIndex(innerFrameIndices)
        innerFrameGeo.computeVertexNormals()

        const innerFrame = new THREE.Mesh(innerFrameGeo, frameMaterial)
        innerFrame.castShadow = true
        curved.add(innerFrame)

        // 沿圆弧创建黑色橡胶滚筒（只创建180度）
        const rollerSpacing = 0.15
        const rollerCount = Math.floor((arcAngle * radius) / rollerSpacing)

        for (let i = 0; i <= rollerCount; i++) {
          const angle = (i / rollerCount) * arcAngle  // 从0到PI
          const x = -radius * Math.sin(angle)  // 向-X方向凸起
          const z = radius * Math.cos(angle)   // Z从+r到-r

          const rollerGeo = new THREE.CylinderGeometry(
            rollerDiameter / 2,
            rollerDiameter / 2,
            width - frameWidth * 2,  // 与直线传送带一致，滚轮端部在框架内边缘
            12
          )
          const roller = new THREE.Mesh(rollerGeo, rollerMaterial)
          roller.rotation.z = Math.PI / 2
          roller.rotation.y = -angle
          roller.position.set(x, elevationHeight + frameHeight / 2, z)
          curved.add(roller)
        }

        // 创建黑色橡胶皮带表面 - 扁平半圆环
        // 履带宽度与直线传送带一致
        const beltThickness = 0.012
        const beltWidth = width - frameWidth * 4  // 与直线传送带一致
        const beltInnerR = radius - beltWidth / 2  // 履带内半径
        const beltOuterR = radius + beltWidth / 2  // 履带外半径
        const beltSegments = 64

        const beltVertices = []
        const beltIndices = []

        // 履带表面的Y坐标（在滚轮顶部上方一点）
        const beltY = elevationHeight + frameHeight + rollerDiameter / 2 + 0.006

        // 创建顶层顶点（从0到180度，向-X方向凸起）
        for (let i = 0; i <= beltSegments; i++) {
          const angle = (i / beltSegments) * Math.PI  // 从0到PI

          // 每个角度创建内外两个顶点
          const outerX = -beltOuterR * Math.sin(angle)  // 向-X方向凸起
          const outerZ = beltOuterR * Math.cos(angle)   // Z从+r到-r
          const innerX = -beltInnerR * Math.sin(angle)  // 向-X方向凸起
          const innerZ = beltInnerR * Math.cos(angle)   // Z从+r到-r

          beltVertices.push(innerX, beltY, innerZ)  // 内圈顶点
          beltVertices.push(outerX, beltY, outerZ)  // 外圈顶点
        }

        // 创建三角形面片（连接相邻的顶点对）
        for (let i = 0; i < beltSegments; i++) {
          const curr = i * 2
          const next = (i + 1) * 2

          // 第一个三角形：当前内 -> 下一个内 -> 当前外
          beltIndices.push(curr, next, curr + 1)
          // 第二个三角形：当前外 -> 下一个内 -> 下一个外
          beltIndices.push(curr + 1, next, next + 1)
        }

        const beltGeometry = new THREE.BufferGeometry()
        beltGeometry.setAttribute('position', new THREE.Float32BufferAttribute(beltVertices, 3))
        beltGeometry.setIndex(beltIndices)
        beltGeometry.computeVertexNormals()  // 自动计算法线

        const belt = new THREE.Mesh(beltGeometry, beltMaterial)
        // 不需要再设置position.y，因为顶点已经在正确的高度了

        curved.add(belt)

        // 创建圆形支撑腿（沿180度圆弧分布）
        const legCount = 8
        const legHeight = elevationHeight
        const legDiameter = 0.04

        for (let i = 0; i <= legCount; i++) {
          const angle = (i / legCount) * arcAngle  // 从0到PI

          // 外侧支撑腿
          const outerX = -(outerRadius - 0.08) * Math.sin(angle)  // 向-X方向凸起
          const outerZ = (outerRadius - 0.08) * Math.cos(angle)   // Z从+r到-r
          const outerLegGeo = new THREE.CylinderGeometry(legDiameter, legDiameter, legHeight, 8)
          const outerLeg = new THREE.Mesh(outerLegGeo, legMaterial)
          outerLeg.position.set(outerX, legHeight / 2, outerZ)
          curved.add(outerLeg)

          // 外侧底脚
          const outerFootGeo = new THREE.CylinderGeometry(legDiameter * 1.3, legDiameter, 0.02, 8)
          const outerFoot = new THREE.Mesh(outerFootGeo, legMaterial)
          outerFoot.position.set(outerX, 0.01, outerZ)
          curved.add(outerFoot)

          // 内侧支撑腿
          const innerX = -(innerRadius + 0.08) * Math.sin(angle)  // 向-X方向凸起
          const innerZ = (innerRadius + 0.08) * Math.cos(angle)   // Z从+r到-r
          const innerLegGeo = new THREE.CylinderGeometry(legDiameter, legDiameter, legHeight, 8)
          const innerLeg = new THREE.Mesh(innerLegGeo, legMaterial)
          innerLeg.position.set(innerX, legHeight / 2, innerZ)
          curved.add(innerLeg)

          // 内侧底脚
          const innerFootGeo = new THREE.CylinderGeometry(legDiameter * 1.3, legDiameter, 0.02, 8)
          const innerFoot = new THREE.Mesh(innerFootGeo, legMaterial)
          innerFoot.position.set(innerX, 0.01, innerZ)
          curved.add(innerFoot)
        }

        return curved
      }

      // 6. 主输送带网络系统 - 右下方15个短传送带
      const createMainConveyorNetwork = () => {
        const area = new THREE.Group()

        // 在右下方创建15个短传送带
        // 单行并排摆放在右下方（正X，负Z）
        for (let i = 0; i < 15; i++) {
          const conveyor = createRealisticRollerConveyor(3, 0.6)  // 3米长，0.6米宽
          conveyor.position.set(
            -20 + i * 3.4,    // X: 从-20开始（向左移动），每个间隔3.4米
            0,
            -25              // Z: -25（更靠下方）
          )
          conveyor.rotation.y = 0  // 横向摆放
          area.add(conveyor)

          // 在每个传送带下方添加切肉设备
          const slicer = createMeatSlicingEquipment()
          slicer.position.set(
            -20 + i * 3.4,    // X: 与传送带对齐
            0,
            -27.5            // Z: 在传送带下方2.5米处
          )
          area.add(slicer)

          // 在送料机左侧添加原料堆放区
          const materialStack = createMaterialStack()
          materialStack.position.set(
            -20 + i * 3.4 - 1.5,  // X: 在送料机左侧1.5米处
            0,
            -27.5                // Z: 与送料机对齐
          )
          materialStack.rotation.y = Math.PI / 2  // 旋转90度，使纸箱面向送料机
          area.add(materialStack)
        }

        // 在所有纵向传送带的上方（前端）添加横向主传送带
        // 横向传送带连接所有15条纵向传送带
        const horizontalConveyorLength = 15 * 3.4 + 0.6  // 覆盖所有15条传送带的宽度
        const horizontalConveyor = createRealisticRollerConveyor(horizontalConveyorLength, 0.8)
        horizontalConveyor.position.set(
          -20 + (15 * 3.4) / 2 - 1.7,  // X: 居中对齐所有传送带
          0,
          -25 + 1.5                   // Z: 在纵向传送带前端上方
        )
        horizontalConveyor.rotation.y = Math.PI / 2  // 旋转90度，变成横向
        area.add(horizontalConveyor)

        // 在横向传送带左端添加180度圆弧形转弯传送带
        // 横向传送带的中心位置
        const horizontalCenterX = -20 + (15 * 3.4) / 2 - 1.7
        const horizontalZ = -25 + 1.5
        const horizontalLength = horizontalConveyorLength

        // 横向传送带旋转90度后，长度沿X方向延伸
        // 左端X坐标 = 中心X - 长度/2
        const horizontalLeftEndX = horizontalCenterX - horizontalLength / 2

        // 创建180度圆弧传送带（半径基于横向传送带中心线，宽度0.8米与横向传送带一致）
        // 横向传送带旋转90度后，宽度0.8米沿Z方向
        // 圆弧的中心半径应该是横向传送带的中心线位置
        const horizontalConveyorWidth = 0.8
        const curvedRadius = 3.0  // 圆弧中心半径
        const curvedConveyor = createCurvedConveyor(curvedRadius, horizontalConveyorWidth)

        // 圆弧从角度0（+Z方向）向-X方向凸起，到角度PI（-Z方向）
        // 终点在 (0, 0, -radius)，应该对齐到横向传送带的中心线
        curvedConveyor.position.set(
          horizontalLeftEndX,           // X: 与横向传送带左端对齐
          0,
          horizontalZ + curvedRadius    // Z: 圆心在横向传送带后方radius米
        )
        area.add(curvedConveyor)

        // 在圆弧另一端（起点）连接一个短传送带（横向，向右延伸）
        // 起点位置：圆心 + (0, 0, +radius)
        const curvedStartZ = horizontalZ + curvedRadius + curvedRadius  // 圆弧起点的Z坐标
        const shortConveyorLength = 10.0  // 短传送带长度10米
        const shortConveyor = createRealisticRollerConveyor(shortConveyorLength, horizontalConveyorWidth)
        shortConveyor.position.set(
          horizontalLeftEndX + shortConveyorLength / 2,  // X: 从圆弧起点向右延伸
          0,
          curvedStartZ                                    // Z: 与圆弧起点对齐
        )
        shortConveyor.rotation.y = Math.PI / 2  // 旋转90度，变成横向
        area.add(shortConveyor)

        // 创建连接框架材质和几何体（提前定义，供后续使用）
        const connectionFrameGeo = new THREE.BoxGeometry(0.03, 0.18, 0.8)
        const connectionFrameMaterial = new THREE.MeshStandardMaterial({
          color: 0xc9b583,
          metalness: 0.7,
          roughness: 0.3
        })

        // ========== 创建斜向传送带的横向连接段 ==========
        // 在短传送带左侧1/4处创建一个横向连接传送带，然后连接到斜向传送带
        const shortConveyorLeftQuarterX = horizontalLeftEndX + shortConveyorLength / 4  // 短传送带左侧1/4处X坐标

        // 横向连接传送带（从短传送带左侧1/4处向右延伸）
        const crossConnectorLength = 3.0  // 横向连接传送带长度3米
        const crossConnector = createRealisticRollerConveyor(crossConnectorLength, horizontalConveyorWidth)
        crossConnector.position.set(
          shortConveyorLeftQuarterX + crossConnectorLength / 2,  // X: 从左侧1/4处向右延伸
          0,
          curvedStartZ                                            // Z: 与短传送带对齐
        )
        crossConnector.rotation.y = Math.PI / 2  // 旋转90度，横向
        area.add(crossConnector)

        // 斜向传送带从横向连接段的右端开始
        const crossConnectorEndX = shortConveyorLeftQuarterX + crossConnectorLength  // 横向连接段右端X坐标
        const diagonalConveyorLength = 5.0  // 斜向传送带长度5米
        // 缩短左侧终点框架0.3米,延长右侧框架0.1米,避免与横向传送带的框架重叠
        const diagonalConveyor = createRealisticRollerConveyor(diagonalConveyorLength, horizontalConveyorWidth, {
          shortenLeftFrameEnd: 0.3,
          shortenRightFrameEnd: -0.1  // 负值表示延长
        })

        // 向右上方：正X方向（向右），负Z方向（向上）
        const diagonalAngle = Math.PI / 6  // 30度倾斜角
        diagonalConveyor.position.set(
          crossConnectorEndX + (diagonalConveyorLength / 2) * Math.cos(diagonalAngle),  // X: 从连接段右端向右延伸
          0,
          curvedStartZ - (diagonalConveyorLength / 2) * Math.sin(diagonalAngle)  // Z: 向上延伸（负方向）
        )
        diagonalConveyor.rotation.y = Math.PI / 2 + diagonalAngle  // 旋转，使其向右上方
        area.add(diagonalConveyor)

        // ========== 在斜向传送带另一端添加横向传送带 ==========
        // 计算斜向传送带的终点位置
        const diagonalEndX = crossConnectorEndX + diagonalConveyorLength * Math.cos(diagonalAngle)
        const diagonalEndZ = curvedStartZ - diagonalConveyorLength * Math.sin(diagonalAngle)

        // 右上端横向传送带（向右延伸）
        const rightConnectorLength = 4.0  // 右上端横向传送带长度4米
        const rightConnector = createRealisticRollerConveyor(rightConnectorLength, horizontalConveyorWidth)
        // 向左移动0.15米以与斜向传送带重叠，消除缝隙
        const overlap = 0.15
        rightConnector.position.set(
          diagonalEndX - overlap + rightConnectorLength / 2,  // X: 从斜向传送带终点向右延伸，轻微重叠
          -0.08,                                              // Y: 向下移动0.08米
          diagonalEndZ                                        // Z: 与斜向传送带终点对齐
        )
        rightConnector.rotation.y = Math.PI / 2  // 旋转90度，横向
        area.add(rightConnector)

        // ========== 在右上端横向传送带右侧添加滚筒输送机 ==========
        const rollerConveyorGroup = new THREE.Group()

        // 滚筒输送机位置（传送带右侧）
        const conveyorWidth = 1.5  // 输送机宽度（X方向）
        const conveyorLength = 2.5  // 输送机长度（Z方向）
        // X位置：向右移动4.5米
        const rollerConveyorPositionX = diagonalEndX - overlap + conveyorWidth / 2 + 4.5
        // Z位置：传送带右侧，向下方移动1.9米
        const rollerConveyorPositionZ = diagonalEndZ + horizontalConveyorWidth / 2 + conveyorLength / 2 + 0.3 - 1.9

        // 1. 底座平台（深灰色）
        const rollerBaseMaterial = new THREE.MeshStandardMaterial({
          color: 0x404040,
          metalness: 0.7,
          roughness: 0.4
        })

        const rollerBaseHeight = 0.12
        const rollerBaseGeo = new THREE.BoxGeometry(conveyorWidth, rollerBaseHeight, conveyorLength)
        const rollerBase = new THREE.Mesh(rollerBaseGeo, rollerBaseMaterial)
        rollerBase.position.set(0, rollerBaseHeight / 2, 0)
        rollerBase.castShadow = true
        rollerConveyorGroup.add(rollerBase)

        // 2. 蓝色支撑框架（两侧纵向主梁）
        const blueFrameMaterial = new THREE.MeshStandardMaterial({
          color: 0x2e5c8a,  // 蓝色
          metalness: 0.7,
          roughness: 0.3
        })

        const frameHeight = 0.25
        const frameWidth = 0.08
        const frameDepth = conveyorLength

        // 左侧纵向主梁
        const leftFrameGeo = new THREE.BoxGeometry(frameWidth, frameHeight, frameDepth)
        const leftFrame = new THREE.Mesh(leftFrameGeo, blueFrameMaterial)
        leftFrame.position.set(-conveyorWidth / 2 + frameWidth / 2, rollerBaseHeight + frameHeight / 2, 0)
        leftFrame.castShadow = true
        rollerConveyorGroup.add(leftFrame)

        // 右侧纵向主梁
        const rightFrame = new THREE.Mesh(leftFrameGeo, blueFrameMaterial)
        rightFrame.position.set(conveyorWidth / 2 - frameWidth / 2, rollerBaseHeight + frameHeight / 2, 0)
        rightFrame.castShadow = true
        rollerConveyorGroup.add(rightFrame)

        // 3. 横向支撑梁（蓝色）
        const crossBeamCount = 5
        const crossBeamGeo = new THREE.BoxGeometry(conveyorWidth - frameWidth * 2, 0.06, 0.08)
        for (let i = 0; i < crossBeamCount; i++) {
          const crossBeam = new THREE.Mesh(crossBeamGeo, blueFrameMaterial)
          const zPos = -conveyorLength / 2 + (conveyorLength / (crossBeamCount - 1)) * i
          crossBeam.position.set(0, rollerBaseHeight + 0.03, zPos)
          crossBeam.castShadow = true
          rollerConveyorGroup.add(crossBeam)
        }

        // 4. 滚筒（白色/浅灰色，排列整齐）
        const rollerMaterial = new THREE.MeshStandardMaterial({
          color: 0xaaaaaa,  // 浅灰色
          metalness: 0.6,
          roughness: 0.3
        })

        const rollerRadius = 0.04
        const rollerLength = conveyorWidth - frameWidth * 2 - 0.05
        const rollerGeo = new THREE.CylinderGeometry(rollerRadius, rollerRadius, rollerLength, 20)
        const rollerCount = 25  // 滚筒数量
        const rollerSpacing = conveyorLength / (rollerCount + 1)

        for (let i = 0; i < rollerCount; i++) {
          const roller = new THREE.Mesh(rollerGeo, rollerMaterial)
          roller.rotation.z = Math.PI / 2  // 旋转90度，使滚筒横向
          const zPos = -conveyorLength / 2 + rollerSpacing * (i + 1)
          roller.position.set(0, rollerBaseHeight + frameHeight, zPos)
          roller.castShadow = true
          rollerConveyorGroup.add(roller)

          // 滚筒轴承座（两端）
          const bearingMaterial = new THREE.MeshStandardMaterial({
            color: 0x505050,
            metalness: 0.8,
            roughness: 0.3
          })
          const bearingGeo = new THREE.BoxGeometry(0.05, 0.05, 0.03)

          // 左侧轴承
          const leftBearing = new THREE.Mesh(bearingGeo, bearingMaterial)
          leftBearing.position.set(-rollerLength / 2 - 0.025, rollerBaseHeight + frameHeight, zPos)
          leftBearing.castShadow = true
          rollerConveyorGroup.add(leftBearing)

          // 右侧轴承
          const rightBearing = new THREE.Mesh(bearingGeo, bearingMaterial)
          rightBearing.position.set(rollerLength / 2 + 0.025, rollerBaseHeight + frameHeight, zPos)
          rightBearing.castShadow = true
          rollerConveyorGroup.add(rightBearing)
        }

        // 5. 黄色安全护栏（两侧）
        const yellowRailingMaterial = new THREE.MeshStandardMaterial({
          color: 0xffd700,  // 金黄色
          metalness: 0.5,
          roughness: 0.4
        })

        const railingHeight = 0.5
        const railingPostCount = 6

        // 护栏立柱（两侧）
        const railingPostGeo = new THREE.CylinderGeometry(0.025, 0.025, railingHeight, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyorWidth / 2 - 0.1 : conveyorWidth / 2 + 0.1

          for (let i = 0; i < railingPostCount; i++) {
            const post = new THREE.Mesh(railingPostGeo, yellowRailingMaterial)
            const zPos = -conveyorLength / 2 + (conveyorLength / (railingPostCount - 1)) * i
            post.position.set(xPos, rollerBaseHeight + frameHeight + railingHeight / 2, zPos)
            post.castShadow = true
            rollerConveyorGroup.add(post)
          }
        }

        // 护栏横杆（上下两层，两侧）
        const railingBarGeo = new THREE.CylinderGeometry(0.02, 0.02, conveyorLength, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyorWidth / 2 - 0.1 : conveyorWidth / 2 + 0.1

          // 上层横杆
          const topBar = new THREE.Mesh(railingBarGeo, yellowRailingMaterial)
          topBar.rotation.x = Math.PI / 2
          topBar.position.set(xPos, rollerBaseHeight + frameHeight + railingHeight - 0.1, 0)
          topBar.castShadow = true
          rollerConveyorGroup.add(topBar)

          // 下层横杆
          const midBar = new THREE.Mesh(railingBarGeo, yellowRailingMaterial)
          midBar.rotation.x = Math.PI / 2
          midBar.position.set(xPos, rollerBaseHeight + frameHeight + railingHeight / 2, 0)
          midBar.castShadow = true
          rollerConveyorGroup.add(midBar)
        }

        // 6. 支撑腿（四个角）
        const supportLegMaterial = new THREE.MeshStandardMaterial({
          color: 0x2e5c8a,  // 蓝色，与框架匹配
          metalness: 0.7,
          roughness: 0.4
        })

        const legHeight = 0.8
        const legGeo = new THREE.BoxGeometry(0.08, legHeight, 0.08)
        const legPositions = [
          [-conveyorWidth / 2 + 0.15, -conveyorLength / 2 + 0.15],
          [conveyorWidth / 2 - 0.15, -conveyorLength / 2 + 0.15],
          [-conveyorWidth / 2 + 0.15, conveyorLength / 2 - 0.15],
          [conveyorWidth / 2 - 0.15, conveyorLength / 2 - 0.15]
        ]

        legPositions.forEach(pos => {
          const leg = new THREE.Mesh(legGeo, supportLegMaterial)
          leg.position.set(pos[0], -legHeight / 2 + rollerBaseHeight, pos[1])
          leg.castShadow = true
          rollerConveyorGroup.add(leg)

          // 腿部底座固定板
          const footPlateGeo = new THREE.BoxGeometry(0.15, 0.03, 0.15)
          const footPlate = new THREE.Mesh(footPlateGeo, new THREE.MeshStandardMaterial({
            color: 0x404040,
            metalness: 0.7,
            roughness: 0.4
          }))
          footPlate.position.set(pos[0], -legHeight + rollerBaseHeight, pos[1])
          footPlate.castShadow = true
          rollerConveyorGroup.add(footPlate)
        })

        // 7. 侧面支撑加强筋
        const reinforceMaterial = new THREE.MeshStandardMaterial({
          color: 0x2e5c8a,
          metalness: 0.7,
          roughness: 0.4
        })

        // 对角支撑（三角形加强）
        legPositions.forEach(pos => {
          const reinforceGeo = new THREE.BoxGeometry(0.04, 0.5, 0.04)
          const reinforce = new THREE.Mesh(reinforceGeo, reinforceMaterial)

          // 旋转45度形成对角支撑
          reinforce.rotation.z = pos[0] < 0 ? Math.PI / 4 : -Math.PI / 4
          reinforce.position.set(
            pos[0],
            -legHeight / 2 + rollerBaseHeight + 0.25,
            pos[1]
          )
          reinforce.castShadow = true
          rollerConveyorGroup.add(reinforce)
        })

        // 8. 驱动电机（安装在一端侧面）
        const motorMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.8,
          roughness: 0.3
        })

        const motorGeo = new THREE.BoxGeometry(0.25, 0.25, 0.3)
        const motor = new THREE.Mesh(motorGeo, motorMaterial)
        motor.position.set(conveyorWidth / 2 + 0.15, rollerBaseHeight + frameHeight / 2, -conveyorLength / 2 + 0.3)
        motor.castShadow = true
        rollerConveyorGroup.add(motor)

        // 电机轴
        const motorShaftGeo = new THREE.CylinderGeometry(0.03, 0.03, 0.15, 12)
        const motorShaft = new THREE.Mesh(motorShaftGeo, new THREE.MeshStandardMaterial({
          color: 0x606060,
          metalness: 0.9,
          roughness: 0.2
        }))
        motorShaft.rotation.z = Math.PI / 2
        motorShaft.position.set(conveyorWidth / 2 + 0.05, rollerBaseHeight + frameHeight / 2, -conveyorLength / 2 + 0.3)
        rollerConveyorGroup.add(motorShaft)

        // 9. 控制箱（侧面安装）
        const controlBoxMaterial = new THREE.MeshStandardMaterial({
          color: 0x3a3a3a,
          metalness: 0.5,
          roughness: 0.5
        })

        const controlBoxGeo = new THREE.BoxGeometry(0.3, 0.4, 0.2)
        const controlBox = new THREE.Mesh(controlBoxGeo, controlBoxMaterial)
        controlBox.position.set(-conveyorWidth / 2 - 0.15, rollerBaseHeight + frameHeight + 0.2, -conveyorLength / 2 + 0.5)
        controlBox.castShadow = true
        rollerConveyorGroup.add(controlBox)

        // 控制箱面板（带指示灯）
        const panelGeo = new THREE.BoxGeometry(0.25, 0.35, 0.02)
        const panel = new THREE.Mesh(panelGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.4,
          roughness: 0.6
        }))
        panel.position.set(-conveyorWidth / 2 - 0.26, rollerBaseHeight + frameHeight + 0.2, -conveyorLength / 2 + 0.5)
        rollerConveyorGroup.add(panel)

        // 指示灯（绿色运行灯）
        const indicatorGeo = new THREE.CircleGeometry(0.025, 16)
        const runningLight = new THREE.Mesh(indicatorGeo, new THREE.MeshStandardMaterial({
          color: 0x00ff00,
          emissive: 0x00ff00,
          emissiveIntensity: 0.8
        }))
        runningLight.position.set(-conveyorWidth / 2 - 0.27, rollerBaseHeight + frameHeight + 0.3, -conveyorLength / 2 + 0.5)
        runningLight.rotation.y = -Math.PI / 2
        rollerConveyorGroup.add(runningLight)

        // 10. 输送机标识牌
        const signMaterial = new THREE.MeshStandardMaterial({
          color: 0xffcc00,  // 黄色警示色
          metalness: 0.4,
          roughness: 0.5
        })

        const signGeo = new THREE.BoxGeometry(0.4, 0.2, 0.02)
        const conveyorSign = new THREE.Mesh(signGeo, signMaterial)
        conveyorSign.position.set(0, rollerBaseHeight + frameHeight + railingHeight + 0.15, -conveyorLength / 2 + 0.3)
        conveyorSign.castShadow = true
        rollerConveyorGroup.add(conveyorSign)

        // 标识牌文字底板（黑色）
        const textPlateGeo = new THREE.BoxGeometry(0.35, 0.15, 0.01)
        const textPlate = new THREE.Mesh(textPlateGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff  // 改为白色
        }))
        textPlate.position.set(0, rollerBaseHeight + frameHeight + railingHeight + 0.15, -conveyorLength / 2 + 0.31)
        rollerConveyorGroup.add(textPlate)

        // 11. 传动链条系统（侧面可见）
        const chainMaterial = new THREE.MeshStandardMaterial({
          color: 0x3a3a3a,
          metalness: 0.9,
          roughness: 0.4
        })

        // 传动链条（右侧）
        for (let i = 0; i < 3; i++) {
          const chainGeo = new THREE.TorusGeometry(0.015, 0.005, 8, 12)
          const chain = new THREE.Mesh(chainGeo, chainMaterial)
          chain.rotation.y = Math.PI / 2
          const zPos = -conveyorLength / 2 + 0.5 + i * 0.8
          chain.position.set(conveyorWidth / 2 - frameWidth - 0.05, rollerBaseHeight + frameHeight - 0.05, zPos)
          rollerConveyorGroup.add(chain)
        }

        // 12. 张紧装置（链条张紧器）
        const tensionerMaterial = new THREE.MeshStandardMaterial({
          color: 0x606060,
          metalness: 0.8,
          roughness: 0.3
        })

        const tensionerBodyGeo = new THREE.BoxGeometry(0.1, 0.08, 0.12)
        const tensioner = new THREE.Mesh(tensionerBodyGeo, tensionerMaterial)
        tensioner.position.set(conveyorWidth / 2 - frameWidth - 0.05, rollerBaseHeight + frameHeight - 0.1, conveyorLength / 2 - 0.4)
        tensioner.castShadow = true
        rollerConveyorGroup.add(tensioner)

        // 张紧轮
        const tensionerWheelGeo = new THREE.CylinderGeometry(0.035, 0.035, 0.06, 16)
        const tensionerWheel = new THREE.Mesh(tensionerWheelGeo, new THREE.MeshStandardMaterial({
          color: 0x808080,
          metalness: 0.7,
          roughness: 0.3
        }))
        tensionerWheel.rotation.z = Math.PI / 2
        tensionerWheel.position.set(conveyorWidth / 2 - frameWidth - 0.05, rollerBaseHeight + frameHeight - 0.05, conveyorLength / 2 - 0.4)
        rollerConveyorGroup.add(tensionerWheel)

        // 13. 光电传感器（物料检测）
        const sensorMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.7,
          roughness: 0.3
        })

        // 发射端（一侧）
        const sensorEmitterGeo = new THREE.BoxGeometry(0.04, 0.06, 0.03)
        const sensorEmitter = new THREE.Mesh(sensorEmitterGeo, sensorMaterial)
        sensorEmitter.position.set(-conveyorWidth / 2 + frameWidth, rollerBaseHeight + frameHeight + 0.08, 0)
        rollerConveyorGroup.add(sensorEmitter)

        // 发射端指示灯（红色）
        const emitterLightGeo = new THREE.CircleGeometry(0.008, 12)
        const emitterLight = new THREE.Mesh(emitterLightGeo, new THREE.MeshStandardMaterial({
          color: 0xff0000,
          emissive: 0xff0000,
          emissiveIntensity: 0.7
        }))
        emitterLight.position.set(-conveyorWidth / 2 + frameWidth + 0.021, rollerBaseHeight + frameHeight + 0.1, 0)
        emitterLight.rotation.y = Math.PI / 2
        rollerConveyorGroup.add(emitterLight)

        // 接收端（对侧）
        const sensorReceiver = new THREE.Mesh(sensorEmitterGeo, sensorMaterial)
        sensorReceiver.position.set(conveyorWidth / 2 - frameWidth, rollerBaseHeight + frameHeight + 0.08, 0)
        rollerConveyorGroup.add(sensorReceiver)

        // 接收端指示灯（绿色）
        const receiverLight = new THREE.Mesh(emitterLightGeo, new THREE.MeshStandardMaterial({
          color: 0x00ff00,
          emissive: 0x00ff00,
          emissiveIntensity: 0.7
        }))
        receiverLight.position.set(conveyorWidth / 2 - frameWidth - 0.021, rollerBaseHeight + frameHeight + 0.1, 0)
        receiverLight.rotation.y = -Math.PI / 2
        rollerConveyorGroup.add(receiverLight)

        // 14. 电缆桥架（顶部走线）
        const cableTrayMaterial = new THREE.MeshStandardMaterial({
          color: 0x505050,
          metalness: 0.6,
          roughness: 0.4
        })

        const cableTrayGeo = new THREE.BoxGeometry(0.15, 0.04, conveyorLength * 0.8)
        const cableTray = new THREE.Mesh(cableTrayGeo, cableTrayMaterial)
        cableTray.position.set(-conveyorWidth / 2 - 0.2, rollerBaseHeight + frameHeight + railingHeight + 0.05, 0)
        cableTray.castShadow = true
        rollerConveyorGroup.add(cableTray)

        // 电缆桥架盖板（网格状）
        for (let i = 0; i < 8; i++) {
          const trayGridGeo = new THREE.BoxGeometry(0.12, 0.005, 0.02)
          const trayGrid = new THREE.Mesh(trayGridGeo, new THREE.MeshStandardMaterial({
            color: 0x404040,
            metalness: 0.5
          }))
          const zPos = -conveyorLength * 0.35 + i * 0.1
          trayGrid.position.set(-conveyorWidth / 2 - 0.2, rollerBaseHeight + frameHeight + railingHeight + 0.07, zPos)
          rollerConveyorGroup.add(trayGrid)
        }

        // 15. 电线管和电缆
        const conduitMaterial = new THREE.MeshStandardMaterial({
          color: 0x707070,
          metalness: 0.7,
          roughness: 0.3
        })

        // 主电线管（从控制箱到电机）
        const conduitGeo = new THREE.CylinderGeometry(0.02, 0.02, 1.2, 12)
        const mainConduit = new THREE.Mesh(conduitGeo, conduitMaterial)
        mainConduit.rotation.x = Math.PI / 2
        mainConduit.position.set(-conveyorWidth / 2 - 0.15, rollerBaseHeight + frameHeight + 0.15, -conveyorLength / 2 + 1.1)
        rollerConveyorGroup.add(mainConduit)

        // 电缆束（橙色电源线）
        const cableGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.6, 8)
        const powerCable = new THREE.Mesh(cableGeo, new THREE.MeshStandardMaterial({
          color: 0xff6600,
          metalness: 0.3,
          roughness: 0.6
        }))
        powerCable.rotation.x = Math.PI / 2
        powerCable.position.set(conveyorWidth / 2 + 0.15, rollerBaseHeight + frameHeight + 0.05, -conveyorLength / 2 + 0.6)
        rollerConveyorGroup.add(powerCable)

        // 16. 润滑油管道
        const oilLineMaterial = new THREE.MeshStandardMaterial({
          color: 0x8b4513,
          metalness: 0.5,
          roughness: 0.5
        })

        const oilLineGeo = new THREE.CylinderGeometry(0.008, 0.008, conveyorLength * 0.6, 8)
        const oilLine = new THREE.Mesh(oilLineGeo, oilLineMaterial)
        oilLine.rotation.x = Math.PI / 2
        oilLine.position.set(conveyorWidth / 2 - frameWidth - 0.03, rollerBaseHeight + frameHeight + 0.02, 0)
        rollerConveyorGroup.add(oilLine)

        // 润滑油嘴（多个）
        const oilNippleGeo = new THREE.CylinderGeometry(0.012, 0.008, 0.025, 8)
        for (let i = 0; i < 4; i++) {
          const oilNipple = new THREE.Mesh(oilNippleGeo, new THREE.MeshStandardMaterial({
            color: 0xb8860b,
            metalness: 0.8,
            roughness: 0.2
          }))
          const zPos = -conveyorLength / 2 + 0.5 + i * 0.5
          oilNipple.position.set(conveyorWidth / 2 - frameWidth - 0.03, rollerBaseHeight + frameHeight + 0.04, zPos)
          rollerConveyorGroup.add(oilNipple)
        }

        // 17. 急停按钮（红色大按钮）
        const eStopButtonGeo = new THREE.CylinderGeometry(0.05, 0.05, 0.04, 16)
        const eStopButton = new THREE.Mesh(eStopButtonGeo, new THREE.MeshStandardMaterial({
          color: 0xff0000,
          emissive: 0xff0000,
          emissiveIntensity: 0.5,
          metalness: 0.4,
          roughness: 0.5
        }))
        eStopButton.position.set(-conveyorWidth / 2 - 0.15, rollerBaseHeight + frameHeight + 0.4, -conveyorLength / 2 + 0.8)
        eStopButton.castShadow = true
        rollerConveyorGroup.add(eStopButton)

        // 急停按钮底座（黄黑警示色）
        const eStopBaseGeo = new THREE.CylinderGeometry(0.07, 0.07, 0.03, 16)
        const eStopBase = new THREE.Mesh(eStopBaseGeo, new THREE.MeshStandardMaterial({
          color: 0xffcc00,
          metalness: 0.5,
          roughness: 0.5
        }))
        eStopBase.position.set(-conveyorWidth / 2 - 0.15, rollerBaseHeight + frameHeight + 0.38, -conveyorLength / 2 + 0.8)
        rollerConveyorGroup.add(eStopBase)

        // 18. 警示标签（多个位置）
        const warningLabelMaterial = new THREE.MeshStandardMaterial({
          color: 0xffcc00,
          metalness: 0.3,
          roughness: 0.6
        })

        const warningPositions = [
          { x: 0, y: rollerBaseHeight + frameHeight + 0.15, z: conveyorLength / 2 - 0.1 },
          { x: -conveyorWidth / 2 - 0.15, y: rollerBaseHeight + frameHeight + 0.15, z: 0 },
          { x: conveyorWidth / 2 + 0.15, y: rollerBaseHeight + frameHeight + 0.15, z: conveyorLength / 2 - 0.5 }
        ]

        warningPositions.forEach(pos => {
          const labelGeo = new THREE.BoxGeometry(0.12, 0.12, 0.01)
          const warningLabel = new THREE.Mesh(labelGeo, warningLabelMaterial)
          warningLabel.position.set(pos.x, pos.y, pos.z)
          warningLabel.castShadow = true
          rollerConveyorGroup.add(warningLabel)

          // 警示图案底板（黑色三角形）
          const triangleGeo = new THREE.CircleGeometry(0.05, 3)
          const triangle = new THREE.Mesh(triangleGeo, new THREE.MeshStandardMaterial({
            color: 0xffffff  // 改为白色
          }))
          triangle.position.set(pos.x, pos.y, pos.z + 0.011)
          rollerConveyorGroup.add(triangle)
        })

        // 19. 速度控制旋钮
        const speedKnobGeo = new THREE.CylinderGeometry(0.04, 0.04, 0.03, 16)
        const speedKnob = new THREE.Mesh(speedKnobGeo, new THREE.MeshStandardMaterial({
          color: 0x0066cc,
          metalness: 0.6,
          roughness: 0.4
        }))
        speedKnob.rotation.x = Math.PI / 2
        speedKnob.position.set(-conveyorWidth / 2 - 0.27, rollerBaseHeight + frameHeight + 0.1, -conveyorLength / 2 + 0.5)
        rollerConveyorGroup.add(speedKnob)

        // 速度刻度盘
        const dialGeo = new THREE.CircleGeometry(0.06, 32)
        const dial = new THREE.Mesh(dialGeo, new THREE.MeshStandardMaterial({
          color: 0xeeeeee,
          metalness: 0.2,
          roughness: 0.7
        }))
        dial.position.set(-conveyorWidth / 2 - 0.271, rollerBaseHeight + frameHeight + 0.1, -conveyorLength / 2 + 0.5)
        dial.rotation.y = -Math.PI / 2
        rollerConveyorGroup.add(dial)


        // 21. 清扫器（滚筒清洁装置）
        const scraperMaterial = new THREE.MeshStandardMaterial({
          color: 0x8b4513,
          metalness: 0.4,
          roughness: 0.6
        })

        const scraperGeo = new THREE.BoxGeometry(conveyorWidth - frameWidth * 2 - 0.1, 0.02, 0.08)
        const scraper = new THREE.Mesh(scraperGeo, scraperMaterial)
        scraper.position.set(0, rollerBaseHeight + frameHeight - 0.02, conveyorLength / 2 - 0.2)
        scraper.rotation.x = -Math.PI / 8
        rollerConveyorGroup.add(scraper)

        // 清扫器支架
        for (let i = 0; i < 3; i++) {
          const bracketGeo = new THREE.BoxGeometry(0.03, 0.1, 0.03)
          const bracket = new THREE.Mesh(bracketGeo, new THREE.MeshStandardMaterial({
            color: 0x505050,
            metalness: 0.7
          }))
          const xPos = -0.5 + i * 0.5
          bracket.position.set(xPos, rollerBaseHeight + frameHeight - 0.05, conveyorLength / 2 - 0.2)
          rollerConveyorGroup.add(bracket)
        }

        // 22. 接地端子
        const groundTerminalGeo = new THREE.BoxGeometry(0.04, 0.04, 0.02)
        const groundTerminal = new THREE.Mesh(groundTerminalGeo, new THREE.MeshStandardMaterial({
          color: 0xffd700,
          metalness: 0.9,
          roughness: 0.2
        }))
        groundTerminal.position.set(conveyorWidth / 2 - 0.1, rollerBaseHeight + 0.05, -conveyorLength / 2 + 0.2)
        rollerConveyorGroup.add(groundTerminal)

        // 接地线（绿黄色）
        const groundWireGeo = new THREE.CylinderGeometry(0.008, 0.008, 0.3, 8)
        const groundWire = new THREE.Mesh(groundWireGeo, new THREE.MeshStandardMaterial({
          color: 0x9acd32,
          metalness: 0.5,
          roughness: 0.5
        }))
        groundWire.position.set(conveyorWidth / 2 - 0.1, rollerBaseHeight - 0.1, -conveyorLength / 2 + 0.2)
        rollerConveyorGroup.add(groundWire)

        // 23. 检修口盖板
        const inspectionCoverGeo = new THREE.BoxGeometry(0.3, 0.02, 0.25)
        const inspectionCover = new THREE.Mesh(inspectionCoverGeo, new THREE.MeshStandardMaterial({
          color: 0x3a3a3a,
          metalness: 0.6,
          roughness: 0.4
        }))
        inspectionCover.position.set(0, rollerBaseHeight + 0.01, 0)
        inspectionCover.castShadow = true
        rollerConveyorGroup.add(inspectionCover)

        // 检修口把手
        const handleGeo = new THREE.BoxGeometry(0.08, 0.015, 0.03)
        const inspectionHandle = new THREE.Mesh(handleGeo, new THREE.MeshStandardMaterial({
          color: 0xff6600,
          metalness: 0.5,
          roughness: 0.5
        }))
        inspectionHandle.position.set(0, rollerBaseHeight + 0.03, 0)
        rollerConveyorGroup.add(inspectionHandle)

        // 24. 固定螺栓细节（框架连接处）
        const boltMaterial = new THREE.MeshStandardMaterial({
          color: 0x404040,
          metalness: 0.9,
          roughness: 0.3
        })

        const boltGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.02, 6)
        legPositions.forEach(pos => {
          // 每个腿部添加4个固定螺栓
          for (let i = 0; i < 4; i++) {
            const bolt = new THREE.Mesh(boltGeo, boltMaterial)
            const offsetX = i % 2 === 0 ? -0.03 : 0.03
            const offsetZ = i < 2 ? -0.03 : 0.03
            bolt.position.set(pos[0] + offsetX, rollerBaseHeight + 0.01, pos[1] + offsetZ)
            rollerConveyorGroup.add(bolt)
          }
        })

        // 25. 产品名牌（侧面）
        const nameplateMaterial = new THREE.MeshStandardMaterial({
          color: 0xc0c0c0,
          metalness: 0.7,
          roughness: 0.3
        })

        const nameplateGeo = new THREE.BoxGeometry(0.25, 0.15, 0.01)
        const nameplate = new THREE.Mesh(nameplateGeo, nameplateMaterial)
        nameplate.position.set(conveyorWidth / 2 - frameWidth / 2, rollerBaseHeight + frameHeight / 2, conveyorLength / 2 - 0.3)
        nameplate.castShadow = true
        rollerConveyorGroup.add(nameplate)

        // 名牌文字底板（黑色）
        const nameplateTextGeo = new THREE.BoxGeometry(0.22, 0.12, 0.005)
        const nameplateText = new THREE.Mesh(nameplateTextGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff  // 改为白色
        }))
        nameplateText.position.set(conveyorWidth / 2 - frameWidth / 2, rollerBaseHeight + frameHeight / 2, conveyorLength / 2 - 0.295)
        rollerConveyorGroup.add(nameplateText)

        // ========== 在滚筒输送机上方添加扫描设备 ==========
        // 扫描设备支撑立柱材质（纯白色金属）
        const scannerPostMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,
          metalness: 0.8,
          roughness: 0.2
        })

        // 扫描设备高度和位置
        const scannerHeight = 1.5  // 扫描设备总高度（增加）
        const postRadius = 0.05  // 立柱半径（加粗）
        const postHeight = scannerHeight - 0.3  // 立柱高度

        // 左侧立柱（带加强筋）
        const leftPostGeo = new THREE.CylinderGeometry(postRadius, postRadius * 1.3, postHeight, 16)
        const leftPost = new THREE.Mesh(leftPostGeo, scannerPostMaterial)
        leftPost.position.set(-conveyorWidth / 2 - 0.15, rollerBaseHeight + frameHeight + postHeight / 2, 0)
        leftPost.castShadow = true
        rollerConveyorGroup.add(leftPost)

        // 左侧立柱底座
        const postBaseGeo = new THREE.CylinderGeometry(postRadius * 2, postRadius * 2.5, 0.08, 16)
        const leftBase = new THREE.Mesh(postBaseGeo, scannerPostMaterial)
        leftBase.position.set(-conveyorWidth / 2 - 0.15, rollerBaseHeight + frameHeight + 0.04, 0)
        leftBase.castShadow = true
        rollerConveyorGroup.add(leftBase)

        // 右侧立柱
        const rightPost = new THREE.Mesh(leftPostGeo, scannerPostMaterial)
        rightPost.position.set(conveyorWidth / 2 + 0.15, rollerBaseHeight + frameHeight + postHeight / 2, 0)
        rightPost.castShadow = true
        rollerConveyorGroup.add(rightPost)

        // 右侧立柱底座
        const rightBase = new THREE.Mesh(postBaseGeo, scannerPostMaterial)
        rightBase.position.set(conveyorWidth / 2 + 0.15, rollerBaseHeight + frameHeight + 0.04, 0)
        rightBase.castShadow = true
        rollerConveyorGroup.add(rightBase)

        // 顶部横梁（工字梁造型）- 覆盖整个传送带长度
        const beamWidth = conveyorWidth + 0.4
        const beamLength = conveyorLength * 0.8  // 覆盖80%的传送带长度
        const beamGeo = new THREE.BoxGeometry(beamWidth, 0.12, beamLength)
        const beam = new THREE.Mesh(beamGeo, scannerPostMaterial)
        beam.position.set(0, rollerBaseHeight + frameHeight + postHeight, 0)
        beam.castShadow = true
        rollerConveyorGroup.add(beam)

        // 横梁加强板
        const beamPlateGeo = new THREE.BoxGeometry(beamWidth - 0.1, 0.03, beamLength - 0.1)
        const beamTopPlate = new THREE.Mesh(beamPlateGeo, scannerPostMaterial)
        beamTopPlate.position.set(0, rollerBaseHeight + frameHeight + postHeight + 0.075, 0)
        rollerConveyorGroup.add(beamTopPlate)

        const beamBottomPlate = new THREE.Mesh(beamPlateGeo, scannerPostMaterial)
        beamBottomPlate.position.set(0, rollerBaseHeight + frameHeight + postHeight - 0.075, 0)
        rollerConveyorGroup.add(beamBottomPlate)

        // 多个扫描头沿传送带分布
        const scannerHeadCount = 5
        const scannerSpacing = beamLength / (scannerHeadCount + 1)

        for (let i = 0; i < scannerHeadCount; i++) {
          const scannerZPos = -beamLength / 2 + scannerSpacing * (i + 1)

          // 扫描头外壳（分层设计）- 纯白色
          const scannerHeadMaterial = new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.6,
            roughness: 0.2
          })

          // 主扫描头外壳
          const scannerHeadGeo = new THREE.BoxGeometry(0.25, 0.22, 0.18)
          const scannerHead = new THREE.Mesh(scannerHeadGeo, scannerHeadMaterial)
          scannerHead.position.set(0, rollerBaseHeight + frameHeight + postHeight - 0.17, scannerZPos)
          scannerHead.castShadow = true
          rollerConveyorGroup.add(scannerHead)

          // 扫描头顶盖 - 纯白色
          const headCapGeo = new THREE.BoxGeometry(0.27, 0.05, 0.2)
          const headCap = new THREE.Mesh(headCapGeo, new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.75,
            roughness: 0.2
          }))
          headCap.position.set(0, rollerBaseHeight + frameHeight + postHeight - 0.05, scannerZPos)
          rollerConveyorGroup.add(headCap)

          // 扫描镜头外环 - 纯白色金属
          const lensRingGeo = new THREE.CylinderGeometry(0.06, 0.06, 0.04, 32)
          const lensRing = new THREE.Mesh(lensRingGeo, new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.95,
            roughness: 0.15
          }))
          lensRing.position.set(0, rollerBaseHeight + frameHeight + postHeight - 0.29, scannerZPos)
          lensRing.rotation.x = Math.PI / 2
          rollerConveyorGroup.add(lensRing)

          // 扫描镜头（白色发光玻璃）
          const lensGeo = new THREE.CircleGeometry(0.055, 32)
          const lensMaterial = new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.9,
            roughness: 0.1,
            emissive: 0xffffff,
            emissiveIntensity: 0.3
          })
          const lens = new THREE.Mesh(lensGeo, lensMaterial)
          lens.position.set(0, rollerBaseHeight + frameHeight + postHeight - 0.291, scannerZPos)
          lens.rotation.x = Math.PI / 2
          rollerConveyorGroup.add(lens)
        }

        // 激光扫描线（白色发光）
        const laserLineGeo = new THREE.PlaneGeometry(conveyorWidth + 0.2, 0.002)
        const laserLineMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,
          emissive: 0xffffff,
          emissiveIntensity: 0.9,
          transparent: true,
          opacity: 0.7,
          side: THREE.DoubleSide
        })
        const laserLine = new THREE.Mesh(laserLineGeo, laserLineMaterial)
        laserLine.position.set(0, rollerBaseHeight + frameHeight + 0.15, 0)
        laserLine.rotation.x = Math.PI / 2
        rollerConveyorGroup.add(laserLine)

        // 指示灯组（3个LED灯）
        const ledColors = [0x00ff00, 0xffff00, 0xff0000]
        const ledPositions = [-0.07, 0, 0.07]

        ledPositions.forEach((xPos, index) => {
          // LED灯座
          const ledHousingGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.01, 16)
          const ledHousing = new THREE.Mesh(ledHousingGeo, new THREE.MeshStandardMaterial({
            color: 0xffffff,  // 改为白色
            metalness: 0.6,
            roughness: 0.4
          }))
          ledHousing.position.set(xPos, rollerBaseHeight + frameHeight + postHeight - 0.03, 0.08)
          ledHousing.rotation.x = Math.PI / 2
          rollerConveyorGroup.add(ledHousing)

          // LED灯（发光）
          const ledGeo = new THREE.SphereGeometry(0.012, 16, 16)
          const ledMaterial = new THREE.MeshStandardMaterial({
            color: ledColors[index],
            emissive: ledColors[index],
            emissiveIntensity: index === 0 ? 0.8 : 0.2,
            metalness: 0.3,
            roughness: 0.4
          })
          const led = new THREE.Mesh(ledGeo, ledMaterial)
          led.position.set(xPos, rollerBaseHeight + frameHeight + postHeight - 0.03, 0.09)
          rollerConveyorGroup.add(led)

          // 活跃LED的光晕
          if (index === 0) {
            const ledLight = new THREE.PointLight(ledColors[index], 0.5, 0.3)
            ledLight.position.set(xPos, rollerBaseHeight + frameHeight + postHeight - 0.03, 0.09)
            rollerConveyorGroup.add(ledLight)
          }
        })

        // 电源线缆
        const scannerCableGeo = new THREE.CylinderGeometry(0.008, 0.008, 0.3, 8)
        const scannerCableMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.2,
          roughness: 0.8
        })
        const scannerCable = new THREE.Mesh(scannerCableGeo, scannerCableMaterial)
        scannerCable.position.set(conveyorWidth / 2 + 0.1, rollerBaseHeight + frameHeight + postHeight - 0.15, 0)
        rollerConveyorGroup.add(scannerCable)

        // 接线盒 - 纯白色
        const junctionBoxGeo = new THREE.BoxGeometry(0.08, 0.12, 0.06)
        const junctionBox = new THREE.Mesh(junctionBoxGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff,
          metalness: 0.6,
          roughness: 0.4
        }))
        junctionBox.position.set(conveyorWidth / 2 + 0.1, rollerBaseHeight + frameHeight + 0.3, 0)
        junctionBox.castShadow = true
        rollerConveyorGroup.add(junctionBox)

        // 品牌标识 - 纯白色发光
        const brandLabelGeo = new THREE.BoxGeometry(0.12, 0.03, 0.001)
        const brandLabel = new THREE.Mesh(brandLabelGeo, new THREE.MeshStandardMaterial({
          color: 0xffffff,
          emissive: 0xffffff,
          emissiveIntensity: 0.4,
          metalness: 0.7,
          roughness: 0.3
        }))
        brandLabel.position.set(0, rollerBaseHeight + frameHeight + postHeight - 0.14, 0.076)
        rollerConveyorGroup.add(brandLabel)

        // 设置滚筒输送机的世界坐标
        rollerConveyorGroup.position.set(rollerConveyorPositionX, 0, rollerConveyorPositionZ)
        rollerConveyorGroup.rotation.y = -Math.PI * 5 / 2  // 保持相同的旋转角度
        area.add(rollerConveyorGroup)

        // ========== 在滚筒输送机右侧添加第二条滚筒传送带 ==========
        const rollerConveyor2Group = new THREE.Group()

        // 第二条滚筒传送带位置（第一条的右侧）
        const conveyor2Width = 1.5  // 输送机宽度（X方向）
        const conveyor2Length = 2.5  // 输送机长度（Z方向）
        const spacing = 0.3  // 两条传送带之间的间距
        // X位置：在第一条传送带右侧
        const rollerConveyor2PositionX = rollerConveyorPositionX + conveyorWidth + spacing
        // Z位置：与第一条传送带对齐
        const rollerConveyor2PositionZ = rollerConveyorPositionZ

        // 1. 底座平台（深灰色）
        const roller2BaseMaterial = new THREE.MeshStandardMaterial({
          color: 0x404040,
          metalness: 0.7,
          roughness: 0.4
        })

        const roller2BaseHeight = 0.12
        const roller2BaseGeo = new THREE.BoxGeometry(conveyor2Width, roller2BaseHeight, conveyor2Length)
        const roller2Base = new THREE.Mesh(roller2BaseGeo, roller2BaseMaterial)
        roller2Base.position.set(0, roller2BaseHeight / 2, 0)
        roller2Base.castShadow = true
        rollerConveyor2Group.add(roller2Base)

        // 2. 蓝色支撑框架（两侧纵向主梁）
        const blue2FrameMaterial = new THREE.MeshStandardMaterial({
          color: 0x2e5c8a,
          metalness: 0.7,
          roughness: 0.3
        })

        const frame2Height = 0.25
        const frame2Width = 0.08
        const frame2Depth = conveyor2Length

        // 左侧纵向主梁
        const left2FrameGeo = new THREE.BoxGeometry(frame2Width, frame2Height, frame2Depth)
        const left2Frame = new THREE.Mesh(left2FrameGeo, blue2FrameMaterial)
        left2Frame.position.set(-conveyor2Width / 2 + frame2Width / 2, roller2BaseHeight + frame2Height / 2, 0)
        left2Frame.castShadow = true
        rollerConveyor2Group.add(left2Frame)

        // 右侧纵向主梁
        const right2Frame = new THREE.Mesh(left2FrameGeo, blue2FrameMaterial)
        right2Frame.position.set(conveyor2Width / 2 - frame2Width / 2, roller2BaseHeight + frame2Height / 2, 0)
        right2Frame.castShadow = true
        rollerConveyor2Group.add(right2Frame)

        // 3. 横向支撑梁（蓝色）
        const crossBeam2Count = 5
        const crossBeam2Geo = new THREE.BoxGeometry(conveyor2Width - frame2Width * 2, 0.06, 0.08)
        for (let i = 0; i < crossBeam2Count; i++) {
          const crossBeam = new THREE.Mesh(crossBeam2Geo, blue2FrameMaterial)
          const zPos = -conveyor2Length / 2 + (conveyor2Length / (crossBeam2Count - 1)) * i
          crossBeam.position.set(0, roller2BaseHeight + 0.03, zPos)
          crossBeam.castShadow = true
          rollerConveyor2Group.add(crossBeam)
        }

        // 4. 滚筒（白色/浅灰色，排列整齐）
        const roller2Material = new THREE.MeshStandardMaterial({
          color: 0xe8e8e8,
          metalness: 0.6,
          roughness: 0.3
        })

        const roller2Radius = 0.04
        const roller2Length = conveyor2Width - frame2Width * 2 - 0.05
        const roller2Geo = new THREE.CylinderGeometry(roller2Radius, roller2Radius, roller2Length, 20)
        const roller2Count = 25
        const roller2Spacing = conveyor2Length / (roller2Count + 1)

        for (let i = 0; i < roller2Count; i++) {
          const roller = new THREE.Mesh(roller2Geo, roller2Material)
          roller.rotation.z = Math.PI / 2
          const zPos = -conveyor2Length / 2 + roller2Spacing * (i + 1)
          roller.position.set(0, roller2BaseHeight + frame2Height, zPos)
          roller.castShadow = true
          rollerConveyor2Group.add(roller)

          // 滚筒轴承座（两端）
          const bearing2Material = new THREE.MeshStandardMaterial({
            color: 0x505050,
            metalness: 0.8,
            roughness: 0.3
          })
          const bearing2Geo = new THREE.BoxGeometry(0.05, 0.05, 0.03)

          const leftBearing = new THREE.Mesh(bearing2Geo, bearing2Material)
          leftBearing.position.set(-roller2Length / 2 - 0.025, roller2BaseHeight + frame2Height, zPos)
          leftBearing.castShadow = true
          rollerConveyor2Group.add(leftBearing)

          const rightBearing = new THREE.Mesh(bearing2Geo, bearing2Material)
          rightBearing.position.set(roller2Length / 2 + 0.025, roller2BaseHeight + frame2Height, zPos)
          rightBearing.castShadow = true
          rollerConveyor2Group.add(rightBearing)
        }

        // 5. 黄色安全护栏（两侧）
        const yellow2RailingMaterial = new THREE.MeshStandardMaterial({
          color: 0xffd700,
          metalness: 0.5,
          roughness: 0.4
        })

        const railing2Height = 0.5
        const railing2PostCount = 6

        // 护栏立柱（两侧）
        const railing2PostGeo = new THREE.CylinderGeometry(0.025, 0.025, railing2Height, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyor2Width / 2 - 0.1 : conveyor2Width / 2 + 0.1

          for (let i = 0; i < railing2PostCount; i++) {
            const post = new THREE.Mesh(railing2PostGeo, yellow2RailingMaterial)
            const zPos = -conveyor2Length / 2 + (conveyor2Length / (railing2PostCount - 1)) * i
            post.position.set(xPos, roller2BaseHeight + frame2Height + railing2Height / 2, zPos)
            post.castShadow = true
            rollerConveyor2Group.add(post)
          }
        }

        // 护栏横杆（上下两层，两侧）
        const railing2BarGeo = new THREE.CylinderGeometry(0.02, 0.02, conveyor2Length, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyor2Width / 2 - 0.1 : conveyor2Width / 2 + 0.1

          // 上层横杆
          const topBar = new THREE.Mesh(railing2BarGeo, yellow2RailingMaterial)
          topBar.rotation.x = Math.PI / 2
          topBar.position.set(xPos, roller2BaseHeight + frame2Height + railing2Height - 0.1, 0)
          topBar.castShadow = true
          rollerConveyor2Group.add(topBar)

          // 下层横杆
          const midBar = new THREE.Mesh(railing2BarGeo, yellow2RailingMaterial)
          midBar.rotation.x = Math.PI / 2
          midBar.position.set(xPos, roller2BaseHeight + frame2Height + railing2Height / 2, 0)
          midBar.castShadow = true
          rollerConveyor2Group.add(midBar)
        }

        // 6. 支撑腿（四个角）
        const support2LegMaterial = new THREE.MeshStandardMaterial({
          color: 0x2e5c8a,
          metalness: 0.7,
          roughness: 0.4
        })

        const leg2Height = 0.8
        const leg2Geo = new THREE.BoxGeometry(0.08, leg2Height, 0.08)
        const leg2Positions = [
          [-conveyor2Width / 2 + 0.15, -conveyor2Length / 2 + 0.15],
          [conveyor2Width / 2 - 0.15, -conveyor2Length / 2 + 0.15],
          [-conveyor2Width / 2 + 0.15, conveyor2Length / 2 - 0.15],
          [conveyor2Width / 2 - 0.15, conveyor2Length / 2 - 0.15]
        ]

        leg2Positions.forEach(pos => {
          const leg = new THREE.Mesh(leg2Geo, support2LegMaterial)
          leg.position.set(pos[0], -leg2Height / 2 + roller2BaseHeight, pos[1])
          leg.castShadow = true
          rollerConveyor2Group.add(leg)

          // 腿部底座固定板
          const footPlate2Geo = new THREE.BoxGeometry(0.15, 0.03, 0.15)
          const footPlate = new THREE.Mesh(footPlate2Geo, new THREE.MeshStandardMaterial({
            color: 0x404040,
            metalness: 0.7,
            roughness: 0.4
          }))
          footPlate.position.set(pos[0], -leg2Height + roller2BaseHeight, pos[1])
          footPlate.castShadow = true
          rollerConveyor2Group.add(footPlate)

          // 对角支撑加强筋
          const reinforce2Geo = new THREE.BoxGeometry(0.04, 0.5, 0.04)
          const reinforce = new THREE.Mesh(reinforce2Geo, new THREE.MeshStandardMaterial({
            color: 0x2e5c8a,
            metalness: 0.7,
            roughness: 0.4
          }))
          reinforce.rotation.z = pos[0] < 0 ? Math.PI / 4 : -Math.PI / 4
          reinforce.position.set(pos[0], -leg2Height / 2 + roller2BaseHeight + 0.25, pos[1])
          reinforce.castShadow = true
          rollerConveyor2Group.add(reinforce)
        })

        // 7. 驱动电机
        const motor2Geo = new THREE.BoxGeometry(0.25, 0.25, 0.3)
        const motor2 = new THREE.Mesh(motor2Geo, new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.8,
          roughness: 0.3
        }))
        motor2.position.set(conveyor2Width / 2 + 0.15, roller2BaseHeight + frame2Height / 2, -conveyor2Length / 2 + 0.3)
        motor2.castShadow = true
        rollerConveyor2Group.add(motor2)

        // 8. 控制箱
        const control2BoxGeo = new THREE.BoxGeometry(0.3, 0.4, 0.2)
        const control2Box = new THREE.Mesh(control2BoxGeo, new THREE.MeshStandardMaterial({
          color: 0x3a3a3a,
          metalness: 0.5,
          roughness: 0.5
        }))
        control2Box.position.set(-conveyor2Width / 2 - 0.15, roller2BaseHeight + frame2Height + 0.2, -conveyor2Length / 2 + 0.5)
        control2Box.castShadow = true
        rollerConveyor2Group.add(control2Box)

        // 控制箱面板
        const panel2Geo = new THREE.BoxGeometry(0.25, 0.35, 0.02)
        const panel2 = new THREE.Mesh(panel2Geo, new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.4,
          roughness: 0.6
        }))
        panel2.position.set(-conveyor2Width / 2 - 0.26, roller2BaseHeight + frame2Height + 0.2, -conveyor2Length / 2 + 0.5)
        rollerConveyor2Group.add(panel2)

        // 运行指示灯（绿色）
        const running2LightGeo = new THREE.CircleGeometry(0.025, 16)
        const running2Light = new THREE.Mesh(running2LightGeo, new THREE.MeshStandardMaterial({
          color: 0x00ff00,
          emissive: 0x00ff00,
          emissiveIntensity: 0.8
        }))
        running2Light.position.set(-conveyor2Width / 2 - 0.27, roller2BaseHeight + frame2Height + 0.3, -conveyor2Length / 2 + 0.5)
        running2Light.rotation.y = -Math.PI / 2
        rollerConveyor2Group.add(running2Light)

        // 9. 标识牌
        const conveyor2SignGeo = new THREE.BoxGeometry(0.4, 0.2, 0.02)
        const conveyor2Sign = new THREE.Mesh(conveyor2SignGeo, new THREE.MeshStandardMaterial({
          color: 0xffcc00,
          metalness: 0.4,
          roughness: 0.5
        }))
        conveyor2Sign.position.set(0, roller2BaseHeight + frame2Height + railing2Height + 0.15, -conveyor2Length / 2 + 0.3)
        conveyor2Sign.castShadow = true
        rollerConveyor2Group.add(conveyor2Sign)


        // 设置第二条滚筒输送机的世界坐标
        rollerConveyor2Group.position.set(rollerConveyor2PositionX, 0, rollerConveyor2PositionZ)
        rollerConveyor2Group.rotation.y = -Math.PI * 5 / 2  // 保持相同的旋转角度
        area.add(rollerConveyor2Group)

        // ========== 在第二条滚筒输送机右侧添加横向传送带 ==========
        const conveyor3Width = 0.8  // 传送带宽度
        const conveyor3Length = 20.0  // 横向传送带长度20米
        const horizontalConveyor3 = createRealisticRollerConveyor(conveyor3Length, conveyor3Width)

        // 计算横向传送带的位置（在第二条滚筒输送机右侧）
        // 履带向左移动
        const horizontalConveyor3PositionX = rollerConveyor2PositionX + conveyor2Width + spacing + conveyor3Length / 2 - 0.6 + 0.0  // 履带向左移动
        const horizontalConveyor3PositionZ = rollerConveyor2PositionZ

        horizontalConveyor3.position.set(horizontalConveyor3PositionX, 0, horizontalConveyor3PositionZ)
        horizontalConveyor3.rotation.y = -Math.PI * 5 / 2  // 向左旋转90度
        area.add(horizontalConveyor3)

        // ========== 在横向传送带下方添加3个斜向传送带(与横向传送带相连) ==========
        const diagonal3ConveyorWidth = 0.8  // 斜向传送带宽度
        const diagonal3ConveyorLength = 4.0  // 斜向传送带长度
        const diagonal3ConveyorSpacing = 5.0  // 斜向传送带之间的间距5米

        // 存储每个连接传送带的位置信息
        const group1BottomConnectors: Array<{ x: number; z: number }> = []

        for (let i = 0; i < 3; i++) {
          const diagonal3Conveyor = createRealisticRollerConveyor(diagonal3ConveyorLength, diagonal3ConveyorWidth, {
            shortenLeftFrameEnd: -0.1  // 延长左侧框架0.1米（负值表示延长）
          })

          // 计算斜向传送带的位置（与横向传送带相连，从横向传送带起点沿X轴分布）
          // 起点位置：横向传送带左端，向右移动
          const startX = horizontalConveyor3PositionX - conveyor3Length / 2 + 1.0 + 8.5  // 向右移动2.5米
          const diagonal3ConveyorPositionX = startX + i * diagonal3ConveyorSpacing
          // Z位置：增加与横向传送带的间隔
          const diagonal3ConveyorPositionZ = horizontalConveyor3PositionZ + diagonal3ConveyorLength / 2 * Math.cos(Math.PI / 4) + 0.2  // 间隔距离0.2米

          diagonal3Conveyor.position.set(diagonal3ConveyorPositionX, 0, diagonal3ConveyorPositionZ)
          diagonal3Conveyor.rotation.y = Math.PI / 4  // 向右倾斜45度
          area.add(diagonal3Conveyor)

          // 计算斜向传送带的终点位置
          const diagonal3EndX = diagonal3ConveyorPositionX + (diagonal3ConveyorLength / 2) * Math.cos(Math.PI / 4)
          const diagonal3EndZ = diagonal3ConveyorPositionZ + (diagonal3ConveyorLength / 2) * Math.sin(Math.PI / 4)

          // 直接在斜向传送带终点添加横向传送带
          const shortHorizontalLength = 1.0  // 横向传送带长度1米（缩短1米）
          const shortHorizontalWidth = 0.8
          const shortHorizontalConveyor = createRealisticRollerConveyor(shortHorizontalLength, shortHorizontalWidth)

          // 横向传送带位置：从斜向传送带终点开始，向左延伸
          // 重叠距离
          const overlapDistance = 0.25
          shortHorizontalConveyor.position.set(
            diagonal3EndX - overlapDistance + shortHorizontalLength / 2,
            0,
            diagonal3EndZ
          )
          shortHorizontalConveyor.rotation.y = -Math.PI / 2  // 横向（向左）
          area.add(shortHorizontalConveyor)

          // 在横向传送带右侧添加竖着的传送带
          const verticalConveyorLength = 8.0  // 竖着传送带长度8米（向下延长1米，向上延长1米）
          const verticalConveyorWidth = 0.8
          const verticalConveyor = createRealisticRollerConveyor(verticalConveyorLength, verticalConveyorWidth)

          // 计算竖着传送带的位置（在横向传送带右端）
          const shortHorizontalEndX = diagonal3EndX - overlapDistance + shortHorizontalLength
          const verticalConveyorPositionX = shortHorizontalEndX + 0.25  // 右侧，有0.25米重叠
          const verticalConveyorPositionZ = diagonal3EndZ + verticalConveyorLength / 2 - 0.4  // 向前延伸，向上延长调整位置

          verticalConveyor.position.set(verticalConveyorPositionX, 0, verticalConveyorPositionZ)
          verticalConveyor.rotation.y = 0  // 竖着（向前）
          area.add(verticalConveyor)

          // 在竖着传送带下方添加安检设备
          const securityDevice = createSecurityCheckDevice()
          const verticalConveyorEndZ = verticalConveyorPositionZ + verticalConveyorLength / 2
          securityDevice.position.set(
            verticalConveyorPositionX,
            0,
            verticalConveyorEndZ + 1.5  // 在传送带末端下方1.5米处
          )
          area.add(securityDevice)

          // 在安检设备下方创建竖着的履带传送带
          const verticalBeltLength = 5.0  // 竖着履带传送带长度5米
          const verticalBeltWidth = 1.0
          const verticalBelt = createBeltConveyor(verticalBeltLength, verticalBeltWidth)

          // 履带传送带位置：在安检设备下方，沿Z轴竖着
          // Y坐标抬高0.28，使履带表面与下方连接传送带的滚筒顶部保持相同高度
          verticalBelt.position.set(
            verticalConveyorPositionX,
            0.28,  // 抬高与横向滚筒传送带保持相同高度
            verticalConveyorEndZ + 1.5 + 2.75 + verticalBeltLength / 2  // 在安检设备末端下方
          )
          verticalBelt.rotation.y = 0  // 不旋转，沿Z轴方向
          area.add(verticalBelt)

          // 在白色履带传送带下方添加连接用横向传送带（与之前横向传送带样式一样）
          const connectingConveyorLength = 4.2  // 连接传送带长度4.2米（末端延长0.2米）
          const connectingConveyorWidth = 0.8
          const connectingConveyor = createRealisticRollerConveyor(connectingConveyorLength, connectingConveyorWidth)

          // 计算连接传送带位置（在白色履带传送带末端下方）
          const verticalBeltEndZ = verticalConveyorEndZ + 1.5 + 2.75 + verticalBeltLength
          const connectingConveyorPositionX = verticalConveyorPositionX
          const connectingConveyorPositionZ = verticalBeltEndZ + connectingConveyorLength / 2

          connectingConveyor.position.set(connectingConveyorPositionX, 0, connectingConveyorPositionZ)
          connectingConveyor.rotation.y = 0  // 沿Z轴方向
          area.add(connectingConveyor)

          // 保存连接传送带的末端位置
          const connectingConveyorEndZ = connectingConveyorPositionZ + connectingConveyorLength / 2
          group1BottomConnectors.push({
            x: connectingConveyorPositionX,
            z: connectingConveyorEndZ
          })
        }

        // ========== 在斜向传送带和右上端横向传送带连接处添加第三条滚筒传送带 ==========
        const rollerConveyor3Group = new THREE.Group()

        // 第三条滚筒传送带尺寸
        const conveyor3RollerWidth = 1.5  // 输送机宽度（X方向）
        const conveyor3RollerLength = 2.5  // 输送机长度（Z方向）

        // 计算第三条滚筒传送带位置（在斜向传送带终点下方）
        const rollerConveyor3PositionX = diagonalEndX + 1.5 - 0.1  // 向右移动1.5米,再向左调整0.1米
        const rollerConveyor3PositionZ = diagonalEndZ + horizontalConveyorWidth / 2 + conveyor3RollerLength / 2 + 0.3 + 0.5  // 向下移动0.5米

        // 1. 底座平台（深灰色）
        const roller3BaseMaterial = new THREE.MeshStandardMaterial({
          color: 0x404040,
          metalness: 0.7,
          roughness: 0.4
        })

        const roller3BaseHeight = 0.12
        const roller3BaseGeo = new THREE.BoxGeometry(conveyor3RollerWidth, roller3BaseHeight, conveyor3RollerLength)
        const roller3Base = new THREE.Mesh(roller3BaseGeo, roller3BaseMaterial)
        roller3Base.position.set(0, roller3BaseHeight / 2, 0)
        roller3Base.castShadow = true
        rollerConveyor3Group.add(roller3Base)

        // 2. 蓝色支撑框架（两侧纵向主梁）
        const blue3FrameMaterial = new THREE.MeshStandardMaterial({
          color: 0x2e5c8a,
          metalness: 0.7,
          roughness: 0.3
        })

        const frame3Height = 0.25
        const frame3Width = 0.08
        const frame3Depth = conveyor3RollerLength

        // 左侧纵向主梁
        const left3FrameGeo = new THREE.BoxGeometry(frame3Width, frame3Height, frame3Depth)
        const left3Frame = new THREE.Mesh(left3FrameGeo, blue3FrameMaterial)
        left3Frame.position.set(-conveyor3RollerWidth / 2 + frame3Width / 2, roller3BaseHeight + frame3Height / 2, 0)
        left3Frame.castShadow = true
        rollerConveyor3Group.add(left3Frame)

        // 右侧纵向主梁
        const right3Frame = new THREE.Mesh(left3FrameGeo, blue3FrameMaterial)
        right3Frame.position.set(conveyor3RollerWidth / 2 - frame3Width / 2, roller3BaseHeight + frame3Height / 2, 0)
        right3Frame.castShadow = true
        rollerConveyor3Group.add(right3Frame)

        // 3. 横向支撑梁（蓝色）
        const crossBeam3Count = 5
        const crossBeam3Geo = new THREE.BoxGeometry(conveyor3RollerWidth - frame3Width * 2, 0.06, 0.08)
        for (let i = 0; i < crossBeam3Count; i++) {
          const crossBeam = new THREE.Mesh(crossBeam3Geo, blue3FrameMaterial)
          const zPos = -conveyor3RollerLength / 2 + (conveyor3RollerLength / (crossBeam3Count - 1)) * i
          crossBeam.position.set(0, roller3BaseHeight + 0.03, zPos)
          crossBeam.castShadow = true
          rollerConveyor3Group.add(crossBeam)
        }

        // 4. 滚筒（白色/浅灰色，排列整齐）
        const roller3Material = new THREE.MeshStandardMaterial({
          color: 0xe8e8e8,
          metalness: 0.6,
          roughness: 0.3
        })

        const roller3Radius = 0.04
        const roller3Length = conveyor3RollerWidth - frame3Width * 2 - 0.05
        const roller3Geo = new THREE.CylinderGeometry(roller3Radius, roller3Radius, roller3Length, 20)
        const roller3Count = 25
        const roller3Spacing = conveyor3RollerLength / (roller3Count + 1)

        for (let i = 0; i < roller3Count; i++) {
          const roller = new THREE.Mesh(roller3Geo, roller3Material)
          roller.rotation.z = Math.PI / 2  // 旋转90度，使滚筒横向
          const zPos = -conveyor3RollerLength / 2 + roller3Spacing * (i + 1)
          roller.position.set(0, roller3BaseHeight + frame3Height, zPos)
          roller.castShadow = true
          rollerConveyor3Group.add(roller)

          // 滚筒轴承座（两端）
          const bearing3Material = new THREE.MeshStandardMaterial({
            color: 0x505050,
            metalness: 0.8,
            roughness: 0.3
          })
          const bearing3Geo = new THREE.BoxGeometry(0.05, 0.05, 0.03)

          // 左侧轴承
          const leftBearing = new THREE.Mesh(bearing3Geo, bearing3Material)
          leftBearing.position.set(-roller3Length / 2 - 0.025, roller3BaseHeight + frame3Height, zPos)
          leftBearing.castShadow = true
          rollerConveyor3Group.add(leftBearing)

          // 右侧轴承
          const rightBearing = new THREE.Mesh(bearing3Geo, bearing3Material)
          rightBearing.position.set(roller3Length / 2 + 0.025, roller3BaseHeight + frame3Height, zPos)
          rightBearing.castShadow = true
          rollerConveyor3Group.add(rightBearing)
        }

        // 5. 驱动电机（末端）
        const motor3Material = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.6,
          roughness: 0.4
        })

        const motorBody3Geo = new THREE.CylinderGeometry(0.12, 0.12, 0.25, 16)
        const motorBody3 = new THREE.Mesh(motorBody3Geo, motor3Material)
        motorBody3.rotation.z = Math.PI / 2
        motorBody3.position.set(conveyor3RollerWidth / 2 + 0.2, roller3BaseHeight + frame3Height, conveyor3RollerLength / 2 - 0.3)
        motorBody3.castShadow = true
        rollerConveyor3Group.add(motorBody3)

        // 电机法兰
        const motorFlange3Geo = new THREE.CylinderGeometry(0.15, 0.15, 0.03, 16)
        const motorFlange3 = new THREE.Mesh(motorFlange3Geo, new THREE.MeshStandardMaterial({
          color: 0x2c3e50,
          metalness: 0.7,
          roughness: 0.3
        }))
        motorFlange3.rotation.z = Math.PI / 2
        motorFlange3.position.set(conveyor3RollerWidth / 2 + 0.075, roller3BaseHeight + frame3Height, conveyor3RollerLength / 2 - 0.3)
        rollerConveyor3Group.add(motorFlange3)

        // 6. 控制箱
        const controlBox3Geo = new THREE.BoxGeometry(0.3, 0.4, 0.2)
        const controlBox3 = new THREE.Mesh(controlBox3Geo, new THREE.MeshStandardMaterial({
          color: 0x34495e,
          metalness: 0.5,
          roughness: 0.5
        }))
        controlBox3.position.set(-conveyor3RollerWidth / 2 - 0.2, roller3BaseHeight + 0.2, -conveyor3RollerLength / 2 + 0.5)
        controlBox3.castShadow = true
        rollerConveyor3Group.add(controlBox3)

        // 7. 黄色安全护栏（两侧）
        const yellowRailing3Material = new THREE.MeshStandardMaterial({
          color: 0xffd700,  // 金黄色
          metalness: 0.5,
          roughness: 0.4
        })

        const railing3Height = 0.5
        const railing3PostCount = 6

        // 护栏立柱（两侧）
        const railing3PostGeo = new THREE.CylinderGeometry(0.025, 0.025, railing3Height, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyor3RollerWidth / 2 - 0.1 : conveyor3RollerWidth / 2 + 0.1

          for (let i = 0; i < railing3PostCount; i++) {
            const post = new THREE.Mesh(railing3PostGeo, yellowRailing3Material)
            const zPos = -conveyor3RollerLength / 2 + (conveyor3RollerLength / (railing3PostCount - 1)) * i
            post.position.set(xPos, roller3BaseHeight + frame3Height + railing3Height / 2, zPos)
            post.castShadow = true
            rollerConveyor3Group.add(post)
          }
        }

        // 护栏横杆（上下两层，两侧）
        const railing3BarGeo = new THREE.CylinderGeometry(0.02, 0.02, conveyor3RollerLength, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyor3RollerWidth / 2 - 0.1 : conveyor3RollerWidth / 2 + 0.1

          // 上层横杆
          const topBar = new THREE.Mesh(railing3BarGeo, yellowRailing3Material)
          topBar.rotation.x = Math.PI / 2
          topBar.position.set(xPos, roller3BaseHeight + frame3Height + railing3Height - 0.1, 0)
          topBar.castShadow = true
          rollerConveyor3Group.add(topBar)

          // 下层横杆
          const midBar = new THREE.Mesh(railing3BarGeo, yellowRailing3Material)
          midBar.rotation.x = Math.PI / 2
          midBar.position.set(xPos, roller3BaseHeight + frame3Height + railing3Height / 2, 0)
          midBar.castShadow = true
          rollerConveyor3Group.add(midBar)
        }

        // 8. 扫描设备（与第一条滚筒传送带一致）
        const scanner3PostMaterial = new THREE.MeshStandardMaterial({
          color: 0xffffff,
          metalness: 0.8,
          roughness: 0.2
        })

        const scanner3Height = 1.5
        const post3Radius = 0.05
        const post3Height = scanner3Height - 0.3

        // 左侧立柱
        const leftPost3Geo = new THREE.CylinderGeometry(post3Radius, post3Radius * 1.3, post3Height, 16)
        const leftPost3 = new THREE.Mesh(leftPost3Geo, scanner3PostMaterial)
        leftPost3.position.set(-conveyor3RollerWidth / 2 - 0.15, roller3BaseHeight + frame3Height + post3Height / 2, 0)
        leftPost3.castShadow = true
        rollerConveyor3Group.add(leftPost3)

        // 左侧立柱底座
        const postBase3Geo = new THREE.CylinderGeometry(post3Radius * 2, post3Radius * 2.5, 0.08, 16)
        const leftBase3 = new THREE.Mesh(postBase3Geo, scanner3PostMaterial)
        leftBase3.position.set(-conveyor3RollerWidth / 2 - 0.15, roller3BaseHeight + frame3Height + 0.04, 0)
        leftBase3.castShadow = true
        rollerConveyor3Group.add(leftBase3)

        // 右侧立柱
        const rightPost3 = new THREE.Mesh(leftPost3Geo, scanner3PostMaterial)
        rightPost3.position.set(conveyor3RollerWidth / 2 + 0.15, roller3BaseHeight + frame3Height + post3Height / 2, 0)
        rightPost3.castShadow = true
        rollerConveyor3Group.add(rightPost3)

        // 右侧立柱底座
        const rightBase3 = new THREE.Mesh(postBase3Geo, scanner3PostMaterial)
        rightBase3.position.set(conveyor3RollerWidth / 2 + 0.15, roller3BaseHeight + frame3Height + 0.04, 0)
        rightBase3.castShadow = true
        rollerConveyor3Group.add(rightBase3)

        // 顶部横梁
        const beam3Width = conveyor3RollerWidth + 0.4
        const beam3Length = conveyor3RollerLength * 0.8
        const beam3Geo = new THREE.BoxGeometry(beam3Width, 0.12, beam3Length)
        const beam3 = new THREE.Mesh(beam3Geo, scanner3PostMaterial)
        beam3.position.set(0, roller3BaseHeight + frame3Height + post3Height, 0)
        beam3.castShadow = true
        rollerConveyor3Group.add(beam3)

        // 横梁加强板
        const beamPlate3Geo = new THREE.BoxGeometry(beam3Width - 0.1, 0.03, beam3Length - 0.1)
        const beamTopPlate3 = new THREE.Mesh(beamPlate3Geo, scanner3PostMaterial)
        beamTopPlate3.position.set(0, roller3BaseHeight + frame3Height + post3Height + 0.075, 0)
        rollerConveyor3Group.add(beamTopPlate3)

        const beamBottomPlate3 = new THREE.Mesh(beamPlate3Geo, scanner3PostMaterial)
        beamBottomPlate3.position.set(0, roller3BaseHeight + frame3Height + post3Height - 0.075, 0)
        rollerConveyor3Group.add(beamBottomPlate3)

        // 多个扫描头沿传送带分布
        const scanner3HeadCount = 5
        const scanner3Spacing = beam3Length / (scanner3HeadCount + 1)

        for (let i = 0; i < scanner3HeadCount; i++) {
          const scanner3ZPos = -beam3Length / 2 + scanner3Spacing * (i + 1)

          // 扫描头外壳
          const scannerHead3Material = new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.6,
            roughness: 0.2
          })

          const scannerHead3Geo = new THREE.BoxGeometry(0.25, 0.22, 0.18)
          const scannerHead3 = new THREE.Mesh(scannerHead3Geo, scannerHead3Material)
          scannerHead3.position.set(0, roller3BaseHeight + frame3Height + post3Height - 0.17, scanner3ZPos)
          scannerHead3.castShadow = true
          rollerConveyor3Group.add(scannerHead3)

          // 扫描头顶盖
          const headCap3Geo = new THREE.BoxGeometry(0.27, 0.05, 0.2)
          const headCap3 = new THREE.Mesh(headCap3Geo, new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.75,
            roughness: 0.2
          }))
          headCap3.position.set(0, roller3BaseHeight + frame3Height + post3Height - 0.05, scanner3ZPos)
          rollerConveyor3Group.add(headCap3)

          // 扫描镜头外环
          const lensRing3Geo = new THREE.CylinderGeometry(0.06, 0.06, 0.04, 32)
          const lensRing3 = new THREE.Mesh(lensRing3Geo, new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.95,
            roughness: 0.15
          }))
          lensRing3.position.set(0, roller3BaseHeight + frame3Height + post3Height - 0.29, scanner3ZPos)
          lensRing3.rotation.x = Math.PI / 2
          rollerConveyor3Group.add(lensRing3)

          // 扫描镜头
          const lens3Geo = new THREE.CircleGeometry(0.055, 32)
          const lens3Material = new THREE.MeshStandardMaterial({
            color: 0xffffff,
            metalness: 0.9,
            roughness: 0.1,
            emissive: 0xffffff,
            emissiveIntensity: 0.3
          })
          const lens3 = new THREE.Mesh(lens3Geo, lens3Material)
          lens3.position.set(0, roller3BaseHeight + frame3Height + post3Height - 0.291, scanner3ZPos)
          lens3.rotation.x = Math.PI / 2
          rollerConveyor3Group.add(lens3)
        }

        // 激光扫描线
        const laserLine3Geo = new THREE.PlaneGeometry(conveyor3RollerWidth + 0.2, 0.002)
        const laserLine3Material = new THREE.MeshStandardMaterial({
          color: 0xffffff,
          emissive: 0xffffff,
          emissiveIntensity: 0.9,
          transparent: true,
          opacity: 0.7,
          side: THREE.DoubleSide
        })
        const laserLine3 = new THREE.Mesh(laserLine3Geo, laserLine3Material)
        laserLine3.position.set(0, roller3BaseHeight + frame3Height + 0.15, 0)
        laserLine3.rotation.x = Math.PI / 2
        rollerConveyor3Group.add(laserLine3)

        // 设置第三条滚筒输送机的世界坐标和旋转
        rollerConveyor3Group.position.set(rollerConveyor3PositionX, 0, rollerConveyor3PositionZ)
        rollerConveyor3Group.rotation.y = -Math.PI * 5 / 2  // 保持相同的旋转角度
        area.add(rollerConveyor3Group)

        // ========== 在第三条滚筒传送带右侧添加第四条滚筒传送带 ==========
        const rollerConveyor4Group = new THREE.Group()

        // 第四条滚筒传送带尺寸
        const conveyor4RollerWidth = 1.5  // 输送机宽度（X方向）
        const conveyor4RollerLength = 2.5  // 输送机长度（Z方向）

        // 计算第四条滚筒传送带位置（在第三条右侧）
        const spacing4 = 0.3  // 两条传送带之间的间距
        const rollerConveyor4PositionX = rollerConveyor3PositionX + conveyor3RollerWidth + spacing4
        const rollerConveyor4PositionZ = rollerConveyor3PositionZ

        // 1. 底座平台（深灰色）
        const roller4BaseMaterial = new THREE.MeshStandardMaterial({
          color: 0x404040,
          metalness: 0.7,
          roughness: 0.4
        })

        const roller4BaseHeight = 0.12
        const roller4BaseGeo = new THREE.BoxGeometry(conveyor4RollerWidth, roller4BaseHeight, conveyor4RollerLength)
        const roller4Base = new THREE.Mesh(roller4BaseGeo, roller4BaseMaterial)
        roller4Base.position.set(0, roller4BaseHeight / 2, 0)
        roller4Base.castShadow = true
        rollerConveyor4Group.add(roller4Base)

        // 2. 蓝色支撑框架（两侧纵向主梁）
        const blue4FrameMaterial = new THREE.MeshStandardMaterial({
          color: 0x2e5c8a,
          metalness: 0.7,
          roughness: 0.3
        })

        const frame4Height = 0.25
        const frame4Width = 0.08
        const frame4Depth = conveyor4RollerLength

        // 左侧纵向主梁
        const left4FrameGeo = new THREE.BoxGeometry(frame4Width, frame4Height, frame4Depth)
        const left4Frame = new THREE.Mesh(left4FrameGeo, blue4FrameMaterial)
        left4Frame.position.set(-conveyor4RollerWidth / 2 + frame4Width / 2, roller4BaseHeight + frame4Height / 2, 0)
        left4Frame.castShadow = true
        rollerConveyor4Group.add(left4Frame)

        // 右侧纵向主梁
        const right4Frame = new THREE.Mesh(left4FrameGeo, blue4FrameMaterial)
        right4Frame.position.set(conveyor4RollerWidth / 2 - frame4Width / 2, roller4BaseHeight + frame4Height / 2, 0)
        right4Frame.castShadow = true
        rollerConveyor4Group.add(right4Frame)

        // 3. 横向支撑梁（蓝色）
        const crossBeam4Count = 5
        const crossBeam4Geo = new THREE.BoxGeometry(conveyor4RollerWidth - frame4Width * 2, 0.06, 0.08)
        for (let i = 0; i < crossBeam4Count; i++) {
          const crossBeam = new THREE.Mesh(crossBeam4Geo, blue4FrameMaterial)
          const zPos = -conveyor4RollerLength / 2 + (conveyor4RollerLength / (crossBeam4Count - 1)) * i
          crossBeam.position.set(0, roller4BaseHeight + 0.03, zPos)
          crossBeam.castShadow = true
          rollerConveyor4Group.add(crossBeam)
        }

        // 4. 滚筒（白色/浅灰色，排列整齐）
        const roller4Material = new THREE.MeshStandardMaterial({
          color: 0xe8e8e8,
          metalness: 0.6,
          roughness: 0.3
        })

        const roller4Radius = 0.04
        const roller4Length = conveyor4RollerWidth - frame4Width * 2 - 0.05
        const roller4Geo = new THREE.CylinderGeometry(roller4Radius, roller4Radius, roller4Length, 20)
        const roller4Count = 25
        const roller4Spacing = conveyor4RollerLength / (roller4Count + 1)

        for (let i = 0; i < roller4Count; i++) {
          const roller = new THREE.Mesh(roller4Geo, roller4Material)
          roller.rotation.z = Math.PI / 2  // 旋转90度，使滚筒横向
          const zPos = -conveyor4RollerLength / 2 + roller4Spacing * (i + 1)
          roller.position.set(0, roller4BaseHeight + frame4Height, zPos)
          roller.castShadow = true
          rollerConveyor4Group.add(roller)

          // 滚筒轴承座（两端）
          const bearing4Material = new THREE.MeshStandardMaterial({
            color: 0x505050,
            metalness: 0.8,
            roughness: 0.3
          })
          const bearing4Geo = new THREE.BoxGeometry(0.05, 0.05, 0.03)

          // 左侧轴承
          const leftBearing = new THREE.Mesh(bearing4Geo, bearing4Material)
          leftBearing.position.set(-roller4Length / 2 - 0.025, roller4BaseHeight + frame4Height, zPos)
          leftBearing.castShadow = true
          rollerConveyor4Group.add(leftBearing)

          // 右侧轴承
          const rightBearing = new THREE.Mesh(bearing4Geo, bearing4Material)
          rightBearing.position.set(roller4Length / 2 + 0.025, roller4BaseHeight + frame4Height, zPos)
          rightBearing.castShadow = true
          rollerConveyor4Group.add(rightBearing)
        }

        // 5. 驱动电机（末端）
        const motor4Material = new THREE.MeshStandardMaterial({
          color: 0xffffff,  // 改为白色
          metalness: 0.6,
          roughness: 0.4
        })

        const motorBody4Geo = new THREE.CylinderGeometry(0.12, 0.12, 0.25, 16)
        const motorBody4 = new THREE.Mesh(motorBody4Geo, motor4Material)
        motorBody4.rotation.z = Math.PI / 2
        motorBody4.position.set(conveyor4RollerWidth / 2 + 0.2, roller4BaseHeight + frame4Height, conveyor4RollerLength / 2 - 0.3)
        motorBody4.castShadow = true
        rollerConveyor4Group.add(motorBody4)

        // 电机法兰
        const motorFlange4Geo = new THREE.CylinderGeometry(0.15, 0.15, 0.03, 16)
        const motorFlange4 = new THREE.Mesh(motorFlange4Geo, new THREE.MeshStandardMaterial({
          color: 0x2c3e50,
          metalness: 0.7,
          roughness: 0.3
        }))
        motorFlange4.rotation.z = Math.PI / 2
        motorFlange4.position.set(conveyor4RollerWidth / 2 + 0.075, roller4BaseHeight + frame4Height, conveyor4RollerLength / 2 - 0.3)
        rollerConveyor4Group.add(motorFlange4)

        // 6. 控制箱
        const controlBox4Geo = new THREE.BoxGeometry(0.3, 0.4, 0.2)
        const controlBox4 = new THREE.Mesh(controlBox4Geo, new THREE.MeshStandardMaterial({
          color: 0x34495e,
          metalness: 0.5,
          roughness: 0.5
        }))
        controlBox4.position.set(-conveyor4RollerWidth / 2 - 0.2, roller4BaseHeight + 0.2, -conveyor4RollerLength / 2 + 0.5)
        controlBox4.castShadow = true
        rollerConveyor4Group.add(controlBox4)

        // 7. 黄色安全护栏（两侧）
        const yellowRailing4Material = new THREE.MeshStandardMaterial({
          color: 0xffd700,  // 金黄色
          metalness: 0.5,
          roughness: 0.4
        })

        const railing4Height = 0.5
        const railing4PostCount = 6

        // 护栏立柱（两侧）
        const railing4PostGeo = new THREE.CylinderGeometry(0.025, 0.025, railing4Height, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyor4RollerWidth / 2 - 0.1 : conveyor4RollerWidth / 2 + 0.1

          for (let i = 0; i < railing4PostCount; i++) {
            const post = new THREE.Mesh(railing4PostGeo, yellowRailing4Material)
            const zPos = -conveyor4RollerLength / 2 + (conveyor4RollerLength / (railing4PostCount - 1)) * i
            post.position.set(xPos, roller4BaseHeight + frame4Height + railing4Height / 2, zPos)
            post.castShadow = true
            rollerConveyor4Group.add(post)
          }
        }

        // 护栏横杆（上下两层，两侧）
        const railing4BarGeo = new THREE.CylinderGeometry(0.02, 0.02, conveyor4RollerLength, 12)
        for (let side = 0; side < 2; side++) {
          const xPos = side === 0 ? -conveyor4RollerWidth / 2 - 0.1 : conveyor4RollerWidth / 2 + 0.1

          // 上层横杆
          const topBar = new THREE.Mesh(railing4BarGeo, yellowRailing4Material)
          topBar.rotation.x = Math.PI / 2
          topBar.position.set(xPos, roller4BaseHeight + frame4Height + railing4Height - 0.1, 0)
          topBar.castShadow = true
          rollerConveyor4Group.add(topBar)

          // 下层横杆
          const midBar = new THREE.Mesh(railing4BarGeo, yellowRailing4Material)
          midBar.rotation.x = Math.PI / 2
          midBar.position.set(xPos, roller4BaseHeight + frame4Height + railing4Height / 2, 0)
          midBar.castShadow = true
          rollerConveyor4Group.add(midBar)
        }

        // 设置第四条滚筒输送机的世界坐标和旋转
        rollerConveyor4Group.position.set(rollerConveyor4PositionX, 0, rollerConveyor4PositionZ)
        rollerConveyor4Group.rotation.y = -Math.PI * 5 / 2  // 保持相同的旋转角度
        area.add(rollerConveyor4Group)

        // ========== 在第四条滚筒传送带右侧添加履带传送带 ==========
        // 使用createRealisticRollerConveyor创建带式传送带（与斜向传送带相同类型）
        const beltConveyorLength = 12.0  // 传送带长度12.0米（增加3米）
        const beltConveyorWidth = 0.8   // 传送带宽度0.8米
        const beltConveyor = createRealisticRollerConveyor(beltConveyorLength, beltConveyorWidth)

        // 计算履带传送带位置（在第四条滚筒传送带右侧，向右延长）
        const spacingBelt = 0.3  // 传送带之间的间距
        // 向右延长，调整中心位置向右移动
        const beltConveyorPositionX = rollerConveyor4PositionX + conveyor4RollerWidth + spacingBelt + 5.35  // 向右延长，中心位置右移（增加3米，中心右移1.5米）
        const beltConveyorPositionZ = rollerConveyor4PositionZ

        // 设置履带传送带的世界坐标和旋转
        beltConveyor.position.set(beltConveyorPositionX, 0, beltConveyorPositionZ)
        beltConveyor.rotation.y = -Math.PI * 5 / 2  // 保持相同的旋转角度
        area.add(beltConveyor)

        // ========== 在第四个滚筒传送带右侧横向传送带下方添加3个斜向传送带 ==========
        const diagonal4ConveyorWidth = 0.8  // 斜向传送带宽度
        const diagonal4ConveyorLength = 4.0  // 斜向传送带长度
        const diagonal4ConveyorSpacing = 5.0  // 斜向传送带之间的间距5米

        // 存储每个连接传送带的位置信息
        const group2BottomConnectors: Array<{ x: number; z: number }> = []

        for (let i = 0; i < 3; i++) {
          const diagonal4Conveyor = createRealisticRollerConveyor(diagonal4ConveyorLength, diagonal4ConveyorWidth, {
            shortenLeftFrameEnd: -0.1  // 延长左侧框架0.1米（负值表示延长）
          })

          // 计算斜向传送带的位置（与横向传送带相连，从横向传送带起点沿X轴分布）
          // 起点位置：横向传送带左端，向右移动
          const startX4 = beltConveyorPositionX - beltConveyorLength / 2 + 1.0 + 1.5  // 向左移动4.5米
          const diagonal4ConveyorPositionX = startX4 + i * diagonal4ConveyorSpacing
          // Z位置：增加与横向传送带的间隔
          const diagonal4ConveyorPositionZ = beltConveyorPositionZ + diagonal4ConveyorLength / 2 * Math.cos(Math.PI / 4) + 0.2  // 间隔距离0.2米

          diagonal4Conveyor.position.set(diagonal4ConveyorPositionX, 0, diagonal4ConveyorPositionZ)
          diagonal4Conveyor.rotation.y = Math.PI / 4  // 向右倾斜45度
          area.add(diagonal4Conveyor)

          // 计算斜向传送带的终点位置
          const diagonal4EndX = diagonal4ConveyorPositionX + (diagonal4ConveyorLength / 2) * Math.cos(Math.PI / 4)
          const diagonal4EndZ = diagonal4ConveyorPositionZ + (diagonal4ConveyorLength / 2) * Math.sin(Math.PI / 4)

          // 直接在斜向传送带终点添加横向传送带
          const shortHorizontal4Length = 1.8  // 横向传送带长度1.8米
          const shortHorizontal4Width = 0.8
          const shortHorizontal4Conveyor = createRealisticRollerConveyor(shortHorizontal4Length, shortHorizontal4Width)

          // 横向传送带位置：从斜向传送带终点开始，向左延伸
          // 重叠距离
          const overlapDistance4 = 0.25
          shortHorizontal4Conveyor.position.set(
            diagonal4EndX - overlapDistance4 + shortHorizontal4Length / 2,
            0,
            diagonal4EndZ
          )
          shortHorizontal4Conveyor.rotation.y = -Math.PI / 2  // 横向（向左）
          area.add(shortHorizontal4Conveyor)

          // 在前两个横向传送带右侧添加竖着的传送带
          if (i < 2) {
            const vertical4ConveyorLength = 6.0  // 竖着传送带长度6米
            const vertical4ConveyorWidth = 0.8
            const vertical4Conveyor = createRealisticRollerConveyor(vertical4ConveyorLength, vertical4ConveyorWidth)

            // 计算竖着传送带的位置（在横向传送带右端）
            const shortHorizontal4EndX = diagonal4EndX - overlapDistance4 + shortHorizontal4Length
            const vertical4ConveyorPositionX = shortHorizontal4EndX + 0.25  // 右侧，有0.25米重叠
            const vertical4ConveyorPositionZ = diagonal4EndZ + vertical4ConveyorLength / 2 - 0.4  // 向前延伸，向上移动0.4米

            vertical4Conveyor.position.set(vertical4ConveyorPositionX, 0, vertical4ConveyorPositionZ)
            vertical4Conveyor.rotation.y = 0  // 竖着（向前）
            area.add(vertical4Conveyor)

            // 在竖着传送带下方添加安检设备
            const security4Device = createSecurityCheckDevice()
            const vertical4ConveyorEndZ = vertical4ConveyorPositionZ + vertical4ConveyorLength / 2
            security4Device.position.set(
              vertical4ConveyorPositionX,
              0,
              vertical4ConveyorEndZ + 1.5  // 在传送带末端下方1.5米处
            )
            area.add(security4Device)

            // 在安检设备下方创建竖着的履带传送带
            const vertical4BeltLength = 5.0  // 竖着履带传送带长度5米
            const vertical4BeltWidth = 1.0
            const vertical4Belt = createBeltConveyor(vertical4BeltLength, vertical4BeltWidth)

            // 履带传送带位置：在安检设备下方，沿Z轴竖着
            // Y坐标抬高0.28，使履带表面与下方连接传送带的滚筒顶部保持相同高度
            vertical4Belt.position.set(
              vertical4ConveyorPositionX,
              0.28,  // 抬高与横向滚筒传送带保持相同高度
              vertical4ConveyorEndZ + 1.5 + 2.75 + vertical4BeltLength / 2  // 在安检设备末端下方
            )
            vertical4Belt.rotation.y = 0  // 不旋转，沿Z轴方向
            area.add(vertical4Belt)

            // 在白色履带传送带下方添加连接用横向传送带（与之前横向传送带样式一样）
            const connecting4ConveyorLength = 4.2  // 连接传送带长度4.2米（与第一组保持一致）
            const connecting4ConveyorWidth = 0.8
            const connecting4Conveyor = createRealisticRollerConveyor(connecting4ConveyorLength, connecting4ConveyorWidth)

            // 计算连接传送带位置（在白色履带传送带末端下方）
            const vertical4BeltEndZ = vertical4ConveyorEndZ + 1.5 + 2.75 + vertical4BeltLength
            const connecting4ConveyorPositionX = vertical4ConveyorPositionX
            const connecting4ConveyorPositionZ = vertical4BeltEndZ + connecting4ConveyorLength / 2

            connecting4Conveyor.position.set(connecting4ConveyorPositionX, 0, connecting4ConveyorPositionZ)
            connecting4Conveyor.rotation.y = 0  // 沿Z轴方向
            area.add(connecting4Conveyor)

            // 保存连接传送带的末端位置
            const connecting4ConveyorEndZ = connecting4ConveyorPositionZ + connecting4ConveyorLength / 2
            group2BottomConnectors.push({
              x: connecting4ConveyorPositionX,
              z: connecting4ConveyorEndZ
            })
          }
        }

        // ========== 在所有5个连接传送带末端添加统一的横向连接传送带 ==========
        if (group1BottomConnectors.length > 0 && group2BottomConnectors.length > 0) {
          // 合并两组连接传送带的位置
          const allBottomConnectors = [...group1BottomConnectors, ...group2BottomConnectors]

          // 计算所有连接传送带的X位置范围
          const allBottomXPositions = allBottomConnectors.map(c => c.x)
          const allBottomMinX = Math.min(...allBottomXPositions)
          const allBottomMaxX = Math.max(...allBottomXPositions)

          // 计算横向连接传送带参数
          const unifiedBottomConnectorLength = allBottomMaxX - allBottomMinX + 0.8 + 2.0  // 加上传送带宽度，向右侧延长2米
          const unifiedBottomConnectorWidth = 0.8
          const unifiedBottomConnectorCenterX = (allBottomMinX + allBottomMaxX) / 2 + 2.0 / 2  // 中心点向右移动1米

          // 所有连接传送带的Z位置应该相同，取第一个
          const unifiedBottomConnectorZ = allBottomConnectors[0].z

          // 创建横向连接传送带（连接所有5个灰色滚筒传送带）
          const unifiedBottomConnector = createRealisticRollerConveyor(unifiedBottomConnectorLength, unifiedBottomConnectorWidth)
          unifiedBottomConnector.position.set(unifiedBottomConnectorCenterX, 0, unifiedBottomConnectorZ)
          unifiedBottomConnector.rotation.y = Math.PI / 2  // 横向（沿X轴）
          area.add(unifiedBottomConnector)

          // 在横向连接传送带下方再连接一个平行的横向传送带（二字型，直接紧贴）
          const secondConnectorLength = unifiedBottomConnectorLength  // 第二个连接传送带长度与第一个相同
          const secondConnectorWidth = 0.8

          // 计算第二个连接传送带的位置（在第一个横向传送带下方，直接紧贴）
          const secondConnectorX = unifiedBottomConnectorCenterX
          const secondConnectorZ = unifiedBottomConnectorZ + unifiedBottomConnectorWidth  // 紧贴第一条传送带

          // 创建第二个连接传送带
          const secondConnector = createRealisticRollerConveyor(secondConnectorLength, secondConnectorWidth)
          secondConnector.position.set(secondConnectorX, 0, secondConnectorZ)
          secondConnector.rotation.y = Math.PI / 2  // 横向（沿X轴），与第一个平行
          area.add(secondConnector)

          // ========== 创建真正的S型曲线传送带 ==========
          const createSShapeConveyor = (startX: number, startZ: number, width: number, totalLength: number) => {
            const sGroup = new THREE.Group()

            // 传送带抬高高度（与直线传送带一致）
            const elevationHeight = 0.35

            // 定义Z字型路径：直线段+弯曲转角（按照图片红色标记）
            const sideShift = 1.5  // Z字型的纵向偏移量
            const turnRadius = 0.6  // 转弯半径
            const firstSegmentLength = 2.5  // 第一段长度（继续向右延长）
            const secondSegmentLength = 6.5  // 第二段长度（延长）
            const thirdSegmentLength = 2.0  // 第三段长度（延长0.5）

            // 创建组合曲线路径（直线+弯曲转角）
            const curves = []

            // 第一段：水平向右的直线
            const line1Start = new THREE.Vector3(startX, 0, startZ)
            const line1End = new THREE.Vector3(startX + firstSegmentLength, 0, startZ)
            curves.push(new THREE.LineCurve3(line1Start, line1End))

            // 第一个转弯：向上转（使用二次贝塞尔曲线）
            const turn1Start = line1End
            const turn1End = new THREE.Vector3(startX + firstSegmentLength + turnRadius, 0, startZ - turnRadius)
            const turn1Control = new THREE.Vector3(startX + firstSegmentLength + turnRadius, 0, startZ)
            curves.push(new THREE.QuadraticBezierCurve3(turn1Start, turn1Control, turn1End))

            // 第二段：向上的直线
            const line2Start = turn1End
            const line2End = new THREE.Vector3(startX + firstSegmentLength + turnRadius, 0, startZ - turnRadius - secondSegmentLength)
            curves.push(new THREE.LineCurve3(line2Start, line2End))

            // 第二个转弯：向右转
            const turn2Start = line2End
            const turn2End = new THREE.Vector3(startX + firstSegmentLength + turnRadius * 2, 0, startZ - turnRadius - secondSegmentLength - turnRadius)
            const turn2Control = new THREE.Vector3(startX + firstSegmentLength + turnRadius, 0, startZ - turnRadius - secondSegmentLength - turnRadius)
            curves.push(new THREE.QuadraticBezierCurve3(turn2Start, turn2Control, turn2End))

            // 第三段：水平向右的直线
            const line3Start = turn2End
            const line3End = new THREE.Vector3(startX + firstSegmentLength + turnRadius + turnRadius + thirdSegmentLength, 0, startZ - turnRadius - secondSegmentLength - turnRadius)
            curves.push(new THREE.LineCurve3(line3Start, line3End))

            // 组合所有曲线段
            const curve = new THREE.CurvePath()
            curves.forEach(c => curve.add(c))

            // 创建传送带主体（平坦的表面，使用多个板条组成）
            const beltMaterial = new THREE.MeshStandardMaterial({
              color: 0x555555,  // 改为深灰色履带（S型传送带）
              metalness: 0,
              roughness: 0.9,
              side: THREE.DoubleSide
            })

            // 沿曲线创建平坦的传送带表面
            const numSegments = 100
            for (let i = 0; i < numSegments; i++) {
              const t1 = i / numSegments
              const t2 = (i + 1) / numSegments

              const p1 = curve.getPointAt(t1)
              const p2 = curve.getPointAt(t2)
              const tangent1 = curve.getTangentAt(t1)
              const tangent2 = curve.getTangentAt(t2)

              // 计算垂直于切线的法线方向（在XZ平面上）
              const normal1 = new THREE.Vector3(-tangent1.z, 0, tangent1.x).normalize()
              const normal2 = new THREE.Vector3(-tangent2.z, 0, tangent2.x).normalize()

              // 创建一个矩形板条
              const halfWidth = width / 2
              const vertices = new Float32Array([
                // 左侧两个顶点
                p1.x - normal1.x * halfWidth, elevationHeight + 0.02, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + 0.02, p2.z - normal2.z * halfWidth,
                // 右侧两个顶点
                p1.x + normal1.x * halfWidth, elevationHeight + 0.02, p1.z + normal1.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + 0.02, p2.z + normal2.z * halfWidth,
              ])

              const indices = [
                0, 1, 2,
                2, 1, 3
              ]

              const geometry = new THREE.BufferGeometry()
              geometry.setAttribute('position', new THREE.BufferAttribute(vertices, 3))
              geometry.setIndex(indices)
              geometry.computeVertexNormals()

              const mesh = new THREE.Mesh(geometry, beltMaterial)
              mesh.castShadow = true
              mesh.receiveShadow = true
              sGroup.add(mesh)
            }

            // 添加滚筒（横跨传送带宽度，连接两侧边框）
            const numRollers = 30
            for (let i = 0; i <= numRollers; i++) {
              const t = i / numRollers
              const point = curve.getPointAt(t)
              const tangent = curve.getTangentAt(t)

              // 计算垂直于切线的法线方向（在水平面上）
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              // 计算滚筒两端的位置（连接两侧边框）
              const halfWidth = width / 2
              const leftEnd = new THREE.Vector3(
                point.x - normal.x * halfWidth,
                0,
                point.z - normal.z * halfWidth
              )
              const rightEnd = new THREE.Vector3(
                point.x + normal.x * halfWidth,
                0,
                point.z + normal.z * halfWidth
              )

              // 滚筒的中心位置
              const center = new THREE.Vector3().lerpVectors(leftEnd, rightEnd, 0.5)

              // 计算滚筒的方向向量
              const direction = new THREE.Vector3().subVectors(rightEnd, leftEnd).normalize()

              // 创建滚筒
              const roller = new THREE.Mesh(
                new THREE.CylinderGeometry(0.04, 0.04, width, 12),
                new THREE.MeshStandardMaterial({
                  color: 0x333333,  // 改为浅黑色滚筒（S型传送带）
                  metalness: 0,
                  roughness: 0.95
                })
              )

              // 设置滚筒位置
              roller.position.copy(center)
              roller.position.y = elevationHeight

              // 使用四元数设置滚筒方向，使其沿着两端点方向
              const up = new THREE.Vector3(0, 1, 0)
              const quaternion = new THREE.Quaternion()
              quaternion.setFromUnitVectors(up, direction)
              roller.quaternion.copy(quaternion)

              sGroup.add(roller)
            }

            // 添加侧边框架
            const frameMaterial = new THREE.MeshStandardMaterial({
              color: 0xc9b583,  // 金黄色边框（与直线传送带一致）
              metalness: 0.7,
              roughness: 0.3
            })

            const numPoints = 100  // 边框曲线采样点数
            for (let side = -1; side <= 1; side += 2) {
              const framePoints = []
              for (let i = 0; i <= numPoints; i++) {
                const t = i / numPoints
                const point = curve.getPointAt(t)
                const tangent = curve.getTangentAt(t)
                const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()
                const offset = normal.multiplyScalar(side * width * 0.5)
                framePoints.push(point.clone().add(offset))
              }

              const frameCurve = new THREE.CatmullRomCurve3(framePoints)
              const frameGeometry = new THREE.TubeGeometry(frameCurve, 100, 0.03, 8, false)
              const frameMesh = new THREE.Mesh(frameGeometry, frameMaterial)
              frameMesh.position.y = elevationHeight + 0.1
              sGroup.add(frameMesh)
            }

            // 添加圆形支撑腿 - 沿曲线路径均匀分布
            const legMaterial = new THREE.MeshStandardMaterial({
              color: 0xa0a0a0,  // 灰色金属
              metalness: 0.6,
              roughness: 0.4
            })

            const legHeight = 0.35  // 支撑腿高度（与直线传送带一致）
            const legDiameter = 0.04
            const legSpacing = 0.8  // 每0.8米一对腿
            const curveLength = curve.getLength()
            const numLegPairs = Math.max(2, Math.ceil(curveLength / legSpacing))

            // 沿曲线路径创建支腿
            for (let i = 0; i < numLegPairs; i++) {
              const t = i / (numLegPairs - 1)
              const point = curve.getPointAt(t)
              const tangent = curve.getTangentAt(t)
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              // 左右两侧各一个支腿
              for (let side = -1; side <= 1; side += 2) {
                const legOffset = normal.clone().multiplyScalar(side * (width * 0.4))
                const legPosition = point.clone().add(legOffset)

                // 主支撑腿
                const legGeo = new THREE.CylinderGeometry(legDiameter, legDiameter, legHeight, 8)
                const leg = new THREE.Mesh(legGeo, legMaterial)
                leg.position.set(legPosition.x, legHeight / 2, legPosition.z)
                leg.castShadow = true
                sGroup.add(leg)

                // 底部调节脚
                const footGeo = new THREE.CylinderGeometry(legDiameter * 1.3, legDiameter, 0.02, 8)
                const foot = new THREE.Mesh(footGeo, legMaterial)
                foot.position.set(legPosition.x, 0.01, legPosition.z)
                sGroup.add(foot)
              }
            }

            return sGroup
          }

          // 第一个S型的起点（第一条横向传送带的右侧末端）
          const sStartX = unifiedBottomConnectorCenterX + unifiedBottomConnectorLength / 2
          const sStartZ = unifiedBottomConnectorZ

          // 创建第一个S型传送带（宽度与直线传送带一致）
          const sCurveConveyor = createSShapeConveyor(sStartX, sStartZ, 0.8, 6)
          area.add(sCurveConveyor)

          // 在S型传送带转弯处下方添加白色架子
          const createShelfUnderCurve = (x: number, z: number) => {
            const shelfGroup = new THREE.Group()

            const shelfMaterial = new THREE.MeshStandardMaterial({
              color: 0xffffff,  // 白色
              metalness: 0.2,
              roughness: 0.7
            })

            // 架子参数（单层，横跨传送带）
            const shelfWidth = 2.5  // 增加宽度1米
            const shelfDepth = 1.0  // 减少深度
            const shelfHeight = 0.35  // 单层架子高度
            const shelfThickness = 0.03  // 层板厚度

            // 创建支撑立柱（4根）
            const postRadius = 0.025
            const postHeight = shelfHeight
            const postGeo = new THREE.CylinderGeometry(postRadius, postRadius, postHeight, 8)

            const postOffsets = [
              [-shelfWidth/2 + 0.05, -shelfDepth/2 + 0.05],
              [shelfWidth/2 - 0.05, -shelfDepth/2 + 0.05],
              [-shelfWidth/2 + 0.05, shelfDepth/2 - 0.05],
              [shelfWidth/2 - 0.05, shelfDepth/2 - 0.05]
            ]

            postOffsets.forEach(([px, pz]) => {
              const post = new THREE.Mesh(postGeo, shelfMaterial)
              post.position.set(px, postHeight/2, pz)
              post.castShadow = true
              shelfGroup.add(post)
            })

            // 创建带镂空图案的层板
            // 使用多个小块拼接成带镂空图案的层板
            const barWidth = 0.08  // 条纹宽度
            const gapWidth = 0.12  // 镂空间隙宽度
            const numBars = Math.floor(shelfWidth / (barWidth + gapWidth))

            // 创建横向条纹（带镂空间隙）
            for (let i = 0; i < numBars; i++) {
              const barX = -shelfWidth/2 + (i + 0.5) * (barWidth + gapWidth)
              const barGeo = new THREE.BoxGeometry(barWidth, shelfThickness, shelfDepth)
              const bar = new THREE.Mesh(barGeo, shelfMaterial)
              bar.position.set(barX, shelfHeight, 0)
              bar.castShadow = true
              bar.receiveShadow = true
              shelfGroup.add(bar)
            }

            // 添加边框加强结构
            const edgeThickness = 0.06

            // 前后边框
            const frontEdgeGeo = new THREE.BoxGeometry(shelfWidth, shelfThickness, edgeThickness)
            const frontEdge = new THREE.Mesh(frontEdgeGeo, shelfMaterial)
            frontEdge.position.set(0, shelfHeight, -shelfDepth/2 + edgeThickness/2)
            shelfGroup.add(frontEdge)

            const backEdge = new THREE.Mesh(frontEdgeGeo, shelfMaterial)
            backEdge.position.set(0, shelfHeight, shelfDepth/2 - edgeThickness/2)
            shelfGroup.add(backEdge)

            shelfGroup.position.set(x, 0, z)
            return shelfGroup
          }

          // 计算S型传送带第三段的位置（根据标记图片）
          // 根据createSShapeConveyor函数中的参数计算
          // firstSegmentLength = 2.5, turnRadius = 0.6, secondSegmentLength = 6.5, thirdSegmentLength = 2.0
          // 第三段是水平向右的直线段
          const thirdSegmentStartX = sStartX + 2.5 + 0.6 + 0.6  // 第一段 + 两个转弯半径
          const thirdSegmentZ = sStartZ - 0.6 - 6.5 - 0.6  // 第一个转弯 + 第二段 + 第二个转弯

          // 架子放在第三段的中间位置，竖着放置（垂直于传送带方向）
          const shelfX = thirdSegmentStartX + 1.0  // 第三段中间位置
          const shelfZ = thirdSegmentZ

          const shelfUnderCurve = createShelfUnderCurve(shelfX, shelfZ)
          // 旋转90度，使架子竖着显示（垂直于传送带方向）
          shelfUnderCurve.rotation.y = Math.PI / 2  // 90度
          area.add(shelfUnderCurve)

          // ========== 在S型传送带右侧末端添加重量检测机器 ==========
          // S型传送带第三段的末端位置
          const sEndX = sStartX + 2.5 + 0.6 + 0.6 + 2.0  // 第一段 + 两个转弯 + 第三段
          const sEndZ = thirdSegmentZ  // 与第三段Z坐标相同

          // 1. 进料传送带（S型末端到称重机之间）
          const inputConveyor = createRealisticRollerConveyor(0.6, 0.8)
          inputConveyor.position.set(
            sEndX + 0.3,  // S型末端后0.3米作为中心
            0,
            sEndZ
          )
          area.add(inputConveyor)

          // 2. 创建重量检测机器（使用增强版createDetailedCheckweigher函数）
          const weightDetector = createDetailedCheckweigher()
          weightDetector.position.set(
            sEndX + 1.3,  // 在进料传送带后面（称重机长约1.4米，所以中心在1.3）
            0,
            sEndZ
          )
          // 不需要旋转，称重机默认方向就是物料向右（X正方向）移动
          area.add(weightDetector)

          // ========== 在称重机右侧添加两个C字型传送带 ==========
          // 称重机右侧末端位置（称重机长1.8米）
          const checkweigherEndX = sEndX + 1.3 + 0.9

          // 创建C字型传送带函数（向右→90度弯曲→向下/向上）
          const createCShapeConveyor = (startX: number, startZ: number, width: number, isUpward: boolean = false) => {
            const group = new THREE.Group()
            const elevationHeight = 0.35

            // C字型路径参数
            const segmentLength = 0.8         // 第一段和第二段长度一致（减小）
            const arcRadius = 1.2             // 转弯半径（增大）
            const bendAngle = 90 * Math.PI / 180  // 90度弯曲
            const zDirection = isUpward ? -1 : 1  // 向上=-1，向下=+1

            const curves = []

            // 第一段：水平向右
            const line1Start = new THREE.Vector3(startX, 0, startZ)
            const line1End = new THREE.Vector3(startX + segmentLength, 0, startZ)
            curves.push(new THREE.LineCurve3(line1Start, line1End))

            // 90度弯曲：从水平向右平滑转到垂直向下/向上
            const arcCenterX = line1End.x
            const arcCenterZ = line1End.z + arcRadius * zDirection  // 圆心在下方或上方

            const arcPoints = []
            const arcSteps = 20
            for (let i = 0; i <= arcSteps; i++) {
              const t = i / arcSteps
              let angle
              if (isUpward) {
                // 向上：圆心在上方(-Z)，从90度扫到0度（顺时针递减）
                // 90度：第一段末端(0, 0, arcRadius)，切线+X
                // 0度：弯曲终点(arcRadius, 0, 0)，切线-Z
                angle = Math.PI / 2 - t * bendAngle
              } else {
                // 向下：圆心在下方(+Z)，从-90度扫到0度（逆时针递增）
                // -90度：第一段末端(0, 0, -arcRadius)，切线+X
                // 0度：弯曲终点(arcRadius, 0, 0)，切线+Z
                angle = -Math.PI / 2 + t * bendAngle
              }
              const px = arcCenterX + arcRadius * Math.cos(angle)
              const pz = arcCenterZ + arcRadius * Math.sin(angle)
              arcPoints.push(new THREE.Vector3(px, 0, pz))
            }
            const arcCurve = new THREE.CatmullRomCurve3(arcPoints)
            curves.push(arcCurve)

            // 第二段：沿90度方向垂直向下/向上延伸
            const line2Start = arcPoints[arcPoints.length - 1]
            const direction = isUpward ? -bendAngle : bendAngle  // 向上=-90度，向下=+90度
            const line2End = new THREE.Vector3(
              line2Start.x + segmentLength * Math.cos(direction),
              0,
              line2Start.z + segmentLength * Math.sin(direction)
            )
            curves.push(new THREE.LineCurve3(line2Start, line2End))

            // 组合路径
            const pathCurve = new THREE.CurvePath()
            curves.forEach(c => pathCurve.add(c))

            // 创建履带表面
            const beltMaterial = new THREE.MeshStandardMaterial({
              color: 0x555555,  // 改为深灰色（C字型传送带）
              metalness: 0,
              roughness: 0.95,
              side: THREE.DoubleSide
            })

            const numSegments = 80
            for (let i = 0; i < numSegments; i++) {
              const t1 = i / numSegments
              const t2 = (i + 1) / numSegments

              const p1 = pathCurve.getPointAt(t1)
              const p2 = pathCurve.getPointAt(t2)
              const tangent1 = pathCurve.getTangentAt(t1)
              const tangent2 = pathCurve.getTangentAt(t2)

              const normal1 = new THREE.Vector3(-tangent1.z, 0, tangent1.x).normalize()
              const normal2 = new THREE.Vector3(-tangent2.z, 0, tangent2.x).normalize()

              const halfWidth = width / 2
              const vertices = new Float32Array([
                p1.x - normal1.x * halfWidth, elevationHeight + 0.02, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + 0.02, p2.z - normal2.z * halfWidth,
                p1.x + normal1.x * halfWidth, elevationHeight + 0.02, p1.z + normal1.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + 0.02, p2.z + normal2.z * halfWidth,
              ])

              const geometry = new THREE.BufferGeometry()
              geometry.setAttribute('position', new THREE.BufferAttribute(vertices, 3))
              geometry.setIndex([0, 1, 2, 2, 1, 3])
              geometry.computeVertexNormals()

              const mesh = new THREE.Mesh(geometry, beltMaterial)
              mesh.castShadow = true
              mesh.receiveShadow = true
              group.add(mesh)
            }

            // 添加滚筒
            const numRollers = 25
            for (let i = 0; i <= numRollers; i++) {
              const t = i / numRollers
              const point = pathCurve.getPointAt(t)
              const tangent = pathCurve.getTangentAt(t)
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              const halfWidth = width / 2
              const leftEnd = new THREE.Vector3(point.x - normal.x * halfWidth, 0, point.z - normal.z * halfWidth)
              const rightEnd = new THREE.Vector3(point.x + normal.x * halfWidth, 0, point.z + normal.z * halfWidth)
              const center = new THREE.Vector3().lerpVectors(leftEnd, rightEnd, 0.5)
              const direction = new THREE.Vector3().subVectors(rightEnd, leftEnd).normalize()

              const roller = new THREE.Mesh(
                new THREE.CylinderGeometry(0.04, 0.04, width, 12),
                new THREE.MeshStandardMaterial({ color: 0x333333, metalness: 0, roughness: 0.95 }) // 改为浅黑色（C字型和Z字型）
              )
              roller.position.copy(center)
              roller.position.y = elevationHeight
              const up = new THREE.Vector3(0, 1, 0)
              const quaternion = new THREE.Quaternion()
              quaternion.setFromUnitVectors(up, direction)
              roller.quaternion.copy(quaternion)
              group.add(roller)
            }

            // 添加侧边框架
            const frameMaterial = new THREE.MeshStandardMaterial({
              color: 0xc9b583,
              metalness: 0.7,
              roughness: 0.3,
              side: THREE.DoubleSide
            })

            const frameHeight = 0.12
            const frameWidth = 0.03
            const numFrameSegments = 80

            for (let i = 0; i < numFrameSegments; i++) {
              const t1 = i / numFrameSegments
              const t2 = (i + 1) / numFrameSegments

              const p1 = pathCurve.getPointAt(t1)
              const p2 = pathCurve.getPointAt(t2)
              const tangent1 = pathCurve.getTangentAt(t1)
              const tangent2 = pathCurve.getTangentAt(t2)

              const normal1 = new THREE.Vector3(-tangent1.z, 0, tangent1.x).normalize()
              const normal2 = new THREE.Vector3(-tangent2.z, 0, tangent2.x).normalize()

              const halfWidth = width / 2

              // 左侧框架
              const leftVertices = new Float32Array([
                p1.x - normal1.x * halfWidth, elevationHeight, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight, p2.z - normal2.z * halfWidth,
                p1.x - normal1.x * halfWidth, elevationHeight + frameHeight, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + frameHeight, p2.z - normal2.z * halfWidth,
              ])

              const leftGeom = new THREE.BufferGeometry()
              leftGeom.setAttribute('position', new THREE.BufferAttribute(leftVertices, 3))
              leftGeom.setIndex([0, 1, 2, 2, 1, 3])
              leftGeom.computeVertexNormals()
              const leftFrame = new THREE.Mesh(leftGeom, frameMaterial)
              leftFrame.castShadow = true
              leftFrame.receiveShadow = true
              group.add(leftFrame)

              // 右侧框架
              const rightVertices = new Float32Array([
                p1.x + normal1.x * halfWidth, elevationHeight, p1.z + normal1.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight, p2.z + normal2.z * halfWidth,
                p1.x + normal1.x * halfWidth, elevationHeight + frameHeight, p1.z + normal1.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + frameHeight, p2.z + normal2.z * halfWidth,
              ])

              const rightGeom = new THREE.BufferGeometry()
              rightGeom.setAttribute('position', new THREE.BufferAttribute(rightVertices, 3))
              rightGeom.setIndex([0, 1, 2, 2, 1, 3])
              rightGeom.computeVertexNormals()
              const rightFrame = new THREE.Mesh(rightGeom, frameMaterial)
              rightFrame.castShadow = true
              rightFrame.receiveShadow = true
              group.add(rightFrame)
            }

            // 添加支腿
            const legMaterial = new THREE.MeshStandardMaterial({
              color: 0x404040,
              metalness: 0.6,
              roughness: 0.4
            })

            const legRadius = 0.03
            const legHeight = elevationHeight
            const numLegs = 8  // 沿路径添加8个支腿

            for (let i = 0; i <= numLegs; i++) {
              const t = i / numLegs
              const point = pathCurve.getPointAt(t)

              const leg = new THREE.Mesh(
                new THREE.CylinderGeometry(legRadius, legRadius, legHeight, 8),
                legMaterial
              )
              leg.position.set(point.x, legHeight / 2, point.z)
              leg.castShadow = true
              leg.receiveShadow = true
              group.add(leg)
            }

            return group
          }

          // 添加第一个C字型传送带（上方，第二段向上）
          const cConveyor1 = createCShapeConveyor(checkweigherEndX, sEndZ - 0.4, 0.8, true)
          area.add(cConveyor1)

          // 添加第二个C字型传送带（下方，第二段向下，两条紧挨着）
          const cConveyor2 = createCShapeConveyor(checkweigherEndX, sEndZ + 0.4, 0.8, false)
          area.add(cConveyor2)

          // C字型传送带第二段末端连接横向传送带
          const cSegmentLength = 0.8
          const cArcRadius = 1.2
          // 第二段末端X坐标：起点 + 第一段 + 弧半径
          const cSecondSegmentEndX = checkweigherEndX + cSegmentLength + cArcRadius

          // 第一个C字型（向上）第二段末端的横向传送带（水平向右延伸）
          // Z坐标 = 起点Z - 起始偏移 - 弧半径 - 第二段长度，然后向上移动0.4米（-0.5+0.1）
          const cEndZ1 = sEndZ - 0.4 - cArcRadius - cSegmentLength - 0.4
          // 延长到8.0米，只缩短右侧框架0.8米
          const horizontalConveyor1 = createRealisticRollerConveyor(8.0, 0.8, {
            shortenRightFrameEnd: 0.8
          })
          horizontalConveyor1.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // 调整中心位置以保持左端不动：长度8.0米，中心位置 = 左端 + 4.0
          horizontalConveyor1.position.set(cSecondSegmentEndX + 3.6, 0, cEndZ1)
          area.add(horizontalConveyor1)

          // 第二个C字型（向下）第二段末端的横向传送带（水平向右延伸）
          // Z坐标 = 起点Z + 起始偏移 + 弧半径 + 第二段长度，然后向下移动0.4米（+0.5-0.1）
          const cEndZ2 = sEndZ + 0.4 + cArcRadius + cSegmentLength + 0.4
          // 向右延长0.1米，从8.0米延长到8.1米，缩短左侧框架0.8米以避免与C字型传送带末端框架重叠
          const horizontalConveyor2 = createRealisticRollerConveyor(8.1, 0.8, { shortenLeftFrameEnd: 0.8 })
          horizontalConveyor2.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // 调整中心位置以保持左端不动：长度8.1米，中心位置 = 左端 + 4.05
          horizontalConveyor2.position.set(cSecondSegmentEndX + 3.65, 0, cEndZ2)
          area.add(horizontalConveyor2)

          // 第二个S型的起点（第二条横向传送带的右侧末端）
          // 第二条传送带旋转了90度，沿X轴方向，所以右侧末端在X轴正方向
          const s2StartX = secondConnectorX + secondConnectorLength / 2
          const s2StartZ = secondConnectorZ

          // 创建第二个Z字型传送带（20度转弯）
          const create20DegreeZConveyor = (startX: number, startZ: number, width: number) => {
            const group = new THREE.Group()
            const elevationHeight = 0.35
            const angle20 = 20 * Math.PI / 180

            // Z字型参数
            const firstSegmentLength = 1.0  // 第一段水平长度
            const secondSegmentLength = 2.3  // 第二段斜向长度（继续缩短0.2）
            const thirdSegmentLength = 1.5  // 第三段水平长度
            const transitionLength = 1.2  // 过渡段长度（增加以获得更平滑的过渡）

            const curves = []

            // 第一段：水平向右
            const line1Start = new THREE.Vector3(startX, 0, startZ)
            const line1End = new THREE.Vector3(startX + firstSegmentLength, 0, startZ)
            curves.push(new THREE.LineCurve3(line1Start, line1End))

            // 第一个转弯：从水平转向20度
            const turn1Start = line1End
            const arcRadius = 1.5
            const arcSteps = 20

            // 圆心在起点上方（+Z方向）
            const arc1CenterX = turn1Start.x
            const arc1CenterZ = turn1Start.z + arcRadius

            const arcPoints1 = []
            for (let i = 0; i <= arcSteps; i++) {
              const t = i / arcSteps
              const currentAngle = t * angle20
              const px = arc1CenterX + arcRadius * Math.sin(currentAngle)
              const pz = arc1CenterZ - arcRadius * Math.cos(currentAngle)
              arcPoints1.push(new THREE.Vector3(px, 0, pz))
            }
            const arc1Curve = new THREE.CatmullRomCurve3(arcPoints1)
            const turn1End = arcPoints1[arcPoints1.length - 1]
            curves.push(arc1Curve)

            // 第二段：沿20度方向的直线
            const line2Start = turn1End
            const line2EndX = line2Start.x + secondSegmentLength * Math.cos(angle20)
            const line2EndZ = line2Start.z + secondSegmentLength * Math.sin(angle20)
            const line2End = new THREE.Vector3(line2EndX, 0, line2EndZ)
            curves.push(new THREE.LineCurve3(line2Start, line2End))

            // 第二个转弯：从20度转回水平（镜像对称）
            const turn2Start = line2End

            // 圆心：从起点沿垂直于20度的方向偏移
            // 垂直于20度向右就是 angle20 - 90度
            const perpAngle = angle20 - Math.PI/2
            const arc2CenterX = turn2Start.x + arcRadius * Math.cos(perpAngle)
            const arc2CenterZ = turn2Start.z + arcRadius * Math.sin(perpAngle)

            const arcPoints2 = []
            for (let i = 0; i <= arcSteps; i++) {
              const t = i / arcSteps
              // 从20度+90度的方向，逆时针转20度到90度方向
              const baseAngle = angle20 + Math.PI/2  // 起始是20度方向
              const currentAngle = baseAngle - t * angle20  // 逆时针转20度
              const px = arc2CenterX + arcRadius * Math.cos(currentAngle)
              const pz = arc2CenterZ + arcRadius * Math.sin(currentAngle)
              arcPoints2.push(new THREE.Vector3(px, 0, pz))
            }
            const arc2Curve = new THREE.CatmullRomCurve3(arcPoints2)
            const turn2End = arcPoints2[arcPoints2.length - 1]
            curves.push(arc2Curve)

            // 第三段：水平向右
            const line3Start = turn2End
            const line3End = new THREE.Vector3(line3Start.x + thirdSegmentLength, 0, line3Start.z)
            curves.push(new THREE.LineCurve3(line3Start, line3End))

            // 组合路径
            const pathCurve = new THREE.CurvePath()
            curves.forEach(c => pathCurve.add(c))

            // 创建履带表面
            const beltMaterial = new THREE.MeshStandardMaterial({
              color: 0x555555,  // 改为深灰色（Z字型传送带）
              metalness: 0,
              roughness: 0.95,
              side: THREE.DoubleSide
            })

            const numSegments = 100
            for (let i = 0; i < numSegments; i++) {
              const t1 = i / numSegments
              const t2 = (i + 1) / numSegments

              const p1 = pathCurve.getPointAt(t1)
              const p2 = pathCurve.getPointAt(t2)
              const tangent1 = pathCurve.getTangentAt(t1)
              const tangent2 = pathCurve.getTangentAt(t2)

              const normal1 = new THREE.Vector3(-tangent1.z, 0, tangent1.x).normalize()
              const normal2 = new THREE.Vector3(-tangent2.z, 0, tangent2.x).normalize()

              const halfWidth = width / 2
              const vertices = new Float32Array([
                p1.x - normal1.x * halfWidth, elevationHeight + 0.02, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + 0.02, p2.z - normal2.z * halfWidth,
                p1.x + normal1.x * halfWidth, elevationHeight + 0.02, p1.z + normal1.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + 0.02, p2.z + normal2.z * halfWidth,
              ])

              const geometry = new THREE.BufferGeometry()
              geometry.setAttribute('position', new THREE.BufferAttribute(vertices, 3))
              geometry.setIndex([0, 1, 2, 2, 1, 3])
              geometry.computeVertexNormals()

              const mesh = new THREE.Mesh(geometry, beltMaterial)
              mesh.castShadow = true
              mesh.receiveShadow = true
              group.add(mesh)
            }

            // 添加滚筒
            const numRollers = 30
            for (let i = 0; i <= numRollers; i++) {
              const t = i / numRollers
              const point = pathCurve.getPointAt(t)
              const tangent = pathCurve.getTangentAt(t)
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              const halfWidth = width / 2
              const leftEnd = new THREE.Vector3(point.x - normal.x * halfWidth, 0, point.z - normal.z * halfWidth)
              const rightEnd = new THREE.Vector3(point.x + normal.x * halfWidth, 0, point.z + normal.z * halfWidth)
              const center = new THREE.Vector3().lerpVectors(leftEnd, rightEnd, 0.5)
              const direction = new THREE.Vector3().subVectors(rightEnd, leftEnd).normalize()

              const roller = new THREE.Mesh(
                new THREE.CylinderGeometry(0.04, 0.04, width, 12),
                new THREE.MeshStandardMaterial({ color: 0x333333, metalness: 0, roughness: 0.95 }) // 改为浅黑色（C字型和Z字型）
              )
              roller.position.copy(center)
              roller.position.y = elevationHeight
              const up = new THREE.Vector3(0, 1, 0)
              const quaternion = new THREE.Quaternion()
              quaternion.setFromUnitVectors(up, direction)
              roller.quaternion.copy(quaternion)
              group.add(roller)
            }

            // 添加侧边框架（使用与第一个Z型相同的方法）
            const frameMaterial = new THREE.MeshStandardMaterial({
              color: 0xc9b583,
              metalness: 0.7,
              roughness: 0.3
            })

            const numPoints = 100
            for (let side = -1; side <= 1; side += 2) {
              const framePoints = []
              for (let i = 0; i <= numPoints; i++) {
                const t = i / numPoints
                const point = pathCurve.getPointAt(t)
                const tangent = pathCurve.getTangentAt(t)
                const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()
                const offset = normal.multiplyScalar(side * width * 0.5)
                framePoints.push(point.clone().add(offset))
              }

              const frameCurve = new THREE.CatmullRomCurve3(framePoints)
              const frameGeometry = new THREE.TubeGeometry(frameCurve, 100, 0.03, 8, false)
              const frameMesh = new THREE.Mesh(frameGeometry, frameMaterial)
              frameMesh.position.y = elevationHeight + 0.1
              group.add(frameMesh)
            }

            // 添加支腿
            const legMaterial = new THREE.MeshStandardMaterial({
              color: 0xa0a0a0,
              metalness: 0.6,
              roughness: 0.4
            })

            const totalLength = pathCurve.getLength()
            const legSpacing = 0.8
            const numLegs = Math.ceil(totalLength / legSpacing)

            for (let i = 0; i <= numLegs; i++) {
              const t = i / numLegs
              const point = pathCurve.getPointAt(t)
              const tangent = pathCurve.getTangentAt(t)
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              for (let side = -1; side <= 1; side += 2) {
                const legOffset = normal.clone().multiplyScalar(side * (width * 0.4))
                const legPosition = point.clone().add(legOffset)

                const leg = new THREE.Mesh(
                  new THREE.CylinderGeometry(0.04, 0.04, elevationHeight, 8),
                  legMaterial
                )
                leg.position.set(legPosition.x, elevationHeight / 2, legPosition.z)
                leg.castShadow = true
                group.add(leg)

                const foot = new THREE.Mesh(
                  new THREE.CylinderGeometry(0.052, 0.04, 0.02, 8),
                  legMaterial
                )
                foot.position.set(legPosition.x, 0.01, legPosition.z)
                group.add(foot)
              }
            }

            return group
          }

          const conveyor20deg = create20DegreeZConveyor(s2StartX, s2StartZ, 0.8)
          area.add(conveyor20deg)

          // 在Z字型传送带第三段下方添加白色架子（根据标记位置）
          // Z字型传送带参数：firstSegmentLength = 1.0, secondSegmentLength = 2.3, transitionLength = 1.2
          const angle20 = 20 * Math.PI / 180

          // 计算第二个转弯后第三段起点的位置
          const arc1EndX = s2StartX + 1.2 * Math.cos(angle20)
          const arc1EndZ = s2StartZ + 1.2 * Math.sin(angle20)

          const line2EndX = arc1EndX + 2.3 * Math.cos(angle20)
          const line2EndZ = arc1EndZ + 2.3 * Math.sin(angle20)

          // 第二个转弯结束点（第三段起点）
          const arc2Radius = 1.5
          const perpAngle = angle20 - Math.PI/2
          const arc2CenterX = line2EndX + arc2Radius * Math.cos(perpAngle)
          const arc2CenterZ = line2EndZ + arc2Radius * Math.sin(perpAngle)

          const arc2EndX = arc2CenterX + arc2Radius * Math.sin(angle20)

          // 架子放在第三段的起点位置
          const zShelfX = arc2EndX + 0.5 - 0.2  // 第三段起点稍微向右，再向左移动0.2
          const zShelfZ = s2StartZ + 1.0  // 向上移动一米

          const zShelfUnderCurve = createShelfUnderCurve(zShelfX, zShelfZ)
          // 旋转90度，使架子竖着显示
          zShelfUnderCurve.rotation.y = Math.PI / 2
          area.add(zShelfUnderCurve)

          // 在Z字型传送带末端添加称重机
          // Z字型传送带第三段长度为1.5米
          const thirdSegmentLength = 1.5

          // 计算Z字型传送带第三段起点（arc2结束点）
          // 需要重新计算完整的arc2EndZ
          const baseAngle = angle20 + Math.PI/2
          const endAngle = baseAngle - angle20
          const arc2EndZ = arc2CenterZ + arc2Radius * Math.sin(endAngle)

          // Z字型第三段末端位置
          const zEndX = arc2EndX + thirdSegmentLength
          const zEndZ = arc2EndZ

          // 1. 在Z字型末端和称重机之间添加进料传送带（0.6米）- 向下移动0.4米
          const zInputConveyor = createRealisticRollerConveyor(0.6, 0.8)
          zInputConveyor.position.set(
            zEndX + 0.3,  // Z字型末端后0.3米作为中心
            0,
            zEndZ - 0.4  // 向下移动0.4米
          )
          area.add(zInputConveyor)

          // 2. 创建第二个称重机 - 向下移动0.4米
          const zWeightDetector = createDetailedCheckweigher()
          zWeightDetector.position.set(
            zEndX + 1.3,  // 在进料传送带后面（称重机长约1.8米，所以中心在1.3）
            0,
            zEndZ - 0.4  // 向下移动0.4米
          )
          area.add(zWeightDetector)

          // 3. 在第二个称重机右侧添加两个C字型传送带
          const zCheckweigherEndX = zEndX + 1.3 + 0.9  // 称重机右侧末端
          const zCheckweigherZ = zEndZ - 0.4  // 称重机Z坐标

          // 添加第一个C字型传送带（上方，第二段向上）
          const zCConveyor1 = createCShapeConveyor(zCheckweigherEndX, zCheckweigherZ - 0.4, 0.8, true)
          area.add(zCConveyor1)

          // 添加第二个C字型传送带（下方，第二段向下）
          const zCConveyor2 = createCShapeConveyor(zCheckweigherEndX, zCheckweigherZ + 0.4, 0.8, false)
          area.add(zCConveyor2)

          // C字型传送带第二段末端连接横向传送带
          const zCSegmentLength = 0.8
          const zCArcRadius = 1.2
          // 第二段末端X坐标：起点 + 第一段 + 弧半径
          const zCSecondSegmentEndX = zCheckweigherEndX + zCSegmentLength + zCArcRadius

          // 第一个C字型（向上）第二段末端的横向传送带（水平向右延伸）
          // Z坐标 = 起点Z - 起始偏移 - 弧半径 - 第二段长度
          const zCEndZ1 = zCheckweigherZ - 0.4 - zCArcRadius - zCSegmentLength
          // 延长到8.0米，只缩短右侧框架0.8米
          const zHorizontalConveyor1 = createRealisticRollerConveyor(8.0, 0.8, {
            shortenRightFrameEnd: 0.8
          })
          zHorizontalConveyor1.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // 调整中心位置以保持左端不动：长度8.0米，中心位置 = 左端 + 4.0
          zHorizontalConveyor1.position.set(zCSecondSegmentEndX + 3.6, 0, zCEndZ1)
          area.add(zHorizontalConveyor1)

          // 第二个C字型（向下）第二段末端的横向传送带（水平向右延伸）
          // Z坐标 = 起点Z + 起始偏移 + 弧半径 + 第二段长度
          const zCEndZ2 = zCheckweigherZ + 0.4 + zCArcRadius + zCSegmentLength
          // 延长到8.0米，缩短左侧框架0.8米以避免与C字型传送带末端框架重叠
          const zHorizontalConveyor2 = createRealisticRollerConveyor(8.0, 0.8, { shortenLeftFrameEnd: 0.8 })
          zHorizontalConveyor2.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // 调整中心位置以保持左端不动：长度8.0米，中心位置 = 左端 + 4.0
          zHorizontalConveyor2.position.set(zCSecondSegmentEndX + 3.6, 0, zCEndZ2)
          area.add(zHorizontalConveyor2)

          // 创建装箱机函数（更真实的工业设计）
          const createBoxingMachine = () => {
            const machine = new THREE.Group()

            // 机器尺寸（更符合实际比例）
            const width = 3.0   // 宽度
            const height = 2.8  // 高度
            const depth = 2.0   // 深度

            // 材质定义
            const blueMat = new THREE.MeshStandardMaterial({
              color: 0xf5f5f5,  // 改为白色
              metalness: 0.75,
              roughness: 0.25
            })
            const lightBlueMat = new THREE.MeshStandardMaterial({
              color: 0xffffff,  // 改为纯白色
              metalness: 0.6,
              roughness: 0.35
            })
            const darkBlueMat = new THREE.MeshStandardMaterial({
              color: 0xe8e8e8,  // 改为浅灰白色
              metalness: 0.85,
              roughness: 0.2
            })
            const metalMat = new THREE.MeshStandardMaterial({
              color: 0xf0f0f0,  // 改为白色
              metalness: 0.9,
              roughness: 0.25
            })
            const whiteMat = new THREE.MeshStandardMaterial({
              color: 0xffffff,  // 改为纯白色
              metalness: 0.4,
              roughness: 0.6
            })

            // 底座框架（加强型）
            const baseH = 0.35
            const baseFrameGeo = new THREE.BoxGeometry(width, baseH, depth)
            const baseFrame = new THREE.Mesh(baseFrameGeo, blueMat)
            baseFrame.position.y = baseH / 2
            baseFrame.castShadow = true
            machine.add(baseFrame)

            // 主体立柱（6根，更稳固）
            const pillarW = 0.12
            const pillarH = height - baseH - 0.5
            const pillarGeo = new THREE.BoxGeometry(pillarW, pillarH, pillarW)
            const pillarPositions = [
              // 四角
              [-width/2 + pillarW/2, baseH + pillarH/2, -depth/2 + pillarW/2],
              [width/2 - pillarW/2, baseH + pillarH/2, -depth/2 + pillarW/2],
              [-width/2 + pillarW/2, baseH + pillarH/2, depth/2 - pillarW/2],
              [width/2 - pillarW/2, baseH + pillarH/2, depth/2 - pillarW/2],
              // 中间两根
              [-width/2 + pillarW/2, baseH + pillarH/2, 0],
              [width/2 - pillarW/2, baseH + pillarH/2, 0]
            ]
            pillarPositions.forEach(pos => {
              const pillar = new THREE.Mesh(pillarGeo, darkBlueMat)
              pillar.position.set(pos[0], pos[1], pos[2])
              pillar.castShadow = true
              machine.add(pillar)
            })

            // 顶部框架（加厚）
            const topH = 0.5
            const topGeo = new THREE.BoxGeometry(width, topH, depth)
            const top = new THREE.Mesh(topGeo, blueMat)
            top.position.y = height - topH/2
            top.castShadow = true
            machine.add(top)

            // 顶部盖板
            const topCoverGeo = new THREE.BoxGeometry(width + 0.05, 0.1, depth + 0.05)
            const topCover = new THREE.Mesh(topCoverGeo, darkBlueMat)
            topCover.position.y = height + 0.05
            topCover.castShadow = true
            machine.add(topCover)

            // 工作区域外壳（左右两侧板）- 已去除
            const sideH = pillarH - 0.3
            // const sidePanelGeo = new THREE.BoxGeometry(0.08, sideH, depth - 0.3)

            // const leftPanel = new THREE.Mesh(sidePanelGeo, lightBlueMat)
            // leftPanel.position.set(-width/2 + 0.04, baseH + sideH/2 + 0.15, 0)
            // leftPanel.castShadow = true
            // machine.add(leftPanel)

            // const rightPanel = new THREE.Mesh(sidePanelGeo, lightBlueMat)
            // rightPanel.position.set(width/2 - 0.04, baseH + sideH/2 + 0.15, 0)
            // rightPanel.castShadow = true
            // machine.add(rightPanel)

            // 前后防护门（可视窗口 - 半透明）
            const doorMat = new THREE.MeshStandardMaterial({
              color: 0xffffff,  // 改为白色
              metalness: 0.3,
              roughness: 0.4,
              transparent: true,
              opacity: 0.6
            })
            const doorGeo = new THREE.BoxGeometry(width - 0.35, sideH, 0.06)

            const frontDoor = new THREE.Mesh(doorGeo, doorMat)
            frontDoor.position.set(0, baseH + sideH/2 + 0.15, depth/2 - 0.03)
            frontDoor.castShadow = true
            machine.add(frontDoor)

            const backDoor = new THREE.Mesh(doorGeo, doorMat)
            backDoor.position.set(0, baseH + sideH/2 + 0.15, -depth/2 + 0.03)
            backDoor.castShadow = true
            machine.add(backDoor)

            // 内部传送带（贯穿装箱机，左右两侧均延伸）
            const internalConveyorWidth = 1.6  // 传送带宽度
            const leftExtension = 0.6  // 左侧延伸长度
            const rightExtension = 0.6  // 右侧延伸长度
            const internalConveyorLength = width + leftExtension + rightExtension  // 总长度：左延伸 + 装箱机宽度 + 右延伸
            const conveyorY = baseH + 0.05  // 传送带表面位于底座顶部稍微上方
            const conveyorX = (rightExtension - leftExtension) / 2  // 居中位置（左右延伸相同时为0）

            // 传送带底座（白色）
            const conveyorBaseGeo = new THREE.BoxGeometry(internalConveyorLength, 0.15, internalConveyorWidth)
            const conveyorBaseMat = new THREE.MeshStandardMaterial({
              color: 0xf5f5f5,  // 改为白色
              metalness: 0.7,
              roughness: 0.4
            })
            const conveyorBase = new THREE.Mesh(conveyorBaseGeo, conveyorBaseMat)
            conveyorBase.position.set(conveyorX, conveyorY - 0.075, 0)
            conveyorBase.castShadow = true
            conveyorBase.receiveShadow = true
            machine.add(conveyorBase)

            // 传送带表面（白色带）
            const conveyorBeltGeo = new THREE.BoxGeometry(internalConveyorLength, 0.03, internalConveyorWidth - 0.1)
            const conveyorBeltMat = new THREE.MeshStandardMaterial({
              color: 0xffffff,  // 改为白色
              metalness: 0.6,
              roughness: 0.5
            })
            const conveyorBelt = new THREE.Mesh(conveyorBeltGeo, conveyorBeltMat)
            conveyorBelt.position.set(conveyorX, conveyorY + 0.015, 0)
            conveyorBelt.castShadow = true
            conveyorBelt.receiveShadow = true
            machine.add(conveyorBelt)

            // 传送带框架（两侧）- 改为白色
            const conveyorFrameGeo = new THREE.BoxGeometry(internalConveyorLength, 0.3, 0.1)
            const conveyorFrameMat = new THREE.MeshStandardMaterial({
              color: 0xffffff,  // 改为白色
              metalness: 0.7,
              roughness: 0.3
            })

            const conveyorFrameLeft = new THREE.Mesh(conveyorFrameGeo, conveyorFrameMat)
            conveyorFrameLeft.position.set(conveyorX, conveyorY + 0.15, -(internalConveyorWidth/2 - 0.05))
            conveyorFrameLeft.castShadow = true
            conveyorFrameLeft.receiveShadow = true
            machine.add(conveyorFrameLeft)

            const conveyorFrameRight = new THREE.Mesh(conveyorFrameGeo, conveyorFrameMat)
            conveyorFrameRight.position.set(conveyorX, conveyorY + 0.15, (internalConveyorWidth/2 - 0.05))
            conveyorFrameRight.castShadow = true
            conveyorFrameRight.receiveShadow = true
            machine.add(conveyorFrameRight)


            // 装箱工作平台（内部多层）
            const platformMat = new THREE.MeshStandardMaterial({
              color: 0xf0f0f0,  // 改为白色
              metalness: 0.85,
              roughness: 0.3
            })
            const platformGeo = new THREE.BoxGeometry(width - 0.5, 0.08, depth - 0.5)
            for (let i = 0; i < 3; i++) {
              const platform = new THREE.Mesh(platformGeo, platformMat)
              platform.position.y = baseH + 0.6 + i * 0.75
              platform.castShadow = true
              machine.add(platform)
            }

            // 支撑脚（4个加强型）
            const footGeo = new THREE.CylinderGeometry(0.08, 0.11, 0.15, 16)
            const footMat = new THREE.MeshStandardMaterial({
              color: 0xf0f0f0,  // 改为白色
              metalness: 0.85,
              roughness: 0.25
            })
            const feetPos = [
              [-width/2 + 0.2, 0.075, -depth/2 + 0.2],
              [width/2 - 0.2, 0.075, -depth/2 + 0.2],
              [-width/2 + 0.2, 0.075, depth/2 - 0.2],
              [width/2 - 0.2, 0.075, depth/2 - 0.2]
            ]
            feetPos.forEach(pos => {
              const foot = new THREE.Mesh(footGeo, footMat)
              foot.position.set(pos[0], pos[1], pos[2])
              foot.castShadow = true
              machine.add(foot)
            })

            // 品牌LOGO区域（顶部前方）
            const logoGeo = new THREE.BoxGeometry(width - 0.6, 0.18, 0.35)
            const logoMat = new THREE.MeshStandardMaterial({
              color: 0xffffff,
              metalness: 0.3,
              roughness: 0.7
            })
            const logo = new THREE.Mesh(logoGeo, logoMat)
            logo.position.set(0, height - topH - 0.09, depth/2 - 0.175)
            logo.castShadow = true
            machine.add(logo)

            // 警示条纹（顶部边缘）
            const warningGeo = new THREE.BoxGeometry(width + 0.03, 0.06, 0.08)
            const warningMat = new THREE.MeshStandardMaterial({
              color: 0xffcc00,
              metalness: 0.5,
              roughness: 0.4
            })
            const warningStripe = new THREE.Mesh(warningGeo, warningMat)
            warningStripe.position.set(0, height - topH, depth/2 + 0.04)
            machine.add(warningStripe)

            return machine
          }

          // 创建白色滚筒传送带函数
          const createWhiteRollerConveyor = (length: number, width: number) => {
            const conveyorGroup = new THREE.Group()
            const elevationHeight = 0.35

            // 底座平台（深灰色）
            const baseGeo = new THREE.BoxGeometry(width, 0.12, length)
            const base = new THREE.Mesh(baseGeo, new THREE.MeshStandardMaterial({
              color: 0x404040,
              metalness: 0.7,
              roughness: 0.4
            }))
            base.position.set(0, elevationHeight + 0.06, 0)
            base.castShadow = true
            conveyorGroup.add(base)

            // 蓝色支撑框架（两侧）
            const frameMaterial = new THREE.MeshStandardMaterial({
              color: 0x2e5c8a,
              metalness: 0.7,
              roughness: 0.3
            })
            const frameHeight = 0.25
            const frameWidth = 0.08

            const leftFrameGeo = new THREE.BoxGeometry(frameWidth, frameHeight, length)
            const leftFrame = new THREE.Mesh(leftFrameGeo, frameMaterial)
            leftFrame.position.set(-width / 2 + frameWidth / 2, elevationHeight + 0.12 + frameHeight / 2, 0)
            leftFrame.castShadow = true
            conveyorGroup.add(leftFrame)

            const rightFrame = new THREE.Mesh(leftFrameGeo, frameMaterial)
            rightFrame.position.set(width / 2 - frameWidth / 2, elevationHeight + 0.12 + frameHeight / 2, 0)
            rightFrame.castShadow = true
            conveyorGroup.add(rightFrame)

            // 白色滚筒（密集排列）
            const rollerMaterial = new THREE.MeshStandardMaterial({
              color: 0xaaaaaa,  // 浅灰色
              metalness: 0.6,
              roughness: 0.3
            })
            const rollerRadius = 0.04
            const rollerLength = width - frameWidth * 2 - 0.05
            const rollerSpacing = 0.12
            const rollerCount = Math.floor(length / rollerSpacing)

            for (let i = 0; i < rollerCount; i++) {
              const zPos = -length / 2 + rollerSpacing / 2 + i * rollerSpacing
              const rollerGeo = new THREE.CylinderGeometry(rollerRadius, rollerRadius, rollerLength, 16)
              const roller = new THREE.Mesh(rollerGeo, rollerMaterial)
              roller.rotation.z = Math.PI / 2
              roller.position.set(0, elevationHeight + 0.12 + frameHeight, zPos)
              roller.castShadow = true
              conveyorGroup.add(roller)
            }

            // 支撑腿
            const legMaterial = new THREE.MeshStandardMaterial({
              color: 0x2e5c8a,
              metalness: 0.6,
              roughness: 0.4
            })
            const legHeight = elevationHeight
            const legRadius = 0.04
            const legCount = Math.max(3, Math.ceil(length / 1.5))

            for (let i = 0; i < legCount; i++) {
              const zPos = -length / 2 + 0.2 + (i * (length - 0.4) / (legCount - 1))
              ;[-width / 2 + 0.1, width / 2 - 0.1].forEach(xPos => {
                const legGeo = new THREE.CylinderGeometry(legRadius, legRadius, legHeight, 12)
                const leg = new THREE.Mesh(legGeo, legMaterial)
                leg.position.set(xPos, legHeight / 2, zPos)
                leg.castShadow = true
                conveyorGroup.add(leg)
              })
            }

            return conveyorGroup
          }

          // 创建一条竖着的白色滚筒传送带，贯穿所有四个横向传送带并向下延长
          // 从第一台称重机的第一个横向传送带延伸到第二台称重机的第二个横向传送带，再向下延长9.3米
          const baseVerticalConveyorLength = zCEndZ2 - cEndZ1  // 基础长度
          const extensionLength = 9.3  // 向下延长9.3米（原5.3米+新增4米）
          const throughVerticalConveyorLength = baseVerticalConveyorLength + extensionLength
          const throughVerticalConveyorCenterZ = (cEndZ1 + zCEndZ2) / 2 + extensionLength / 2  // 中心Z坐标向下偏移
          const throughVerticalConveyor = createWhiteRollerConveyor(throughVerticalConveyorLength, 0.8)
          throughVerticalConveyor.rotation.y = 0  // 不旋转，保持竖着（沿Z轴方向）
          // 使用第一台称重机的X坐标，向右移动0.5米，Y坐标向下移动0.35米，让其在横向传送带下方
          const whiteConveyorX = cSecondSegmentEndX + 1.93 + 0.5
          throughVerticalConveyor.position.set(whiteConveyorX, -0.35, throughVerticalConveyorCenterZ)
          area.add(throughVerticalConveyor)

          // 在竖着的白色滚筒传送带末端创建横向的履带传送带
          const verticalConveyorEndZ = throughVerticalConveyorCenterZ + throughVerticalConveyorLength / 2
          const horizontalBeltLength = 3.0  // 横向履带传送带长度3米（再缩短1米）
          const horizontalBeltConveyor = createRealisticRollerConveyor(horizontalBeltLength, 0.8)
          horizontalBeltConveyor.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          const horizontalBeltX = whiteConveyorX + horizontalBeltLength / 2 + 0.4 - 1.0 + 0.2
          const horizontalBeltZ = verticalConveyorEndZ + 0.05 + 0.5
          horizontalBeltConveyor.position.set(
            horizontalBeltX,  // X坐标：白色传送带X + 履带长度的一半 + 0.4米偏移 - 向左移动1米 + 向右移动0.2米
            -0.15,  // Y坐标降低0.15米
            horizontalBeltZ  // Z坐标：末端位置 + 0.05米微调 + 向下移动0.5米
          )
          area.add(horizontalBeltConveyor)

          // 为横向履带传送带添加支腿
          // 传送带在Y=-0.15，支腿从地面延伸到传送带底部
          const beltBottomY = -0.15  // 传送带底部Y坐标
          const legHeight = 0.2  // 支腿高度缩短0.15米（从0.35米减到0.2米）
          const legRadius = 0.08  // 增加支腿半径到0.08米
          const legMaterial = new THREE.MeshStandardMaterial({
            color: 0x404040,  // 深灰色金属
            metalness: 0.6,
            roughness: 0.4
          })

          // 在传送带两端各添加两条支腿（共4条）
          // 因为传送带旋转了-90度，所以支腿位置需要按照旋转后的方向计算
          // 旋转后：传送带沿X轴延伸，宽度在Z轴方向
          const legPositions = [
            { x: horizontalBeltX - horizontalBeltLength / 2 + 0.5, z: horizontalBeltZ - 0.3 },  // 左前
            { x: horizontalBeltX - horizontalBeltLength / 2 + 0.5, z: horizontalBeltZ + 0.3 },  // 左后
            { x: horizontalBeltX + horizontalBeltLength / 2 - 0.5, z: horizontalBeltZ - 0.3 },  // 右前
            { x: horizontalBeltX + horizontalBeltLength / 2 - 0.5, z: horizontalBeltZ + 0.3 }   // 右后
          ]

          legPositions.forEach((pos, index) => {
            const legGeometry = new THREE.CylinderGeometry(legRadius, legRadius, legHeight, 16)
            const leg = new THREE.Mesh(legGeometry, legMaterial)
            // Y坐标：支腿顶部在传送带底部-0.15，底部在地面-0.35，中心在-0.25
            leg.position.set(pos.x, beltBottomY - legHeight / 2, pos.z)
            leg.castShadow = true
            leg.receiveShadow = true
            area.add(leg)

            // 添加底座
            const footGeometry = new THREE.CylinderGeometry(legRadius * 1.5, legRadius * 1.5, 0.03, 16)
            const foot = new THREE.Mesh(footGeometry, legMaterial)
            foot.position.set(pos.x, beltBottomY - legHeight - 0.015, pos.z)  // 底座在支腿底部
            foot.castShadow = true
            foot.receiveShadow = true
            area.add(foot)
          })

          // 在横向履带传送带右侧创建称重机（高度真实的工业设计）
          const createRealisticCheckweigher = () => {
            const group = new THREE.Group()

            // 定义尺寸常量 - 履带式称重机更紧凑
            const BELT_LENGTH = 1.2  // 履带长度
            const BELT_WIDTH = 0.6   // 履带宽度
            const BELT_HEIGHT = 0.7  // 履带高度
            const FRAME_HEIGHT = 0.15 // 底部框架高度

            // ========== 底部框架 ==========
            const frameMaterial = new THREE.MeshStandardMaterial({
              color: 0x404040,
              metalness: 0.7,
              roughness: 0.3
            })

            // 主框架（两侧纵向梁）
            const sideBeamGeo = new THREE.BoxGeometry(0.08, FRAME_HEIGHT, BELT_LENGTH)
            const leftBeam = new THREE.Mesh(sideBeamGeo, frameMaterial)
            leftBeam.position.set(-BELT_WIDTH / 2 + 0.04, FRAME_HEIGHT / 2, 0)
            group.add(leftBeam)

            const rightBeam = new THREE.Mesh(sideBeamGeo, frameMaterial)
            rightBeam.position.set(BELT_WIDTH / 2 - 0.04, FRAME_HEIGHT / 2, 0)
            group.add(rightBeam)

            // 横向连接梁（前后）
            const crossBeamGeo = new THREE.BoxGeometry(BELT_WIDTH - 0.08, FRAME_HEIGHT, 0.08)
            const frontBeam = new THREE.Mesh(crossBeamGeo, frameMaterial)
            frontBeam.position.set(0, FRAME_HEIGHT / 2, -BELT_LENGTH / 2 + 0.04)
            group.add(frontBeam)

            const backBeam = new THREE.Mesh(crossBeamGeo, frameMaterial)
            backBeam.position.set(0, FRAME_HEIGHT / 2, BELT_LENGTH / 2 - 0.04)
            group.add(backBeam)

            // 4个支脚
            const legMaterial = new THREE.MeshStandardMaterial({
              color: 0x333333,
              metalness: 0.7,
              roughness: 0.3
            })
            const legPositions = [
              { x: -BELT_WIDTH / 2 + 0.04, z: -BELT_LENGTH / 2 + 0.04 },
              { x: BELT_WIDTH / 2 - 0.04, z: -BELT_LENGTH / 2 + 0.04 },
              { x: -BELT_WIDTH / 2 + 0.04, z: BELT_LENGTH / 2 - 0.04 },
              { x: BELT_WIDTH / 2 - 0.04, z: BELT_LENGTH / 2 - 0.04 }
            ]
            legPositions.forEach(pos => {
              const legGeo = new THREE.CylinderGeometry(0.03, 0.035, FRAME_HEIGHT, 12)
              const leg = new THREE.Mesh(legGeo, legMaterial)
              leg.position.set(pos.x, FRAME_HEIGHT / 2, pos.z)
              group.add(leg)

              // 支脚垫板
              const footGeo = new THREE.CylinderGeometry(0.045, 0.045, 0.01, 16)
              const foot = new THREE.Mesh(footGeo, legMaterial)
              foot.position.set(pos.x, 0.005, pos.z)
              group.add(foot)
            })

            // ========== 履带传送系统 ==========
            // 履带材质（黑色橡胶）
            const beltMaterial = new THREE.MeshStandardMaterial({
              color: 0x1a1a1a,
              metalness: 0,
              roughness: 0.95
            })

            // 主履带面
            const beltTopGeo = new THREE.BoxGeometry(BELT_WIDTH - 0.16, 0.03, BELT_LENGTH - 0.2)
            const beltTop = new THREE.Mesh(beltTopGeo, beltMaterial)
            beltTop.position.set(0, BELT_HEIGHT, 0)
            group.add(beltTop)

            // ========== 顶部控制面板区域 ==========
            const panelMaterial = new THREE.MeshStandardMaterial({
              color: 0x1a1a1a,  // 黑色面板
              metalness: 0.7,
              roughness: 0.2
            })

            // 主控制面板（倾斜）
            const panelGeo = new THREE.BoxGeometry(BODY_WIDTH * 0.85, 0.22, 0.35)
            const panel = new THREE.Mesh(panelGeo, panelMaterial)
            panel.position.set(0, BODY_HEIGHT + LEG_HEIGHT - 0.02, -BODY_DEPTH / 2 + 0.18)
            panel.rotation.x = -0.35
            group.add(panel)

            // 面板边框
            const panelFrameMaterial = new THREE.MeshStandardMaterial({
              color: 0x888888,
              metalness: 0.8,
              roughness: 0.2
            })
            const panelFrameGeo = new THREE.BoxGeometry(BODY_WIDTH * 0.9, 0.25, 0.02)
            const panelFrame = new THREE.Mesh(panelFrameGeo, panelFrameMaterial)
            panelFrame.position.set(0, BODY_HEIGHT + LEG_HEIGHT, -BODY_DEPTH / 2 + 0.19)
            panelFrame.rotation.x = -0.35
            group.add(panelFrame)

            // 大型LED数字显示屏
            const screenMaterial = new THREE.MeshStandardMaterial({
              color: 0x008800,
              emissive: 0x00ff00,
              emissiveIntensity: 0.6,
              metalness: 0.9,
              roughness: 0.05
            })
            const screenGeo = new THREE.BoxGeometry(0.32, 0.12, 0.015)
            const screen = new THREE.Mesh(screenGeo, screenMaterial)
            screen.position.set(0, BODY_HEIGHT + LEG_HEIGHT + 0.01, -BODY_DEPTH / 2 + 0.2)
            screen.rotation.x = -0.35
            group.add(screen)

            // 显示屏保护玻璃
            const glassGeo = new THREE.BoxGeometry(0.34, 0.14, 0.01)
            const glassMaterial = new THREE.MeshPhysicalMaterial({
              color: 0xffffff,
              metalness: 0,
              roughness: 0.1,
              transmission: 0.9,
              transparent: true,
              opacity: 0.3
            })
            const glass = new THREE.Mesh(glassGeo, glassMaterial)
            glass.position.set(0, BODY_HEIGHT + LEG_HEIGHT + 0.01, -BODY_DEPTH / 2 + 0.21)
            glass.rotation.x = -0.35
            group.add(glass)

            // 控制按钮（4个，不同颜色）
            const buttonColors = [0x00cc00, 0xff0000, 0xffaa00, 0x0088ff]
            const buttonLabels = ['START', 'STOP', 'TARE', 'ZERO']
            buttonColors.forEach((color, i) => {
              const buttonMaterial = new THREE.MeshStandardMaterial({
                color: color,
                metalness: 0.4,
                roughness: 0.3,
                emissive: color,
                emissiveIntensity: 0.2
              })
              const buttonGeo = new THREE.CylinderGeometry(0.02, 0.018, 0.025, 16)
              const button = new THREE.Mesh(buttonGeo, buttonMaterial)
              button.rotation.x = Math.PI / 2 + 0.35
              button.position.set(
                -0.22 + i * 0.15,
                BODY_HEIGHT + LEG_HEIGHT - 0.08,
                -BODY_DEPTH / 2 + 0.08
              )
              group.add(button)

              // 按钮环
              const ringGeo = new THREE.TorusGeometry(0.025, 0.003, 8, 16)
              const ringMaterial = new THREE.MeshStandardMaterial({
                color: 0x666666,
                metalness: 0.8,
                roughness: 0.2
              })
              const ring = new THREE.Mesh(ringGeo, ringMaterial)
              ring.rotation.x = Math.PI / 2 + 0.35
              ring.position.copy(button.position)
              group.add(ring)
            })

            // 状态指示灯（5个）
            const lightColors = [0xff0000, 0xff0000, 0xffff00, 0x00ff00, 0x00ff00]
            const lightStates = [true, false, false, true, true]  // 哪些灯亮着
            lightColors.forEach((color, i) => {
              const lightMaterial = new THREE.MeshStandardMaterial({
                color: lightStates[i] ? color : 0x333333,
                emissive: lightStates[i] ? color : 0x000000,
                emissiveIntensity: lightStates[i] ? 0.8 : 0,
                metalness: 0.9,
                roughness: 0.1
              })
              const lightGeo = new THREE.CylinderGeometry(0.01, 0.01, 0.015, 12)
              const light = new THREE.Mesh(lightGeo, lightMaterial)
              light.rotation.x = Math.PI / 2
              light.position.set(
                0.25,
                BODY_HEIGHT + LEG_HEIGHT - 0.15 - i * 0.045,
                -BODY_DEPTH / 2 + 0.005
              )
              group.add(light)

              // 指示灯外壳
              const housingGeo = new THREE.CylinderGeometry(0.013, 0.013, 0.018, 12)
              const housingMaterial = new THREE.MeshStandardMaterial({
                color: 0x444444,
                metalness: 0.6,
                roughness: 0.3
              })
              const housing = new THREE.Mesh(housingGeo, housingMaterial)
              housing.rotation.x = Math.PI / 2
              housing.position.copy(light.position)
              group.add(housing)
            })

            // 侧面传送带框架材质
            const frameMaterial = new THREE.MeshStandardMaterial({
              color: 0x404040,
              metalness: 0.7,
              roughness: 0.3
            })

            // 左侧入口传送带区域
            const beltInHeight = 0.65
            const beltInWidth = 0.25
            const beltInDepth = 0.45

            // 左侧传送带框架
            const leftFrameGeo = new THREE.BoxGeometry(beltInWidth, 0.08, beltInDepth)
            const leftFrame1 = new THREE.Mesh(leftFrameGeo, frameMaterial)
            leftFrame1.position.set(-BODY_WIDTH / 2 - beltInWidth / 2, beltInHeight, beltInDepth / 4)
            group.add(leftFrame1)

            const leftFrame2 = new THREE.Mesh(leftFrameGeo, frameMaterial)
            leftFrame2.position.set(-BODY_WIDTH / 2 - beltInWidth / 2, beltInHeight, -beltInDepth / 4)
            group.add(leftFrame2)

            // 左侧传送带皮带
            const beltMaterial = new THREE.MeshStandardMaterial({
              color: 0x222222,
              metalness: 0,
              roughness: 0.95
            })
            const beltGeo = new THREE.BoxGeometry(beltInWidth, 0.02, beltInDepth * 0.8)
            const leftBelt = new THREE.Mesh(beltGeo, beltMaterial)
            leftBelt.position.set(-BODY_WIDTH / 2 - beltInWidth / 2, beltInHeight + 0.04, 0)
            group.add(leftBelt)

            // 左侧滚筒
            const rollerMaterial = new THREE.MeshStandardMaterial({
              color: 0x666666,
              metalness: 0.6,
              roughness: 0.3
            })
            const rollerGeo = new THREE.CylinderGeometry(0.03, 0.03, beltInDepth * 0.9, 16)
            const leftRoller1 = new THREE.Mesh(rollerGeo, rollerMaterial)
            leftRoller1.rotation.x = Math.PI / 2
            leftRoller1.position.set(-BODY_WIDTH / 2 - beltInWidth / 2, beltInHeight + 0.04, beltInDepth / 2 - 0.05)
            group.add(leftRoller1)

            const leftRoller2 = new THREE.Mesh(rollerGeo, rollerMaterial)
            leftRoller2.rotation.x = Math.PI / 2
            leftRoller2.position.set(-BODY_WIDTH / 2 - beltInWidth / 2, beltInHeight + 0.04, -beltInDepth / 2 + 0.05)
            group.add(leftRoller2)

            // 右侧出口传送带（镜像左侧）
            const rightFrame1 = new THREE.Mesh(leftFrameGeo, frameMaterial)
            rightFrame1.position.set(BODY_WIDTH / 2 + beltInWidth / 2, beltInHeight, beltInDepth / 4)
            group.add(rightFrame1)

            const rightFrame2 = new THREE.Mesh(leftFrameGeo, frameMaterial)
            rightFrame2.position.set(BODY_WIDTH / 2 + beltInWidth / 2, beltInHeight, -beltInDepth / 4)
            group.add(rightFrame2)

            const rightBelt = new THREE.Mesh(beltGeo, beltMaterial)
            rightBelt.position.set(BODY_WIDTH / 2 + beltInWidth / 2, beltInHeight + 0.04, 0)
            group.add(rightBelt)

            const rightRoller1 = new THREE.Mesh(rollerGeo, rollerMaterial)
            rightRoller1.rotation.x = Math.PI / 2
            rightRoller1.position.set(BODY_WIDTH / 2 + beltInWidth / 2, beltInHeight + 0.04, beltInDepth / 2 - 0.05)
            group.add(rightRoller1)

            const rightRoller2 = new THREE.Mesh(rollerGeo, rollerMaterial)
            rightRoller2.rotation.x = Math.PI / 2
            rightRoller2.position.set(BODY_WIDTH / 2 + beltInWidth / 2, beltInHeight + 0.04, -beltInDepth / 2 + 0.05)
            group.add(rightRoller2)

            // 中间称重平台（不锈钢材质）
            const platformMaterial = new THREE.MeshStandardMaterial({
              color: 0x888888,
              metalness: 0.8,
              roughness: 0.2
            })
            const platformGeo = new THREE.BoxGeometry(BODY_WIDTH * 0.9, 0.04, beltInDepth * 0.85)
            const platform = new THREE.Mesh(platformGeo, platformMaterial)
            platform.position.set(0, beltInHeight + 0.04, 0)
            group.add(platform)

            // 称重传感器底座（4个角）
            const sensorMaterial = new THREE.MeshStandardMaterial({
              color: 0x505050,
              metalness: 0.7,
              roughness: 0.3
            })
            const sensorPositions = [
              { x: -BODY_WIDTH / 3, z: -beltInDepth / 3 },
              { x: BODY_WIDTH / 3, z: -beltInDepth / 3 },
              { x: -BODY_WIDTH / 3, z: beltInDepth / 3 },
              { x: BODY_WIDTH / 3, z: beltInDepth / 3 }
            ]
            sensorPositions.forEach(pos => {
              const sensorGeo = new THREE.CylinderGeometry(0.04, 0.04, 0.06, 12)
              const sensor = new THREE.Mesh(sensorGeo, sensorMaterial)
              sensor.position.set(pos.x, beltInHeight - 0.03, pos.z)
              group.add(sensor)
            })

            // 4个可调支脚
            const legMaterial = new THREE.MeshStandardMaterial({
              color: 0x333333,
              metalness: 0.7,
              roughness: 0.3
            })
            const legRadius = 0.045
            const legHeight = 0.18

            const legPositions = [
              { x: -BODY_WIDTH / 2 + 0.12, z: -BODY_DEPTH / 2 + 0.12 },
              { x: BODY_WIDTH / 2 - 0.12, z: -BODY_DEPTH / 2 + 0.12 },
              { x: -BODY_WIDTH / 2 + 0.12, z: BODY_DEPTH / 2 - 0.12 },
              { x: BODY_WIDTH / 2 - 0.12, z: BODY_DEPTH / 2 - 0.12 }
            ]

            legPositions.forEach(pos => {
              // 支脚主体
              const legGeo = new THREE.CylinderGeometry(legRadius, legRadius, legHeight, 12)
              const leg = new THREE.Mesh(legGeo, legMaterial)
              leg.position.set(pos.x, legHeight / 2, pos.z)
              leg.castShadow = true
              group.add(leg)

              // 可调节螺纹部分
              const threadGeo = new THREE.CylinderGeometry(legRadius * 0.7, legRadius * 0.7, 0.04, 12)
              for (let i = 0; i < 3; i++) {
                const thread = new THREE.Mesh(threadGeo, legMaterial)
                thread.position.set(pos.x, legHeight * 0.3 + i * 0.02, pos.z)
                group.add(thread)
              }

              // 底座垫板
              const footGeo = new THREE.CylinderGeometry(legRadius * 1.8, legRadius * 1.8, 0.015, 16)
              const foot = new THREE.Mesh(footGeo, legMaterial)
              foot.position.set(pos.x, 0.008, pos.z)
              group.add(foot)
            })

            // ========== 品牌标识和标签 ==========
            // 金属铭牌
            const plateMaterial = new THREE.MeshStandardMaterial({
              color: 0xd4d4d4,
              metalness: 0.9,
              roughness: 0.15
            })
            const plateGeo = new THREE.BoxGeometry(0.25, 0.12, 0.01)
            const plate = new THREE.Mesh(plateGeo, plateMaterial)
            plate.position.set(0, BODY_HEIGHT * 0.25 + LEG_HEIGHT, -BODY_DEPTH / 2 + 0.005)
            group.add(plate)

            // 铭牌边框
            const plateBorderGeo = new THREE.BoxGeometry(0.26, 0.13, 0.008)
            const plateBorderMaterial = new THREE.MeshStandardMaterial({
              color: 0x333333,
              metalness: 0.7,
              roughness: 0.3
            })
            const plateBorder = new THREE.Mesh(plateBorderGeo, plateBorderMaterial)
            plateBorder.position.set(0, BODY_HEIGHT * 0.25 + LEG_HEIGHT, -BODY_DEPTH / 2 + 0.003)
            group.add(plateBorder)

            // 安全警告标签（黄黑条纹）
            const warningMaterial = new THREE.MeshStandardMaterial({
              color: 0xffdd00,
              metalness: 0.1,
              roughness: 0.8
            })
            const warningGeo = new THREE.BoxGeometry(0.15, 0.05, 0.005)
            const warning = new THREE.Mesh(warningGeo, warningMaterial)
            warning.position.set(-0.25, BODY_HEIGHT * 0.5 + LEG_HEIGHT, -BODY_DEPTH / 2 + 0.003)
            group.add(warning)

            // CE认证标识
            const ceLabelGeo = new THREE.BoxGeometry(0.04, 0.04, 0.005)
            const ceLabelMaterial = new THREE.MeshStandardMaterial({
              color: 0xffffff,
              metalness: 0,
              roughness: 0.9
            })
            const ceLabel = new THREE.Mesh(ceLabelGeo, ceLabelMaterial)
            ceLabel.position.set(0.28, BODY_HEIGHT * 0.15 + LEG_HEIGHT, -BODY_DEPTH / 2 + 0.003)
            group.add(ceLabel)

            // ========== 电缆和接线 ==========
            // 电源线
            const cableMaterial = new THREE.MeshStandardMaterial({
              color: 0x1a1a1a,
              metalness: 0.1,
              roughness: 0.9
            })

            // 主电源线
            const powerCableGeo = new THREE.CylinderGeometry(0.015, 0.015, 0.3, 12)
            const powerCable = new THREE.Mesh(powerCableGeo, cableMaterial)
            powerCable.position.set(-BODY_WIDTH / 2 + 0.1, LEG_HEIGHT + 0.15, BODY_DEPTH / 2 - 0.05)
            group.add(powerCable)

            // 电缆护套
            const cableGuardMaterial = new THREE.MeshStandardMaterial({
              color: 0x666666,
              metalness: 0.5,
              roughness: 0.4
            })
            const cableGuardGeo = new THREE.BoxGeometry(0.08, 0.06, 0.15)
            const cableGuard = new THREE.Mesh(cableGuardGeo, cableGuardMaterial)
            cableGuard.position.set(-BODY_WIDTH / 2 + 0.05, BODY_HEIGHT * 0.8 + LEG_HEIGHT, BODY_DEPTH / 2 - 0.001)
            group.add(cableGuard)

            // 传感器电缆（从称重平台到主体）
            for (let i = 0; i < 4; i++) {
              const sensorCableGeo = new THREE.CylinderGeometry(0.005, 0.005, 0.15, 8)
              const sensorCable = new THREE.Mesh(sensorCableGeo, cableMaterial)
              const angle = (i * Math.PI / 2) + Math.PI / 4
              sensorCable.position.set(
                Math.cos(angle) * 0.25,
                BELT_HEIGHT + LEG_HEIGHT - 0.075,
                Math.sin(angle) * 0.3
              )
              sensorCable.rotation.x = Math.PI / 6
              group.add(sensorCable)
            }

            // ========== 急停按钮 ==========
            const emergencyButtonBase = new THREE.CylinderGeometry(0.04, 0.04, 0.02, 16)
            const emergencyBaseMaterial = new THREE.MeshStandardMaterial({
              color: 0x222222,
              metalness: 0.6,
              roughness: 0.3
            })
            const emergencyBase = new THREE.Mesh(emergencyButtonBase, emergencyBaseMaterial)
            emergencyBase.rotation.x = Math.PI / 2
            emergencyBase.position.set(-0.3, BODY_HEIGHT * 0.7 + LEG_HEIGHT, -BODY_DEPTH / 2 + 0.02)
            group.add(emergencyBase)

            // 急停按钮（红色蘑菇头）
            const emergencyButtonGeo = new THREE.CylinderGeometry(0.035, 0.025, 0.03, 16)
            const emergencyButtonMaterial = new THREE.MeshStandardMaterial({
              color: 0xcc0000,
              metalness: 0.3,
              roughness: 0.5
            })
            const emergencyButton = new THREE.Mesh(emergencyButtonGeo, emergencyButtonMaterial)
            emergencyButton.rotation.x = Math.PI / 2
            emergencyButton.position.set(-0.3, BODY_HEIGHT * 0.7 + LEG_HEIGHT, -BODY_DEPTH / 2 + 0.04)
            group.add(emergencyButton)

            return group
          }

          const checkweigherAtBeltEnd = createRealisticCheckweigher()
          checkweigherAtBeltEnd.rotation.y = -Math.PI / 2  // 旋转-90度，使传送带方向与横向履带一致
          checkweigherAtBeltEnd.position.set(
            horizontalBeltX + horizontalBeltLength / 2 + 0.1 + 0.4,  // 传送带右端 + 间隙 + 称重机一半宽度
            0,
            horizontalBeltZ
          )
          area.add(checkweigherAtBeltEnd)

          // 在白色垂直传送带右侧添加横向传送带（水平向右延伸）
          // Z坐标位于垂直传送带的首部（顶端），然后向下移动0.9米
          const rightHorizontalConveyorZ = cEndZ1 + 0.9  // 在最顶部向下0.9米
          const rightHorizontalConveyor = createWhiteRollerConveyor(5.0, 0.8)
          rightHorizontalConveyor.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // X坐标：白色传送带的X + 传送带宽度的一半 + 新传送带长度的一半，然后向左移动0.1米
          rightHorizontalConveyor.position.set(whiteConveyorX + 0.4 + 2.5 - 0.1, -0.35, rightHorizontalConveyorZ)
          area.add(rightHorizontalConveyor)

          // 在白色垂直传送带中部添加第二条横向传送带
          // Z坐标位于垂直传送带的中部位置，然后向上移动2.5米
          const middleHorizontalConveyorZ = (cEndZ1 + zCEndZ2) / 2 - 2.5  // 垂直传送带的中部向上2.5米
          const middleHorizontalConveyor = createWhiteRollerConveyor(5.0, 0.8)
          middleHorizontalConveyor.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // X坐标与第一条横向传送带相同
          middleHorizontalConveyor.position.set(whiteConveyorX + 0.4 + 2.5 - 0.1, -0.35, middleHorizontalConveyorZ)
          area.add(middleHorizontalConveyor)

          // 在白色垂直传送带的中心位置添加第三条横向传送带
          // Z坐标位于垂直传送带的正中心（不含延伸部分），然后向下移动3.4米
          const centerHorizontalConveyorZ = (cEndZ1 + zCEndZ2) / 2 + 3.4  // 垂直传送带的正中心向下3.4米
          const centerHorizontalConveyor = createWhiteRollerConveyor(5.0, 0.8)
          centerHorizontalConveyor.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // X坐标与其他横向传送带相同
          centerHorizontalConveyor.position.set(whiteConveyorX + 0.4 + 2.5 - 0.1, -0.35, centerHorizontalConveyorZ)
          area.add(centerHorizontalConveyor)

          // 在白色垂直传送带的正中心位置添加第四条横向传送带
          // Z坐标位于垂直传送带的正中心（不含延伸部分），然后向下移动6.5米
          const center2HorizontalConveyorZ = (cEndZ1 + zCEndZ2) / 2 + 6.5  // 垂直传送带的正中心向下6.5米
          const center2HorizontalConveyor = createWhiteRollerConveyor(5.0, 0.8)
          center2HorizontalConveyor.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
          // X坐标与其他横向传送带相同
          center2HorizontalConveyor.position.set(whiteConveyorX + 0.4 + 2.5 - 0.1, -0.35, center2HorizontalConveyorZ)
          area.add(center2HorizontalConveyor)

          // 在四条白色横向传送带的右侧添加装箱机
          // 横向传送带长度为5.0米，右侧末端X坐标 = 中心X + 长度/2
          const conveyorEndX = whiteConveyorX + 0.4 + 2.5 - 0.1 + 2.5

          // 第一条横向传送带的装箱机
          const boxingMachine1 = createBoxingMachine()
          boxingMachine1.rotation.y = 0  // 横向放置，与传送带平行
          boxingMachine1.position.set(conveyorEndX + 0.8 - 0.1 + 1.3, 0, rightHorizontalConveyorZ - 0.4)
          area.add(boxingMachine1)

          // 第二条横向传送带的装箱机
          const boxingMachine2 = createBoxingMachine()
          boxingMachine2.rotation.y = 0  // 横向放置，与传送带平行
          boxingMachine2.position.set(conveyorEndX + 0.8 + 1.3, 0, middleHorizontalConveyorZ + 0.5)
          area.add(boxingMachine2)

          // 第三条横向传送带的装箱机
          const boxingMachine3 = createBoxingMachine()
          boxingMachine3.rotation.y = 0  // 横向放置，与传送带平行
          boxingMachine3.position.set(conveyorEndX + 0.8 + 1.3, 0, centerHorizontalConveyorZ - 0.4)
          area.add(boxingMachine3)

          // 第四条横向传送带的装箱机
          const boxingMachine4 = createBoxingMachine()
          boxingMachine4.rotation.y = 0  // 横向放置，与传送带平行
          boxingMachine4.position.set(conveyorEndX + 0.8 + 1.3, 0, center2HorizontalConveyorZ + 0.5)
          area.add(boxingMachine4)

          // 装箱机右侧出料白色滚筒传送带（连接装箱机内部传送带）
          const boxingMachineWidth = 3.0  // 装箱机宽度
          const rightExtension = 0.6  // 右侧延伸长度（与装箱机内部传送带一致）
          const outfeedConveyorLength = 7.0  // 出料传送带长度（增加到7.0米）

          // 为每个装箱机添加右侧出料传送带
          const boxingMachines = [
            { machine: boxingMachine1, z: rightHorizontalConveyorZ - 0.4 },
            { machine: boxingMachine2, z: middleHorizontalConveyorZ + 0.5 },
            { machine: boxingMachine3, z: centerHorizontalConveyorZ - 0.4 },
            { machine: boxingMachine4, z: center2HorizontalConveyorZ + 0.5 }
          ]

          boxingMachines.forEach(({ machine, z }) => {
            const outfeedConveyor = createWhiteRollerConveyor(outfeedConveyorLength, 0.8)
            outfeedConveyor.rotation.y = -Math.PI / 2  // 旋转-90度变成水平向右
            // X位置 = 装箱机X + 装箱机宽度/2 + 右侧延伸 + 出料传送带长度/2
            const outfeedX = machine.position.x + boxingMachineWidth/2 + rightExtension + outfeedConveyorLength/2
            outfeedConveyor.position.set(outfeedX, -0.35, z)
            area.add(outfeedConveyor)
          })

          // 在四条白色出料传送带右侧创建竖向传送带（贯穿四条传送带，高于白色传送带）
          // 计算竖向传送带的Z坐标范围
          const firstConveyorZ = rightHorizontalConveyorZ - 0.4  // 第一条传送带的Z坐标
          const lastConveyorZ = center2HorizontalConveyorZ + 0.5  // 第四条传送带的Z坐标
          const baseLength = Math.abs(lastConveyorZ - firstConveyorZ)  // 基础长度
          const extension = 2.0  // 两端延伸长度（上下各延伸1米）
          const verticalConveyorLength = baseLength + extension  // 竖向传送带总长度
          const verticalConveyorCenterZ = (firstConveyorZ + lastConveyorZ) / 2  // 竖向传送带中心Z坐标

          // 计算竖向传送带的X坐标（在出料传送带的右端，向左移动6米）
          const verticalConveyorX = boxingMachine1.position.x + boxingMachineWidth/2 + rightExtension + outfeedConveyorLength + 0.4 - 6.0

          // 使用与C字型连接的横向传送带相同的样式（真实滚筒传送带）
          const verticalConveyor = createRealisticRollerConveyor(verticalConveyorLength, 0.8)
          verticalConveyor.rotation.y = 0  // 不旋转，保持竖向（沿Z轴）
          // Y坐标设置为0，使传送带位于白色滚筒传送带（Y=-0.35）上方，在地面水平高度
          verticalConveyor.position.set(verticalConveyorX, 0, verticalConveyorCenterZ)
          area.add(verticalConveyor)

          // 在白色滚筒传送带右侧新增竖向白色滚筒传送带
          const firstOutfeedX = boxingMachine1.position.x + boxingMachineWidth/2 + rightExtension + outfeedConveyorLength
          const verticalWhiteConveyorX = firstOutfeedX + 0.4  // 在白色滚筒传送带右端，间隔0.4米

          // 创建竖向白色滚筒传送带（向下延长4米）
          const whiteConveyorExtendedLength = verticalConveyorLength + 4.0  // 比原长度增加4米
          const whiteConveyorCenterZ = verticalConveyorCenterZ + 2.0  // 中心向下移动2米，使延长部分在下端
          const verticalWhiteConveyor = createWhiteRollerConveyor(whiteConveyorExtendedLength, 0.8)
          verticalWhiteConveyor.rotation.y = 0  // 不旋转，保持竖向（沿Z轴）
          // Y坐标与白色出料传送带相同（-0.35），Z方向向下移动0.6米
          verticalWhiteConveyor.position.set(verticalWhiteConveyorX, -0.35, whiteConveyorCenterZ + 0.6)
          area.add(verticalWhiteConveyor)

          // 在白色滚筒竖向传送带下方创建横向白色滚筒传送带（向左延伸）
          const bottomHorizontalConveyorLength = 25.0  // 横向传送带长度（向左延长10米后总长度25米）
          const bottomHorizontalConveyorZ = whiteConveyorCenterZ + 0.6 + whiteConveyorExtendedLength / 2 + 0.2  // 竖向传送带的下端，再向下移动0.2米
          const bottomHorizontalConveyor = createWhiteRollerConveyor(bottomHorizontalConveyorLength, 0.8)
          bottomHorizontalConveyor.rotation.y = -Math.PI / 2  // 旋转-90度变成水平
          // X位置调整：保持右端不变，向左延长10米
          const bottomHorizontalConveyorX = verticalWhiteConveyorX - 12.2
          bottomHorizontalConveyor.position.set(bottomHorizontalConveyorX, -0.35, bottomHorizontalConveyorZ)
          area.add(bottomHorizontalConveyor)

          // 创建C字型白色滚筒传送带（向左→90度弯曲→向下）
          const createWhiteCShapeConveyor = (startX: number, startZ: number, width: number, isUpward: boolean = false, yOffset: number = 0) => {
            const group = new THREE.Group()
            const elevationHeight = 0.35 + yOffset  // 加上Y偏移量

            // C字型路径参数
            const segmentLength = 2.0         // 第一段和第二段长度
            const arcRadius = 1.5             // 转弯半径
            const bendAngle = 90 * Math.PI / 180  // 90度弯曲
            const zDirection = isUpward ? -1 : 1  // 向上=-1，向下=+1

            const curves = []

            // 第一段：水平向左
            const line1Start = new THREE.Vector3(startX, 0, startZ)
            const line1End = new THREE.Vector3(startX - segmentLength, 0, startZ)
            curves.push(new THREE.LineCurve3(line1Start, line1End))

            // 90度弯曲：从水平向左平滑转到垂直向下/向上
            const arcCenterX = line1End.x
            const arcCenterZ = line1End.z + arcRadius * zDirection

            const arcPoints = []
            const arcSteps = 20
            for (let i = 0; i <= arcSteps; i++) {
              const t = i / arcSteps
              let angle
              if (isUpward) {
                // 向上：圆心在上方(-Z)，从90度扫到180度
                angle = Math.PI / 2 + t * bendAngle
              } else {
                // 向下：圆心在下方(+Z)，从-90度扫到-180度
                angle = -Math.PI / 2 - t * bendAngle
              }
              const px = arcCenterX + arcRadius * Math.cos(angle)
              const pz = arcCenterZ + arcRadius * Math.sin(angle)
              arcPoints.push(new THREE.Vector3(px, 0, pz))
            }
            const arcCurve = new THREE.CatmullRomCurve3(arcPoints)
            curves.push(arcCurve)

            // 第二段：沿90度方向垂直向下/向上延伸
            const line2Start = arcPoints[arcPoints.length - 1]
            const direction = isUpward ? -bendAngle : bendAngle
            const line2End = new THREE.Vector3(
              line2Start.x + segmentLength * Math.cos(direction),
              0,
              line2Start.z + segmentLength * Math.sin(direction)
            )
            curves.push(new THREE.LineCurve3(line2Start, line2End))

            // 组合路径
            const pathCurve = new THREE.CurvePath()
            curves.forEach(c => pathCurve.add(c))

            // 白色滚筒传送带材质
            const rollerMaterial = new THREE.MeshStandardMaterial({
              color: 0xaaaaaa,  // 浅灰色滚筒
              metalness: 0.6,
              roughness: 0.3
            })

            const frameMaterial = new THREE.MeshStandardMaterial({
              color: 0x2e5c8a,  // 蓝色框架
              metalness: 0.7,
              roughness: 0.3
            })

            const baseMaterial = new THREE.MeshStandardMaterial({
              color: 0x404040,  // 深灰色底座
              metalness: 0.7,
              roughness: 0.4,
              side: THREE.DoubleSide  // 双面渲染
            })

            const legMaterial = new THREE.MeshStandardMaterial({
              color: 0x2e5c8a,  // 蓝色支腿
              metalness: 0.6,
              roughness: 0.4
            })

            // 创建底座（顶面+侧面+底面）
            const baseHeight = 0.12
            const numBaseSegments = 100

            // 顶面
            for (let i = 0; i < numBaseSegments; i++) {
              const t1 = i / numBaseSegments
              const t2 = (i + 1) / numBaseSegments

              const p1 = pathCurve.getPointAt(t1)
              const p2 = pathCurve.getPointAt(t2)
              const tangent1 = pathCurve.getTangentAt(t1)
              const tangent2 = pathCurve.getTangentAt(t2)

              const normal1 = new THREE.Vector3(-tangent1.z, 0, tangent1.x).normalize()
              const normal2 = new THREE.Vector3(-tangent2.z, 0, tangent2.x).normalize()

              const halfWidth = width / 2

              // 顶面四边形
              const topVertices = new Float32Array([
                p1.x - normal1.x * halfWidth, elevationHeight + baseHeight, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + baseHeight, p2.z - normal2.z * halfWidth,
                p1.x + normal1.x * halfWidth, elevationHeight + baseHeight, p1.z + normal1.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + baseHeight, p2.z + normal2.z * halfWidth,
              ])

              const topGeom = new THREE.BufferGeometry()
              topGeom.setAttribute('position', new THREE.BufferAttribute(topVertices, 3))
              topGeom.setIndex([0, 1, 2, 2, 1, 3])
              topGeom.computeVertexNormals()
              const topMesh = new THREE.Mesh(topGeom, baseMaterial)
              topMesh.castShadow = true
              topMesh.receiveShadow = true
              group.add(topMesh)

              // 底面四边形（稍微抬高避免z-fighting）
              const bottomVertices = new Float32Array([
                p1.x - normal1.x * halfWidth, elevationHeight + 0.001, p1.z - normal1.z * halfWidth,
                p1.x + normal1.x * halfWidth, elevationHeight + 0.001, p1.z + normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + 0.001, p2.z - normal2.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + 0.001, p2.z + normal2.z * halfWidth,
              ])

              const bottomGeom = new THREE.BufferGeometry()
              bottomGeom.setAttribute('position', new THREE.BufferAttribute(bottomVertices, 3))
              bottomGeom.setIndex([0, 2, 1, 1, 2, 3])
              bottomGeom.computeVertexNormals()
              const bottomMesh = new THREE.Mesh(bottomGeom, baseMaterial)
              bottomMesh.receiveShadow = true
              group.add(bottomMesh)

              // 左侧面
              const leftSideVertices = new Float32Array([
                p1.x - normal1.x * halfWidth, elevationHeight + 0.001, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + 0.001, p2.z - normal2.z * halfWidth,
                p1.x - normal1.x * halfWidth, elevationHeight + baseHeight, p1.z - normal1.z * halfWidth,
                p2.x - normal2.x * halfWidth, elevationHeight + baseHeight, p2.z - normal2.z * halfWidth,
              ])

              const leftSideGeom = new THREE.BufferGeometry()
              leftSideGeom.setAttribute('position', new THREE.BufferAttribute(leftSideVertices, 3))
              leftSideGeom.setIndex([0, 1, 2, 2, 1, 3])
              leftSideGeom.computeVertexNormals()
              const leftSideMesh = new THREE.Mesh(leftSideGeom, baseMaterial)
              leftSideMesh.castShadow = true
              leftSideMesh.receiveShadow = true
              group.add(leftSideMesh)

              // 右侧面
              const rightSideVertices = new Float32Array([
                p1.x + normal1.x * halfWidth, elevationHeight + 0.001, p1.z + normal1.z * halfWidth,
                p1.x + normal1.x * halfWidth, elevationHeight + baseHeight, p1.z + normal1.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + 0.001, p2.z + normal2.z * halfWidth,
                p2.x + normal2.x * halfWidth, elevationHeight + baseHeight, p2.z + normal2.z * halfWidth,
              ])

              const rightSideGeom = new THREE.BufferGeometry()
              rightSideGeom.setAttribute('position', new THREE.BufferAttribute(rightSideVertices, 3))
              rightSideGeom.setIndex([0, 2, 1, 1, 2, 3])
              rightSideGeom.computeVertexNormals()
              const rightSideMesh = new THREE.Mesh(rightSideGeom, baseMaterial)
              rightSideMesh.castShadow = true
              rightSideMesh.receiveShadow = true
              group.add(rightSideMesh)
            }

            // 添加白色滚筒
            const numRollers = 40
            for (let i = 0; i <= numRollers; i++) {
              const t = i / numRollers
              const point = pathCurve.getPointAt(t)
              const tangent = pathCurve.getTangentAt(t)
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              const halfWidth = width / 2
              const leftEnd = new THREE.Vector3(point.x - normal.x * halfWidth, 0, point.z - normal.z * halfWidth)
              const rightEnd = new THREE.Vector3(point.x + normal.x * halfWidth, 0, point.z + normal.z * halfWidth)
              const center = new THREE.Vector3().lerpVectors(leftEnd, rightEnd, 0.5)
              const direction = new THREE.Vector3().subVectors(rightEnd, leftEnd).normalize()

              const rollerLength = width - 0.16
              const roller = new THREE.Mesh(
                new THREE.CylinderGeometry(0.04, 0.04, rollerLength, 16),
                rollerMaterial
              )
              roller.position.copy(center)
              roller.position.y = elevationHeight + baseHeight + 0.25
              const up = new THREE.Vector3(0, 1, 0)
              const quaternion = new THREE.Quaternion()
              quaternion.setFromUnitVectors(up, direction)
              roller.quaternion.copy(quaternion)
              roller.castShadow = true
              group.add(roller)
            }

            // 添加侧边框架（使用BoxGeometry）
            const frameHeight = 0.25
            const frameWidth = 0.08
            const numFrameSegments = 80

            for (let i = 0; i < numFrameSegments; i++) {
              const t1 = i / numFrameSegments
              const t2 = (i + 1) / numFrameSegments

              const p1 = pathCurve.getPointAt(t1)
              const p2 = pathCurve.getPointAt(t2)
              const tangent = pathCurve.getTangentAt((t1 + t2) / 2)
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              const halfWidth = width / 2
              const segmentLen = p1.distanceTo(p2)
              const midpoint = new THREE.Vector3().lerpVectors(p1, p2, 0.5)

              // 左侧框架
              const leftFrameGeo = new THREE.BoxGeometry(frameWidth, frameHeight, segmentLen)
              const leftFrame = new THREE.Mesh(leftFrameGeo, frameMaterial)
              leftFrame.position.set(
                midpoint.x - normal.x * (halfWidth - frameWidth / 2),
                elevationHeight + baseHeight + frameHeight / 2,
                midpoint.z - normal.z * (halfWidth - frameWidth / 2)
              )
              const angle = Math.atan2(tangent.x, tangent.z)
              leftFrame.rotation.y = -angle
              leftFrame.castShadow = true
              group.add(leftFrame)

              // 右侧框架
              const rightFrameGeo = new THREE.BoxGeometry(frameWidth, frameHeight, segmentLen)
              const rightFrame = new THREE.Mesh(rightFrameGeo, frameMaterial)
              rightFrame.position.set(
                midpoint.x + normal.x * (halfWidth - frameWidth / 2),
                elevationHeight + baseHeight + frameHeight / 2,
                midpoint.z + normal.z * (halfWidth - frameWidth / 2)
              )
              rightFrame.rotation.y = -angle
              rightFrame.castShadow = true
              group.add(rightFrame)
            }

            // 添加支腿
            const legRadius = 0.04
            const legHeight = elevationHeight
            const numLegs = 12

            for (let i = 0; i <= numLegs; i++) {
              const t = i / numLegs
              const point = pathCurve.getPointAt(t)
              const tangent = pathCurve.getTangentAt(t)
              const normal = new THREE.Vector3(-tangent.z, 0, tangent.x).normalize()

              ;[-1, 1].forEach(side => {
                const legPos = new THREE.Vector3(
                  point.x + normal.x * side * (width / 2 - 0.1),
                  0,
                  point.z + normal.z * side * (width / 2 - 0.1)
                )
                const leg = new THREE.Mesh(
                  new THREE.CylinderGeometry(legRadius, legRadius, legHeight, 12),
                  legMaterial
                )
                leg.position.set(legPos.x, legHeight / 2, legPos.z)
                leg.castShadow = true
                group.add(leg)
              })
            }

            return group
          }

          // 在横向白色滚筒传送带左侧添加C字型白色滚筒传送带（向下弯曲）
          const horizontalLeftEndX = bottomHorizontalConveyorX - bottomHorizontalConveyorLength / 2
          const whiteCConveyor = createWhiteCShapeConveyor(horizontalLeftEndX, bottomHorizontalConveyorZ, 0.8, false, -0.35)
          area.add(whiteCConveyor)

          // 计算C字型传送带末端位置
          // C字型路径：向左2米 → 90度弯曲（半径1.5米，圆心在下方）→ 向下2米
          const whiteCSegmentLen = 2.0
          const whiteCRadius = 1.5
          const whiteCEndX = horizontalLeftEndX - whiteCSegmentLen  // 向左2米后的X坐标

          // 弯曲后的Z坐标计算：
          // 起点Z：bottomHorizontalConveyorZ
          // 第一段结束后Z不变：bottomHorizontalConveyorZ
          // 圆心在：bottomHorizontalConveyorZ + whiteCRadius（向下）
          // 弯曲结束点Z：圆心Z + whiteCRadius = bottomHorizontalConveyorZ + whiteCRadius + whiteCRadius
          // 但实际上弯曲是从向左转向向下，弯曲结束点Z应该是：圆心Z + 0（在圆心正下方）
          // 所以弯曲结束点Z = bottomHorizontalConveyorZ + whiteCRadius
          // 第二段向下2米后：bottomHorizontalConveyorZ + whiteCRadius + whiteCSegmentLen
          const whiteCEndZ = bottomHorizontalConveyorZ + whiteCRadius + whiteCSegmentLen

          // 在C字型传送带末端添加履带传送带（竖向，继续向下延伸）
          const whiteCEndBeltLength = 5.0  // 履带传送带长度5米
          const whiteCEndBeltConveyor = createRealisticRollerConveyor(whiteCEndBeltLength, 0.8)
          whiteCEndBeltConveyor.rotation.y = 0  // 不旋转，保持竖向（沿Z轴）
          const whiteCEndBeltX = whiteCEndX - 1.5  // 向左移动1.5米
          const whiteCEndBeltZ = whiteCEndZ + whiteCEndBeltLength / 2 + 0.05  // C字型末端Z + 传送带长度的一半 + 小间隙避免重叠
          whiteCEndBeltConveyor.position.set(
            whiteCEndBeltX,
            -0.15,  // Y坐标降低0.15米
            whiteCEndBeltZ
          )
          area.add(whiteCEndBeltConveyor)

          // 为C字型末端履带传送带添加支腿
          const cBeltLegHeight = 0.2  // 支腿高度缩短0.15米（从0.35米减到0.2米）
          const cBeltLegRadius = 0.08
          const cBeltLegMaterial = new THREE.MeshStandardMaterial({
            color: 0x404040,  // 深灰色金属
            metalness: 0.6,
            roughness: 0.4
          })

          // 在传送带两端各添加两条支腿（共4条）
          const cBeltLegPositions = [
            { x: whiteCEndBeltX - 0.3, z: whiteCEndBeltZ - whiteCEndBeltLength / 2 + 0.5 },  // 前左
            { x: whiteCEndBeltX + 0.3, z: whiteCEndBeltZ - whiteCEndBeltLength / 2 + 0.5 },  // 前右
            { x: whiteCEndBeltX - 0.3, z: whiteCEndBeltZ + whiteCEndBeltLength / 2 - 0.5 },  // 后左
            { x: whiteCEndBeltX + 0.3, z: whiteCEndBeltZ + whiteCEndBeltLength / 2 - 0.5 }   // 后右
          ]

          cBeltLegPositions.forEach((pos) => {
            const legGeometry = new THREE.CylinderGeometry(cBeltLegRadius, cBeltLegRadius, cBeltLegHeight, 16)
            const leg = new THREE.Mesh(legGeometry, cBeltLegMaterial)
            // 支腿顶部在传送带底部-0.15，底部在-0.35
            leg.position.set(pos.x, -0.15 - cBeltLegHeight / 2, pos.z)
            leg.castShadow = true
            leg.receiveShadow = true
            area.add(leg)

            // 添加底座
            const footGeometry = new THREE.CylinderGeometry(cBeltLegRadius * 1.5, cBeltLegRadius * 1.5, 0.03, 16)
            const foot = new THREE.Mesh(footGeometry, cBeltLegMaterial)
            foot.position.set(pos.x, -0.15 - cBeltLegHeight - 0.015, pos.z)
            foot.castShadow = true
            foot.receiveShadow = true
            area.add(foot)
          })
        }

        return area
      }

      // 7. 右侧办公与控制区域 - 简化版本
      const createOfficeArea = () => {
        const area = new THREE.Group()

        // 合并办公建筑（减少几何体数量）
        const officeBuilding = new THREE.Mesh(
          new THREE.BoxGeometry(10, 3.5, 10),
          new THREE.MeshStandardMaterial({
            color: 0x2c3e50,
            metalness: 0.2,
            roughness: 0.8
          })
        )
        officeBuilding.position.set(38, 1.75, 3)
        officeBuilding.castShadow = true
        area.add(officeBuilding)

        return area
      }

      // 8. 顶部存储区域 - 简化版本
      const createStorageArea = () => {
        const area = new THREE.Group()

        // 合并存储区为一个大建筑
        const storage = new THREE.Mesh(
          new THREE.BoxGeometry(20, 4, 8),
          new THREE.MeshStandardMaterial({
            color: 0x95a5a6,
            metalness: 0.3,
            roughness: 0.7
          })
        )
        storage.position.set(18, 2, 22)
        storage.castShadow = true
        area.add(storage)

        return area
      }

      // 9. 底部冷藏区域 - 简化版本
      const createFreezingArea = () => {
        const area = new THREE.Group()

        // 合并冷藏区
        const freezer = new THREE.Mesh(
          new THREE.BoxGeometry(8, 4, 12),
          new THREE.MeshStandardMaterial({
            color: 0x3498db,
            metalness: 0.5,
            roughness: 0.3
          })
        )
        freezer.position.set(-38, 2, -14)
        freezer.castShadow = true
        area.add(freezer)

        return area
      }

      // 10. 工厂墙体和区域划分
      const createFactoryWalls = () => {
        const area = new THREE.Group()

        // 外墙材质
        const wallMaterial = new THREE.MeshStandardMaterial({
          color: 0x2c3e50,
          metalness: 0.1,
          roughness: 0.9
        })

        // 左侧外墙
        const leftWall = new THREE.Mesh(
          new THREE.BoxGeometry(0.3, 5, 60),
          wallMaterial
        )
        leftWall.position.set(-48, 2.5, 0)
        leftWall.castShadow = true
        area.add(leftWall)

        // 右侧外墙
        const rightWall = new THREE.Mesh(
          new THREE.BoxGeometry(0.3, 5, 60),
          wallMaterial
        )
        rightWall.position.set(48, 2.5, 0)
        rightWall.castShadow = true
        area.add(rightWall)

        // 顶部外墙
        const topWall = new THREE.Mesh(
          new THREE.BoxGeometry(96, 5, 0.3),
          wallMaterial
        )
        topWall.position.set(0, 2.5, 30)
        topWall.castShadow = true
        area.add(topWall)

        // 底部外墙
        const bottomWall = new THREE.Mesh(
          new THREE.BoxGeometry(96, 5, 0.3),
          wallMaterial
        )
        bottomWall.position.set(0, 2.5, -30)
        bottomWall.castShadow = true
        area.add(bottomWall)

        // Zone 9 标识牌
        const zone9Label = new THREE.Mesh(
          new THREE.BoxGeometry(3, 1, 0.1),
          new THREE.MeshStandardMaterial({
            color: 0xf39c12,
            emissive: 0xe67e22,
            emissiveIntensity: 0.5
          })
        )
        zone9Label.position.set(-40, 4, 10)
        area.add(zone9Label)

        return area
      }

      // 11. 环境装饰元素
      const createEnvironmentDetails = () => {
        const area = new THREE.Group()

        // 安全标识线（黄黑条纹）
        const safetyLineMaterial = new THREE.MeshStandardMaterial({
          color: 0xffd700
        })

        // 主通道安全线
        for (let i = 0; i < 20; i++) {
          const line = new THREE.Mesh(
            new THREE.BoxGeometry(2, 0.02, 0.2),
            safetyLineMaterial
          )
          line.position.set(-30 + i * 3, 0.01, 0)
          area.add(line)
        }

        return area
      }

      // 只保留传送带网络
      const conveyorNetwork = createMainConveyorNetwork()  // 主输送网络
      conveyorNetwork.position.x = -20  // 将所有设备向左移动20米
      group.add(conveyorNetwork)

      // 工厂地面 - 根据布局扩大尺寸
      const floorGeometry = new THREE.PlaneGeometry(120, 80)
      const floorMaterial = new THREE.MeshPhongMaterial({
        color: 0x2c3e50,
        side: THREE.DoubleSide
      })
      const floor = new THREE.Mesh(floorGeometry, floorMaterial)
      floor.rotation.x = -Math.PI / 2
      floor.position.y = 0
      floor.receiveShadow = true
      group.add(floor)

      return group
    }

    const factory = createFactory()
    scene.add(factory)

    // Grid - 更大的网格以覆盖整个工厂区域
    const gridHelper = new THREE.GridHelper(120, 30, 0x3498db, 0x34495e)
    gridHelper.material.opacity = 0.25
    gridHelper.material.transparent = true
    scene.add(gridHelper)

    // Animation loop
    let animationId: number
    const animate = () => {
      animationId = requestAnimationFrame(animate)
      controls.update()
      renderer.render(scene, camera)
    }
    animate()

    // Handle resize
    const handleResize = () => {
      if (!mountRef.current) return
      const width = mountRef.current.clientWidth
      const height = mountRef.current.clientHeight
      camera.aspect = width / height
      camera.updateProjectionMatrix()
      renderer.setSize(width, height)
    }
    window.addEventListener('resize', handleResize)

    return () => {
      cancelAnimationFrame(animationId)
      window.removeEventListener('resize', handleResize)
      if (mountRef.current && renderer.domElement.parentNode) {
        mountRef.current.removeChild(renderer.domElement)
      }
      renderer.dispose()
    }
  }, [])

  // 设备运行数据
  const deviceStats = {
    total: 99,
    running: 95,
    maintenance: 3,
    fault: 1,
    utilization: 96.2,
  }

  // 工艺图谱数据
  const processData = {
    name: '主流程',
    type: 'MA3002',
    count: 34000,
    efficiency: '92.3%',
    duration: '2023.3.1',
    status: '1232单',
  }

  // 人员管理数据
  const personnelData = {
    attendance: '100%',
    onDuty: 123,
    workers: 98,
    engineers: 25,
    management: 8,
  }

  // 能耗产品品质趋势数据
  const energyTrendData = [
    { date: '08/01', 生产能耗: 35, 计划能耗: 45, 社会能耗: 25 },
    { date: '08/02', 生产能耗: 42, 计划能耗: 48, 社会能耗: 28 },
    { date: '08/03', 生产能耗: 38, 计划能耗: 46, 社会能耗: 26 },
    { date: '08/04', 生产能耗: 45, 计划能耗: 50, 社会能耗: 30 },
    { date: '08/05', 生产能耗: 40, 计划能耗: 47, 社会能耗: 27 },
    { date: '08/06', 生产能耗: 48, 计划能耗: 52, 社会能耗: 32 },
    { date: '08/07', 生产能耗: 43, 计划能耗: 49, 社会能耗: 29 },
    { date: '08/08', 生产能耗: 46, 计划能耗: 51, 社会能耗: 31 },
  ]

  // 7天能耗趋势数据
  const weeklyEnergyData = [
    { date: '03/10', value: 45 },
    { date: '03/11', value: 52 },
    { date: '03/12', value: 48 },
    { date: '03/13', value: 55 },
    { date: '03/14', value: 50 },
    { date: '03/15', value: 58 },
    { date: '03/16', value: 53 },
  ]

  // 招聘看板数据
  const recruitmentData = [
    { year: '2023年', 分值: 30, 产量: 3600, 人均产值: 10, 质量: 10 },
    { year: '2022年', 分值: 30, 产量: 600, 人均产值: 10, 质量: 4 },
    { year: '2021年', 分值: 30, 产量: 4000, 人均产值: 50, 质量: 4 },
    { year: '2020年', 分值: 60, 产量: 500, 人均产值: 40, 质量: 6 },
  ]

  // 区域传感器概览
  const sensorStatus = [
    { name: '测油温度', status: 'normal', value: 0.3 },
    { name: '温度', status: 'warning', value: 0.2 },
    { name: '电流', status: 'normal', value: 0.1 },
    { name: '电压', status: 'normal', value: 0.15 },
    { name: '功率消耗', status: 'normal', value: 0.25 },
  ]

  // 实时监测趋势
  const realtimeData = Array.from({ length: 20 }, (_, i) => ({
    time: `0:00:${i.toString().padStart(2, '0')}`,
    测油温度: Math.sin(i * 0.5) * 0.1 + 0.15,
    温度: Math.cos(i * 0.5) * 0.1 + 0.1,
    电流: Math.sin(i * 0.3 + 1) * 0.08 + 0.12,
    电压: Math.cos(i * 0.4 + 2) * 0.09 + 0.11,
  }))

  // 7天能耗趋势（右侧）
  const weeklyPowerData = Array.from({ length: 7 }, (_, i) => {
    const baseValues = [120, 150, 180, 160, 190, 170, 200]
    return {
      date: `04-${(11 + i).toString().padStart(2, '0')}`,
      value: baseValues[i % baseValues.length] + Math.random() * 50,
    }
  })

  const energyLineConfig = {
    data: energyTrendData.flatMap(item => [
      { date: item.date, type: '生产能耗', value: item.生产能耗 },
      { date: item.date, type: '计划能耗', value: item.计划能耗 },
      { date: item.date, type: '社会能耗', value: item.社会能耗 },
    ]),
    xField: 'date',
    yField: 'value',
    seriesField: 'type',
    smooth: true,
    animation: {
      appear: {
        animation: 'path-in',
        duration: 1000,
      },
    },
    color: ['#1890ff', '#52c41a', '#faad14'],
  }

  const weeklyEnergyConfig = {
    data: weeklyEnergyData,
    xField: 'date',
    yField: 'value',
    smooth: true,
    areaStyle: {
      fill: 'l(270) 0:#1890ff 1:#141414',
    },
    line: {
      color: '#1890ff',
    },
  }

  const realtimeConfig = {
    data: realtimeData.flatMap(item => [
      { time: item.time, type: '测油温度', value: item.测油温度 },
      { time: item.time, type: '温度', value: item.温度 },
      { time: item.time, type: '电流', value: item.电流 },
      { time: item.time, type: '电压', value: item.电压 },
    ]),
    xField: 'time',
    yField: 'value',
    seriesField: 'type',
    smooth: true,
    animation: {
      appear: {
        animation: 'wave-in',
        duration: 1000,
      },
    },
    color: ['#52c41a', '#faad14', '#1890ff', '#722ed1'],
  }

  const weeklyPowerConfig = {
    data: weeklyPowerData,
    xField: 'date',
    yField: 'value',
    columnStyle: {
      fill: 'l(270) 0:#1890ff 0.5:#36cfc9 1:#52c41a',
    },
  }

  return (
    <div className={styles.digitalFactory}>
      {/* 顶部标题栏 */}
      <div className={styles.header}>
        <div className={styles.headerContent}>
          <div className={styles.logo}>
            <ApiOutlined className={styles.logoIcon} />
            <span className={styles.title}>TFF数字工厂</span>
          </div>
          <div className={styles.datetime}>
            {currentTime.toLocaleString('zh-CN', {
              year: 'numeric',
              month: '2-digit',
              day: '2-digit',
              hour: '2-digit',
              minute: '2-digit',
              second: '2-digit',
              hour12: false,
            })}
          </div>
        </div>
      </div>

      {/* 主要内容区 */}
      <div className={styles.mainContent}>
        {/* 左侧面板 */}
        <div className={styles.leftPanel}>
          {/* 设备运行信息 */}
          <Card title="设备运行信息" className={styles.card} bordered={false}>
            <Row gutter={[16, 16]}>
              <Col span={12}>
                <Statistic
                  title="总数"
                  value={deviceStats.total}
                  prefix="总数:"
                  suffix="台"
                />
              </Col>
              <Col span={12}>
                <Statistic
                  title="运行"
                  value={deviceStats.running}
                  valueStyle={{ color: '#52c41a' }}
                  prefix="运行:"
                />
              </Col>
              <Col span={12}>
                <Statistic
                  title="维护"
                  value={deviceStats.maintenance}
                  valueStyle={{ color: '#faad14' }}
                  prefix="维护:"
                />
              </Col>
              <Col span={12}>
                <Statistic
                  title="故障"
                  value={deviceStats.fault}
                  valueStyle={{ color: '#ff4d4f' }}
                  prefix="故障:"
                />
              </Col>
            </Row>
            <div style={{ marginTop: 16 }}>
              <div>利用率: {deviceStats.utilization}%</div>
              <Progress
                percent={deviceStats.utilization}
                strokeColor="#52c41a"
                showInfo={false}
              />
            </div>
            <div style={{ marginTop: 8 }}>
              <div>人数: 2023/123</div>
            </div>
          </Card>

          {/* 工艺图谱 */}
          <Card title="工艺图谱" className={styles.card} bordered={false}>
            <div className={styles.processInfo}>
              <div>产品名称: {processData.name}</div>
              <div>工序号: {processData.type}</div>
              <div>产品代号: {processData.count}</div>
              <div>工序名称: {processData.efficiency}</div>
              <div>用地: {processData.duration}</div>
              <div>单位品类数量: {processData.status}</div>
            </div>
          </Card>

          {/* 人员管理 */}
          <Card title="人员管理" className={styles.card} bordered={false}>
            <div className={styles.personnelInfo}>
              <div className={styles.attendanceRate}>
                出勤人员占比 {personnelData.attendance}
              </div>
              <Row gutter={16}>
                <Col span={8}>
                  <div>在岗: {personnelData.onDuty}人</div>
                </Col>
                <Col span={8}>
                  <div>工人: {personnelData.workers}</div>
                </Col>
                <Col span={8}>
                  <div>管理: {personnelData.management}</div>
                </Col>
              </Row>
              <div style={{ marginTop: 8 }}>
                <div>职员: {personnelData.engineers}</div>
                <div>工程师: 良好</div>
              </div>
            </div>
          </Card>

          {/* 能耗产品品质趋势 */}
          <Card title="能耗产品品质趋势" className={styles.card} bordered={false}>
            <Line {...energyLineConfig} height={180} />
          </Card>

          {/* 7天能耗趋势 */}
          <Card title="7天能耗趋势" className={styles.card} bordered={false}>
            <Line {...weeklyEnergyConfig} height={150} />
          </Card>
        </div>

        {/* 中间3D场景 */}
        <div className={styles.centerPanel}>
          <div className={styles.scene3d} ref={mountRef} />
        </div>

        {/* 右侧面板 */}
        <div className={styles.rightPanel}>
          {/* 招聘看板 */}
          <Card title="招聘看板" className={styles.card} bordered={false}>
            <div className={styles.recruitmentTable}>
              <div className={styles.tableHeader}>
                <span>年份</span>
                <span>分值</span>
                <span>产量</span>
                <span>人均产值</span>
                <span>质量</span>
              </div>
              {recruitmentData.map((item, index) => (
                <div key={index} className={styles.tableRow}>
                  <span>{item.year}</span>
                  <span>{item.分值}亿</span>
                  <span>{item.产量}个</span>
                  <span>{item.人均产值}万</span>
                  <span>{item.质量}亿</span>
                </div>
              ))}
            </div>
          </Card>

          {/* 区域传感器概览 */}
          <Card title="区域传感器概览" className={styles.card} bordered={false}>
            <div className={styles.sensorStatus}>
              <div className={styles.statusLegend}>
                <span className={styles.normal}>正常</span>
                <span className={styles.warning}>普通</span>
                <span className={styles.alarm}>超限</span>
                <span className={styles.fault}>故障</span>
              </div>
              <div className={styles.heatmapPlaceholder}>
                {/* 这里可以放置热力图或状态网格 */}
                <div className={styles.timeScale}>
                  11:20 11:25 11:30 11:35 11:40 11:45 11:50 11:55
                </div>
              </div>
            </div>
          </Card>

          {/* 实时监测趋势 */}
          <Card title="实时监测趋势" className={styles.card} bordered={false}>
            <div className={styles.sensorButtons}>
              <button className={styles.active}>测油温度</button>
              <button>温度</button>
              <button>电流</button>
              <button>电压</button>
              <button>功率消耗</button>
            </div>
            <Line {...realtimeConfig} height={150} />
          </Card>

          {/* 7天能耗趋势 */}
          <Card title="7天能耗趋势" className={styles.card} bordered={false}>
            <Column {...weeklyPowerConfig} height={150} />
          </Card>
        </div>
      </div>
    </div>
  )
}

export default DigitalFactory
