          {/* 产品B产量趋势 */}
          <Card
            style={{ marginTop: '4px' }}
            className={`${styles.card} ${styles.noBorder} ${styles.withTopBorder}`}
            title={
              <div style={{ paddingBottom: '5px', paddingTop: '10px', width: '100%' }}>
                <div style={{ paddingLeft: '5%' }}>产品B产量趋势</div>
                <svg
                  style={{
